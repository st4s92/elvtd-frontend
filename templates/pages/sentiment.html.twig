{% extends 'base.html.twig' %}

{% block title %}Sentiment - Community Outlook{% endblock %}

{% block body %}
    <div class="container-fluid py-4" style="background: #0a0e17; color: #e0e0e0; min-height: 100vh;">
        <style>
            body {
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                background: #0a0e17;
                color: #e0e0e0;
                margin: 0;
                padding: 0;
            }
            .container-fluid {
                max-width: 1400px;
                padding: 1.5rem;
            }
            .card {
                background: #111827;
                border: 1px solid #1f2937;
                border-radius: 10px;
                overflow: hidden;
            }
            .card-header {
                background: #1f2937;
                border-bottom: 1px solid #374151;
                padding: 1rem 1.5rem;
                font-weight: 600;
                color: #f3f4f6;
            }
            .sentiment-badge {
                font-size: 0.8rem;
                padding: 0.4em 0.85em;
                border-radius: 1rem;
                font-weight: 600;
                white-space: nowrap;
            }
            .short-badge   { background: #991b1b; color: white; }
            .long-badge    { background: #166534;  color: white; }
            .balanced-badge{ background: #854d0e; color: white; }

            .progress {
                height: 10px;
                background: #1f2937;
                border-radius: 5px;
                overflow: hidden;
            }
            .progress-short  { background: linear-gradient(90deg, #dc2626, #f87171); }
            .progress-long   { background: linear-gradient(90deg, #16a34a, #4ade80); }

            tr.symbol-row:hover {
                background: #1f2937 !important;
                transition: background 0.15s;
            }
            .symbol-name {
                font-weight: 600;
                color: #60a5fa;
            }
            .text-red    { color: #ef4444 !important; }
            .text-green  { color: #22c55e !important; }
            .text-orange { color: #f59e0b !important; }

            .last-sync {
                font-size: 0.85rem;
                color: #9ca3af;
            }
            #loading, #error {
                min-height: 400px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
            }
        </style>

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h3 class="mb-0">Sentiments</h3>
            <div class="d-flex align-items-center gap-3">
                <div class="last-sync">
                    Last synced: <span id="last-sync-time">loading...</span>
                    <button class="btn btn-sm btn-outline-light ms-2" onclick="window.loadData && window.loadData(true)" title="Refresh now">
                        <i class="bi bi-arrow-repeat"></i>
                    </button>
                </div>
            </div>
        </div>

        <ul class="nav nav-tabs mb-4 border-bottom-0">
            <li class="nav-item">
                <a class="nav-link active" href="#">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" href="#">Listing</a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" href="#">Brokers</a>
            </li>
        </ul>

        <div id="loading" class="text-center my-5">
            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
            <p class="lead">Lade Community Outlook von Myfxbook...</p>
        </div>

        <div id="error" class="alert alert-danger d-none my-4" role="alert"></div>

        <div class="card d-none" id="outlook-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>News & Positioning Feed · Market</div>
                <i class="bi bi-info-circle" title="Community sentiment based on Myfxbook traders"></i>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead>
                    <tr>
                        <th>Symbol</th>
                        <th>Community Trend</th>
                        <th>Open Interest / Positions</th>
                        <th>Avg Short</th>
                        <th>Avg Long</th>
                        <th>Current</th>
                    </tr>
                    </thead>
                    <tbody id="outlook-table"></tbody>
                </table>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const loading = document.getElementById('loading');
                const errorEl = document.getElementById('error');
                const card = document.getElementById('outlook-card');
                const tbody = document.getElementById('outlook-table');
                const syncEl = document.getElementById('last-sync-time');

                if (!loading || !errorEl || !card || !tbody || !syncEl) {
                    console.error('Fehlende DOM-Elemente');
                    if (errorEl) {
                        errorEl.innerHTML = 'Interner Fehler: Fehlende Elemente. Bitte neu laden.';
                        errorEl.classList.remove('d-none');
                    }
                    return;
                }

                let lastSyncTime = Date.now();

                async function loadData(silent = false) {
                    if (!silent) {
                        loading.classList.remove("d-none");
                        card.classList.add("d-none");
                        errorEl.classList.add("d-none");
                        tbody.innerHTML = "";
                    }

                    try {
                        const res = await fetch('/api/myfxbook/outlook');
                        if (!res.ok) throw new Error(`HTTP ${res.status}`);

                        const json = await res.json();

                        if (json.error) {
                            throw new Error(json.message || "API-Fehler");
                        }

                        lastSyncTime = Date.now();
                        updateSyncTime();

                        renderOutlook(json.symbols || []);

                        loading.classList.add("d-none");
                        card.classList.remove("d-none");

                    } catch (err) {
                        console.error(err);
                        errorEl.textContent = "Daten konnten nicht geladen werden: " + err.message;
                        errorEl.classList.remove("d-none");
                        loading.classList.add("d-none");
                    }
                }

                function updateSyncTime() {
                    const elapsed = Math.round((Date.now() - lastSyncTime) / 1000);
                    syncEl.textContent = `${elapsed}s ago`;
                }

                function renderOutlook(symbols) {
                    tbody.innerHTML = "";

                    symbols.forEach(item => {
                        const shortPct = Math.round(item.shortPercentage || 0);
                        const longPct  = Math.round(item.longPercentage  || 0);

                        let trendText = `${shortPct}% Short`;
                        let trendClass = "short-badge";

                        if (longPct > shortPct + 5) {
                            trendText = `${longPct}% Long`;
                            trendClass = "long-badge";
                        } else if (Math.abs(shortPct - longPct) <= 10) {
                            trendText = "Balanced";
                            trendClass = "balanced-badge";
                        }

                        // Check if it's an index (simple heuristic for now)
                        const isIndex = ['US30', 'US100', 'GER40', 'JP225', 'UK100'].includes(item.name);
                        const symbolBadge = isIndex 
                            ? `<span class="badge bg-secondary ms-2" style="font-size: 0.65rem;">INDEX</span>` 
                            : '';

                        const row = document.createElement("tr");
                        row.className = "symbol-row";
                        row.innerHTML = `
                    <td class="symbol-name">
                        <div class="d-flex align-items-center">
                            ${item.name || '—'}
                            ${symbolBadge}
                        </div>
                    </td>
                    <td>
                        <span class="sentiment-badge ${trendClass}">${trendText}</span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress flex-grow-1" style="width:140px;" title="Short: ${shortPct}% / Long: ${longPct}%">
                                <div class="progress-bar progress-bar-short" style="width:${shortPct}%"></div>
                                <div class="progress-bar progress-bar-long" style="width:${longPct}%"></div>
                            </div>
                            <small class="text-muted" title="Total Positions">${(item.totalPositions || 0).toLocaleString()}</small>
                        </div>
                    </td>
                    <td class="text-red">${(item.avgShortPrice || 0).toFixed(4)}</td>
                    <td class="text-green">${(item.avgLongPrice || 0).toFixed(4)}</td>
                    <td class="fw-bold">—</td>
                `;
                        tbody.appendChild(row);
                    });
                }

                window.loadData = loadData;

                loadData();

                setInterval(() => loadData(true), 60000);
                setInterval(updateSyncTime, 1000);
            });
        </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}