{% extends 'base.html.twig' %}

{% block title %}Sentiment Analysis - ELVTD Finance
{% endblock %}

{% block body %}
	<!-- ── Custom Sentiment Styles ── -->
	<style>:root
	{
		--glass-bg: rgba(255, 255, 255, 0.03);
		--glass-border: rgba(255, 255, 255, 0.08);
		--neon-blue: #3b82f6;
		--neon-indigo: #6366f1;
		--neon-green: #10b981;
		--neon-red: #ef4444;
	}

	.sentiment-container {
		max-width: 1200px;
		margin: 0 auto;
		padding-bottom: 50px;
	}

	/* Glass Card Base */
	.glass-card-premium {
		background: #0f172a !important;
		border: 1px solid var(--glass-border);
		border-radius: 24px;
		backdrop-filter: blur(12px);
		padding: 2rem;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		color: white !important;
	}

	/* Global Gauge Section */
	.global-sentiment-wrap {
		margin-bottom: 3rem;
	}

	.sentiment-bar-main {
		height: 60px;
		background: rgba(255, 255, 255, 0.02);
		border-radius: 30px;
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.05);
		box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.2);
	}

	.sentiment-fill-long {
		height: 100%;
		background: linear-gradient(90deg, #059669, #10b981);
		box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
		transition: width 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.sentiment-fill-short {
		height: 100%;
		background: linear-gradient(90deg, #ef4444, #dc2626);
		box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
		transition: width 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.sentiment-label-wrap {
		display: flex;
		justify-content: space-between;
		margin-bottom: 12px;
		padding: 0 10px;
	}

	.label-premium {
		font-size: 0.7rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		opacity: 0.9;
	}

	.text-success {
		color: #10b981 !important;
	}
	.text-danger {
		color: #ef4444 !important;
	}
	.text-primary {
		color: #6366f1 !important;
	}

	/* Symbol Grid */
	.symbol-sentiment-item {
		background: #0f172a !important; /* Force dark navy */
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 20px;
		padding: 1.5rem;
		margin-bottom: 1.5rem;
		transition: all 0.3s ease;
		color: white !important;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
	}

	.symbol-sentiment-item:hover {
		background: #1e293b !important;
		border-color: rgba(99, 102, 241, 0.5);
		transform: translateY(-5px);
	}

	.symbol-badge {
		font-size: 1.25rem;
		font-weight: 950;
		letter-spacing: -0.01em;
		color: #fff !important;
		text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
	}

	.sentiment-mini-bar {
		height: 10px;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 6px;
		overflow: hidden;
		margin-top: 12px;
	}

	.mini-fill-long {
		background: linear-gradient(90deg, #10b981, #34d399);
		box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
	}
	.mini-fill-short {
		background: linear-gradient(90deg, #ef4444, #f87171);
		box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
	}

	.stat-val {
		font-size: 0.9rem;
		font-weight: 850;
		color: white !important;
	}
	.stat-label {
		font-size: 0.65rem;
		opacity: 0.6;
		font-weight: 700;
		letter-spacing: 0.08em;
		margin-top: 2px;
		color: #94a3b8 !important;
	}

	/* Animations */
	.stagger-item {
		opacity: 0;
		transform: translateY(20px);
	}
	.fade-up-anim {
		animation: fadeUp 0.6s forwards;
	}

	@keyframes fadeUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Hero Text */
	.hero-title {
		font-size: 2.5rem;
		font-weight: 950;
		color: #0f172a !important; /* Dark text for light backgrounds */
		letter-spacing: -0.02em;
		margin-bottom: 0.5rem;
	}

	.hero-subtitle {
		color: #334155 !important;
		font-weight: 600;
		letter-spacing: 0.02em;
		font-size: 0.95rem;
	}

	.glow-dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		background: var(--neon-blue);
		border-radius: 50%;
		margin-right: 8px;
		box-shadow: 0 0 12px var(--neon-blue);
	}
</style>

<div
	class="sentiment-container mt-4">
	<!-- ── Header Section ── -->
	<div class="mb-5 stagger-item fade-up-anim" style="animation-delay: 0.1s">
		<h1 class="hero-title">Sentiment Analysis</h1>
		<div class="d-flex align-items-center">
			<span class="glow-dot"></span>
			<span class="hero-subtitle">Globale Community-Analyse ({{ symbols|length }}
				Symbole)</span>
		</div>
	</div>


	<!-- ── Per Symbol Sentiment ── -->
	<div class="row">
		<div class="col-12">
			<h4 class="mb-4 fw-900 text-white text-opacity-80 ps-2" style="letter-spacing: 0.05em; font-size: 0.9rem;">TOP SYMBOLS BY EXPOSURE</h4>

			{% if symbols is empty %}
				<div class="glass-card-premium text-center py-5">
					<i class="fas fa-box-open text-white text-opacity-10 mb-3" style="font-size: 3rem;"></i>
					<p class="text-white text-opacity-40 fw-700">Keine aktiven Positionen gefunden.</p>
				</div>
			{% else %}
				<div class="row">
					{% for item in symbols %}
						<div class="col-md-6 col-lg-4 stagger-item fade-up-anim" style="animation-delay: {{ 0.4 + loop.index0 * 0.05 }}s">
							<div class="symbol-sentiment-item text-center">
								<div class="symbol-badge mb-3">{{ item.symbol }}</div>

								<div class="d-flex justify-content-between mb-2" style="font-size: 0.8rem; font-weight: 850;">
									<span class="text-success">{{ item.buy_pct }}% BUY</span>
									<span class="text-danger">{{ item.sell_pct }}% SELL</span>
								</div>

								<div class="sentiment-mini-bar d-flex">
									<div class="mini-fill-long h-100" style="width: {{ item.buy_pct }}%"></div>
									<div class="mini-fill-short h-100" style="width: {{ item.sell_pct }}%"></div>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}
		</div>
	</div>
</div>{% endblock %}
