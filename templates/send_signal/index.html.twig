{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <h3 class="mb-0 h4 font-weight-bolder">Send TradingView Signal</h3>

        <div class="row mb-4">
            <p>Beispiel:</p>
            <code>
                { "license": "8b5f5280-9b06-4c3c-889c-175df047ba91", "symbol": "US100", "action": "buy", "price": "20235" }
            </code>
        </div>

        <div class="row mb-4">
            <p>Test Signal senden:</p>
            <form id="signalForm">
                <div class="mb-3">
                    <label for="signal" class="form-label">Signal JSON</label>
                    <textarea class="form-control" id="signal" rows="10" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Send Signal</button>
            </form>
            <div id="responseMessage" class="mt-3"></div>
        </div>
    </div>

    <script>
        document.getElementById('signalForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const signal = document.getElementById('signal').value;
            const responseMessage = document.getElementById('responseMessage');

            try {
                const response = await fetch('/api/send-signal', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({signal}),
                });

                const result = await response.json();

                console.log(result);

                if (response.ok) {
                    responseMessage.textContent = 'Signal sent successfully!';
                    responseMessage.className = 'text-success';
                } else {
                    responseMessage.textContent = result.error || 'An error occurred.';
                    responseMessage.className = 'text-danger';
                }
            } catch (error) {
                responseMessage.textContent = 'An error occurred.';
                responseMessage.className = 'text-danger';
            }
        });
    </script>
{% endblock %}