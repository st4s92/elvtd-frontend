{% extends 'base.html.twig' %}

{% block title %}Agents
{% endblock %}

{% block body %}
	<style>
	/* ══════════════════════════════════════════════════════
   AGENTS PAGE — Premium Animated Design
   ══════════════════════════════════════════════════════ */:root
	{
		--ag-bg: #f8fafc;
		--ag-card: #ffffff;
		--ag-dark: #0f172a;
		--ag-dim: #64748b;
		--ag-green: #16a34a;
		--ag-cyan: #06b6d4;
		--ag-border: rgba(0, 0, 0, 0.06);
		--ag-glass: rgba(255, 255, 255, 0.85);
	}
	body {
		background: radial-gradient(at 0% 0%, rgba(22,163,74,0.06) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(6, 182, 212, 0.06) 0px, transparent 50%), var(--ag-bg);
		background-attachment: fixed;
	}

	.agents-wrap {
		padding: 2rem 0 5rem;
	}
	.agents-container {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ══════════════════════════════════════════════════════
	   LOADING OVERLAY — AI Neural Network
	   ══════════════════════════════════════════════════════ */
	#agentsLoadingOverlay {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: #f8fafc;
		overflow: hidden;
	}
	#agentsLoadingOverlay.fade-out {
		animation: agOverlayFade 0.8s ease forwards;
	}
	@keyframes agOverlayFade {
		to {
			opacity: 0;
			pointer-events: none;
		}
	}
	#agentsCanvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
	.ag-node-network {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -55%);
		width: 420px;
		height: 420px;
		z-index: 1;
	}
	.ag-node-center {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 72px;
		height: 72px;
		background: rgba(255, 255, 255, 0.95);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 0 40px rgba(22, 163, 74, 0.3), 0 0 80px rgba(22, 163, 74, 0.1), 0 4px 20px rgba(0, 0, 0, 0.08);
		font-size: 1.6rem;
		color: #16a34a;
		z-index: 3;
		animation: agNodePulse 2s ease-in-out infinite;
	}
	@keyframes agNodePulse {
		0,
		100% {
			box-shadow: 0 0 40px rgba(22, 163, 74, 0.3), 0 0 80px rgba(22, 163, 74, 0.1), 0 4px 20px rgba(0, 0, 0, 0.08);
		}
		50% {
			box-shadow: 0 0 60px rgba(22, 163, 74, 0.4), 0 0 120px rgba(22, 163, 74, 0.15), 0 4px 20px rgba(0, 0, 0, 0.08);
		}
	}
	.ag-orbit-node {
		position: absolute;
		width: 52px;
		height: 52px;
		background: rgba(255, 255, 255, 0.92);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 0 24px rgba(0, 0, 0, 0.06), 0 4px 12px rgba(0, 0, 0, 0.05);
		font-size: 1.1rem;
		z-index: 3;
		opacity: 0;
		animation: agOrbitAppear 0.6s ease forwards;
	}
	.ag-orbit-node:nth-child(3) {
		top: -16px;
		left: 50%;
		transform: translateX(-50%);
		animation-delay: 0.15s;
	}
	.ag-orbit-node:nth-child(4) {
		bottom: -16px;
		left: 50%;
		transform: translateX(-50%);
		animation-delay: 0.3s;
	}
	.ag-orbit-node:nth-child(5) {
		left: -16px;
		top: 50%;
		transform: translateY(-50%);
		animation-delay: 0.45s;
	}
	.ag-orbit-node:nth-child(6) {
		right: -16px;
		top: 50%;
		transform: translateY(-50%);
		animation-delay: 0.6s;
	}
	.ag-orbit-node:nth-child(7) {
		top: 12%;
		left: 12%;
		animation-delay: 0.75s;
	}
	.ag-orbit-node:nth-child(8) {
		top: 12%;
		right: 12%;
		animation-delay: 0.9s;
	}
	@keyframes agOrbitAppear {
		from {
			opacity: 0;
			scale: 0.4;
		}
		to {
			opacity: 1;
			scale: 1;
		}
	}
	.ag-beam-lines {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: 2;
	}
	.ag-beam-line {
		stroke: url('#agBeamGrad');
		stroke-width: 1.5;
		opacity: 0.5;
	}
	.ag-beam-particle {
		fill: #16a34a; filter: drop-shadow(0 0 6px rgba(22,163,74,0.7));
	}
	.ag-load-ui {
		position: absolute;
		bottom: 10%;
		left: 50%;
		transform: translateX(-50%);
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
	}
	.ag-load-title {
		font-size: 1.3rem;
		font-weight: 800;
		color: var(--ag-dark);
		letter-spacing: -0.02em;
	}
	.ag-load-sub {
		font-size: 0.82rem;
		color: var(--ag-dim);
		font-weight: 500;
		transition: opacity 0.3s;
	}
	.ag-load-bar {
		width: 300px;
		height: 4px;
		background: rgba(0, 0, 0, 0.06);
		border-radius: 4px;
		overflow: hidden;
		margin-top: 0.5rem;
	}
	.ag-load-fill {
		height: 100%;
		width: 0;
		background: linear-gradient(90deg, #16a34a, #22c55e, #06b6d4);
		border-radius: 4px;
		transition: width 0.5s ease;
		box-shadow: 0 0 12px rgba(22, 163, 74, 0.4);
	}
	.ag-load-pct {
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--ag-dim);
		font-family: 'JetBrains Mono', monospace;
	}

	/* ── Hero Section ── */
	.agents-hero {
		position: relative;
		border-radius: 28px;
		overflow: hidden;
		margin-bottom: 3rem;
		background: linear-gradient(135deg, #f0ede6 0%, #e8e4db 50%, #ece9e1 100%);
		padding: 3.5rem 3rem;
	}
	.agents-hero-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}
	.agents-hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 16px;
		border-radius: 100px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		background: rgba(22, 163, 74, 0.1);
		color: #16a34a;
		border: 1px solid rgba(22, 163, 74, 0.15);
		margin-bottom: 1rem;
		position: relative;
		z-index: 1;
	}
	.agents-hero-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
		position: relative;
		z-index: 1;
	}
	@media(max-width: 768px) {
		.agents-hero-grid {
			grid-template-columns: 1fr;
		}
	}
	.agents-hero h1 {
		font-size: 2.4rem;
		font-weight: 800;
		color: #1a1a1a;
		letter-spacing: -0.04em;
		margin: 0 0 1rem;
		line-height: 1.2;
	}
	.agents-hero h1 span {
		color: #1a1a1a;
		-webkit-text-fill-color: initial;
	}
	.agents-hero-desc {
		font-size: 0.95rem;
		color: #6b7280;
		line-height: 1.7;
	}
	.agents-hero-features {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
		margin-top: 2rem;
		position: relative;
		z-index: 1;
	}
	.agents-hero-feat {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 12px 16px;
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.5);
		border: 1px solid rgba(0, 0, 0, 0.06);
		transition: all 0.3s;
		backdrop-filter: blur(8px);
	}
	.agents-hero-feat:hover {
		background: rgba(255, 255, 255, 0.7);
		border-color: rgba(22, 163, 74, 0.25);
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
	}
	.agents-hero-feat-icon {
		width: 36px;
		height: 36px;
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.85rem;
		flex-shrink: 0;
	}
	.feat-green {
		background: rgba(22, 163, 74, 0.12);
		color: #16a34a;
	}
	.feat-cyan {
		background: rgba(6, 182, 212, 0.12);
		color: #0891b2;
	}
	.feat-purple {
		background: rgba(139, 92, 246, 0.12);
		color: #7c3aed;
	}
	.feat-amber {
		background: rgba(245, 158, 11, 0.12);
		color: #d97706;
	}
	.agents-hero-feat span {
		font-size: 0.82rem;
		font-weight: 600;
		color: #374151;
	}

	/* Expand/collapse */
	.hero-expand-content {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.6s ease;
	}
	.hero-expand-content.expanded {
		max-height: 600px;
	}
	.hero-toggle {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 20px;
		border-radius: 10px;
		font-size: 0.8rem;
		font-weight: 700;
		background: rgba(255, 255, 255, 0.5);
		border: 1px solid rgba(0, 0, 0, 0.08);
		color: #6b7280;
		cursor: pointer;
		transition: all 0.3s;
		margin-top: 1.5rem;
		position: relative;
		z-index: 1;
	}
	.hero-toggle:hover {
		background: rgba(22, 163, 74, 0.1);
		color: #16a34a;
		border-color: rgba(22, 163, 74, 0.3);
	}

	/* ── Section Headers ── */
	.section-header {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 2rem;
	}
	.section-header h2 {
		font-size: 1.6rem;
		font-weight: 800;
		color: var(--ag-dark);
		letter-spacing: -0.03em;
		margin: 0;
	}
	.section-header .section-count {
		font-size: 0.72rem;
		font-weight: 700;
		background: rgba(22, 163, 74, 0.1);
		color: var(--ag-green);
		padding: 4px 12px;
		border-radius: 100px;
	}

	/* ── Agent Cards Grid ── */
	.agents-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	/* ── Agent Card ── */
	.agent-card {
		position: relative;
		border-radius: 24px;
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.175,0.885,0.32,1.275);
	}
	.agent-card:hover {
		transform: translateY(-6px);
	}
	.agent-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: 24px;
		padding: 2px;
		background: linear-gradient(135deg, rgba(22,163,74,0.3), rgba(6,182,212,0.2), rgba(22,163,74,0.3));
		background-size: 200% 200%;
		animation: agBorderShift 5s ease infinite;
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		pointer-events: none;
		z-index: 1;
	}
	@keyframes agBorderShift {
		0,
		100% {
			background-position: 0 50%;
		}
		50% {
			background-position: 100% 50%;
		}
	}
	.agent-card:hover {
		box-shadow: 0 20px 60px rgba(22, 163, 74, 0.12), 0 0 40px rgba(22, 163, 74, 0.06);
	}

	.agent-card-inner {
		background: linear-gradient(160deg, #1a2332 0%, #0d1520 40%, #111b27 100%);
		border-radius: 24px;
		overflow: hidden;
	}

	/* Chart / Neural Network area */
	.agent-chart-area {
		position: relative;
		padding: 1.5rem 1.5rem 0.5rem;
	}
	.agent-chart-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 0.75rem;
		position: relative;
		z-index: 2;
	}
	.agent-apy {
		display: flex;
		flex-direction: column;
	}
	.agent-apy-label {
		font-size: 0.7rem;
		color: #64748b;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.agent-apy-val {
		font-size: 1.4rem;
		font-weight: 800;
		background: linear-gradient(135deg, #4ade80, #22d3ee);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.agent-icon {
		width: 44px;
		height: 44px;
		border-radius: 14px;
		background: rgba(22, 163, 74, 0.12);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #4ade80;
		font-size: 1.3rem;
	}
	.agent-neural-wrap {
		position: relative;
		width: 100%;
		height: 260px;
		overflow: hidden;
		border-radius: 16px;
	}
	.agent-neural-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	/* Stats row */
	.agent-stats {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 4px;
		padding: 1rem 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}
	@media(max-width: 640px) {
		.agent-stats {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	.agent-stat {
		text-align: center;
		padding: 8px 4px;
		border-radius: 10px;
		transition: background 0.2s;
	}
	.agent-stat:hover {
		background: rgba(255, 255, 255, 0.04);
	}
	.agent-stat-label {
		font-size: 0.58rem;
		color: #64748b;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		margin-bottom: 4px;
	}
	.agent-stat-val {
		font-size: 0.85rem;
		font-weight: 700;
		color: #e2e8f0;
	}

	/* Tags */
	.agent-tags {
		display: flex;
		gap: 8px;
		padding: 0 1.5rem 1rem;
		flex-wrap: wrap;
	}
	.agent-tag {
		font-size: 0.68rem;
		font-weight: 600;
		padding: 5px 12px;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: #94a3b8;
		background: rgba(255, 255, 255, 0.03);
	}

	/* Footer */
	.agent-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.5rem 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}
	.agent-name {
		font-size: 1.05rem;
		font-weight: 700;
		color: #f1f5f9;
	}
	.agent-actions {
		display: flex;
		gap: 8px;
	}
	.agent-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 9px 18px;
		border-radius: 12px;
		font-size: 0.8rem;
		font-weight: 700;
		border: none;
		cursor: pointer;
		transition: all 0.3s;
		text-decoration: none;
	}
	.agent-btn-stats {
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: #cbd5e1;
	}
	.agent-btn-stats:hover {
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		transform: translateY(-1px);
	}
	.agent-btn-subscribe {
		background: linear-gradient(135deg, #16a34a, #0ea5e9);
		color: #fff;
		box-shadow: 0 4px 16px rgba(22, 163, 74, 0.3);
	}
	.agent-btn-subscribe:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 24px rgba(22, 163, 74, 0.4);
		color: #fff;
	}

	/* ── Subscribed Agents Table ── */
	.sub-table-wrap {
		background: var(--ag-glass);
		backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.06);
	}
	.sub-table {
		width: 100%;
		border-collapse: collapse;
	}
	.sub-table th {
		background: rgba(0, 0, 0, 0.02);
		padding: 1rem 1.25rem;
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--ag-dim);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		border-bottom: 1px solid var(--ag-border);
		text-align: left;
	}
	.sub-table td {
		padding: 1rem 1.25rem;
		border-bottom: 1px solid var(--ag-border);
		vertical-align: middle;
		font-size: 0.88rem;
		color: var(--ag-dark);
	}
	.sub-table tr:last-child td {
		border-bottom: none;
	}
	.sub-table tr:hover {
		background: rgba(22, 163, 74, 0.02);
	}

	.sub-badge {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 4px 10px;
		border-radius: 8px;
		font-size: 0.68rem;
		font-weight: 700;
	}
	.sub-badge-active {
		background: rgba(22, 163, 74, 0.1);
		color: var(--ag-green);
	}
	.sub-badge-paused {
		background: rgba(100, 116, 139, 0.1);
		color: var(--ag-dim);
	}
	.sub-badge-agent {
		background: rgba(22, 163, 74, 0.1);
		color: var(--ag-green);
	}
	.sub-badge-leader {
		background: rgba(99, 102, 241, 0.1);
		color: #6366f1;
	}
	.sub-badge-subscriber {
		background: rgba(6, 182, 212, 0.1);
		color: var(--ag-cyan);
	}

	.sub-btn {
		padding: 6px 14px;
		border-radius: 8px;
		font-size: 0.75rem;
		font-weight: 700;
		border: 1px solid var(--ag-border);
		background: transparent;
		color: var(--ag-dim);
		cursor: pointer;
		transition: all 0.2s;
		text-decoration: none;
	}
	.sub-btn:hover {
		background: rgba(220, 38, 38, 0.06);
		color: #dc2626;
		border-color: rgba(220, 38, 38, 0.2);
	}
	.sub-btn-edit {
		border: none;
		background: none;
		padding: 4px 8px;
		color: var(--ag-dim);
		cursor: pointer;
	}
	.sub-btn-edit:hover {
		color: var(--ag-green);
	}

	/* ── Master Orders Section ── */
	.master-orders-section {
		margin-bottom: 3rem;
	}
	.master-orders-card {
		position: relative;
		border-radius: 24px;
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.175,0.885,0.32,1.275);
	}
	.master-orders-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: 24px;
		padding: 2px;
		background: linear-gradient(135deg, rgba(22,163,74,0.3), rgba(6,182,212,0.2), rgba(139,92,246,0.2), rgba(22,163,74,0.3));
		background-size: 300% 300%;
		animation: agBorderShift 6s ease infinite;
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		pointer-events: none;
		z-index: 1;
	}
	.master-orders-inner {
		background: linear-gradient(160deg, #1a2332 0%, #0d1520 40%, #111b27 100%);
		border-radius: 24px;
		overflow: hidden;
	}
	.master-orders-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		height: 600px;
	}
	@media(max-width: 768px) {
		.master-orders-layout {
			grid-template-columns: 1fr;
		}
	}
	/* Left: TradingView Chart */
	.mo-chart-side {
		position: relative;
		overflow: hidden;
		border-right: 1px solid rgba(255, 255, 255, 0.05);
	}
	.mo-chart-side iframe {
		width: 100%;
		height: 100%;
		border: none;
	}
	.mo-chart-header {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
