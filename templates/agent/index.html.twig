									</button>
								{% endif %}
							</div>
						</div>
					</div>
				</div>

				{# Subscribe Modal (preserved) #}
				<div class="modal fade" id="subscribeModal{{ account.id }}" tabindex="-1" role="dialog" aria-hidden="true">
					<div class="modal-dialog modal-dialog-centered" role="document">
						<div class="modal-content" style="border-radius: 20px; border: none;">
							<div class="modal-header border-0 pb-0">
								<h5 class="fw-bold">
									<i class="fas fa-plug me-2"></i>
									{{ agent ? agent.name : 'Kein Agent gefunden' }}
									abonnieren</h5>
								<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
							</div>
							<form action="{{ path('app_agents_update_subscriber') }}" method="post">
								<div class="modal-body">
									<div class="py-2">
										<p style="font-size: 0.82rem; color: #64748b; line-height: 1.6;">
											<strong style="color:#0f172a;">Risikohinweis:</strong><br>
											Die Nutzung erfolgt auf eigenes Risiko. Es kann zu erheblichen Verlusten bis hin zum Totalverlust kommen. Historische Performance ist kein Indikator f&uuml;r zuk&uuml;nftige Entwicklungen.
										</p>
									</div>
									<label for="subscriberId" class="form-label fw-bold" style="font-size:0.82rem;">Dein Account</label>
									<select class="form-control rounded-pill" id="subscriberId" name="subscriberId">
										{% set activeAccounts = 0 %}
										{% for user_account in user_accounts %}
											{% if user_account.metaId|length > 1 %}
												{% set activeAccounts = 1 %}
											{% endif %}
											<option value="{{ user_account.metaId ? user_account.metaId : '' }}" {{ user_account.metaId ? '' : 'disabled' }} {{ user_account.type == 3 ? '' : 'disabled' }}>{{ user_account.name }}
												-
												{{ user_account.login }}
												{{ user_account.metaId ? '' : ' - noch nicht synchronisiert' }}</option>
										{% endfor %}
									</select>
									<input type="hidden" name="strategyId" value="{{ agent ? agent.metaId : '' }}">
									<label for="multiplier" class="form-label fw-bold mt-3" style="font-size:0.82rem;">Risiko Multiplier</label>
									<select class="form-control rounded-pill" id="multiplier" name="multiplier">
										<option value="1">1</option>
									</select>
								</div>
								<div class="modal-footer border-0 pt-0">
									<button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Abbrechen</button>
									{% if activeAccounts > 0 %}
										<button type="submit" class="btn btn-dark rounded-pill fw-bold">
											<i class="fas fa-plug me-1"></i>
											Abonnieren</button>
									{% else %}
										<p style="font-size:0.82rem; color:#64748b;">Du hast noch keinen aktiven Account.</p>
									{% endif %}
								</div>
							</form>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>

		{# ══════════════════════════════════════
																												   MASTER ORDERS
																												   ══════════════════════════════════════ #}
		<div class="master-orders-section animate-in animate-in-2">
			<div class="section-header">
				<h2>Live Master-Trades</h2>
				<span class="section-count">{{ master_trades_total }}
					Orders
					{% set open_count = 0 %}
					{% for t in master_trades %}
						{% if t.status != 700 %}
							{% set open_count = open_count + 1 %}
						{% endif %}
					{% endfor %}
					{% if open_count > 0 %}
						<span class="mo-order-count-badge">{{ open_count }}
							Open</span>
					{% endif %}
				</span>
			</div>

			<div class="master-orders-card">
				<div class="master-orders-inner">
					<div
						class="master-orders-layout">
						{# Left: TradingView Chart #}
						<div class="mo-chart-side" id="moChartSide">
							<div class="mo-chart-header">
								<span class="mo-chart-symbol" id="moChartSymbolLabel">
									<i class="fas fa-chart-line"></i>
									<span id="moChartSymbolText">USTEC</span>
								</span>
							</div>
						</div>

						{# Right: Orders list #}
						<div class="mo-orders-side">
							<div class="mo-orders-header">
								<h6>Aktuelle Positionen</h6>
								<span class="mo-badge-live">
									<span style="width:5px;height:5px;background:#4ade80;border-radius:50%;box-shadow:0 0 6px rgba(74,222,128,0.6);"></span>
									LIVE
								</span>
							</div>

							<div class="mo-orders-list" id="moOrdersList">
								{% if master_trades|length > 0 %}
									{% for trade in master_trades %}
										{% set is_open = trade.status != 700 %}
										<div class="mo-order-item{{ is_open ? ' is-open' : '' }}" data-symbol="{{ trade.order_symbol|lower }}">
											<div class="mo-order-left">
												<span class="mo-order-type {{ trade.order_type == 'DEAL_TYPE_BUY' ? 'buy' : 'sell' }}">
													{{ trade.order_type == 'DEAL_TYPE_BUY' ? 'BUY' : 'SELL' }}
												</span>
												<div>
													<div class="mo-order-symbol">{{ trade.order_symbol }}</div>
													<div class="mo-order-meta">
														<i class="fas fa-layer-group" style="font-size:0.55rem;margin-right:3px;opacity:0.5;"></i>
														{{ trade.order_lot }}
														Lot
													</div>
													<span class="mo-status-badge {{ is_open ? 'open' : 'closed' }}">
														<span class="mo-status-dot"></span>
														{{ is_open ? 'OPEN' : 'CLOSED' }}
													</span>
												</div>
											</div>
											<div class="mo-order-center">
												<div class="mo-order-times">
													<div class="mo-order-time">
														<i class="fas fa-arrow-right" style="color:#4ade80;"></i>
														{{ trade.order_open_at|date('d.m.Y H:i') }}
													</div>
													{% if not is_open and trade.order_close_at is defined and trade.order_close_at %}
														<div class="mo-order-time">
															<i class="fas fa-arrow-left" style="color:#f87171;"></i>
															{{ trade.order_close_at|date('d.m.Y H:i') }}
														</div>
													{% elseif is_open %}
														<div class="mo-order-time" style="color:rgba(74,222,128,0.5);">
															<i class="fas fa-clock" style="color:#4ade80;"></i>
															Aktiv
														</div>
													{% endif %}
												</div>
											</div>
											<div class="mo-order-right">
												<div class="mo-order-profit {{ trade.order_profit >= 0 ? 'positive' : 'negative' }}">
													{{ trade.order_profit >= 0 ? '+' : '' }}{{ trade.order_profit|number_format(2, ',', '.') }}
													&euro;
												</div>
												<div class="mo-order-date">#{{ trade.order_ticket }}</div>
											</div>
										</div>
									{% endfor %}
								{% else %}
									<div class="mo-empty">
										<i class="fas fa-satellite-dish" style="font-size:1.5rem;margin-bottom:0.75rem;display:block;opacity:0.4;"></i>
										Keine Master-Trades vorhanden.
									</div>
								{% endif %}
							</div>

							<div class="mo-search-wrap">
								<div class="mo-search">
									<input type="text" id="moSearchInput" placeholder="Search for Gold, Euro, NAS...">
									<i class="fas fa-search"></i>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# ══════════════════════════════════════
																																					   SUBSCRIBED AGENTS TABLE
																																					   ══════════════════════════════════════ #}
		<div class="section-header animate-in animate-in-3">
			<h2>Abonnierte Agents</h2>
			<span class="section-count">{{ account_agent_connections|length }}</span>
		</div>

		<div class="sub-table-wrap animate-in animate-in-3">
			<table class="sub-table">
				<thead>
					<tr>
						<th>Typ</th>
						<th>Account</th>
						<th>Agent</th>
						<th>Multiplier</th>
						<th>Status</th>
						<th>Aktion</th>
					</tr>
				</thead>
				<tbody>
					{% for connection in account_agent_connections %}
						<tr>
							<td>
								{% if connection.account.type == 1 %}
									<span class="sub-badge sub-badge-agent">
										<i class="fas fa-robot" style="font-size:0.55rem;"></i>
										Agent</span>
								{% elseif connection.account.type == 2 %}
									<span class="sub-badge sub-badge-leader">
										<i class="fas fa-crown" style="font-size:0.55rem;"></i>
										Leader</span>
								{% else %}
									<span class="sub-badge sub-badge-subscriber">
										<i class="fas fa-plug" style="font-size:0.55rem;"></i>
										Subscriber</span>
								{% endif %}
								{% if is_granted('ROLE_ADMIN') %}
									{% if account.host == 'metapi' %}
										<br><a href="https://app.metaapi.cloud/trade-copier/subscribers/{{ connection.account.metaId }}" target="_blank" style="font-size:0.65rem; color: var(--ag-dim);">{{ connection.account.host }}</a>
									{% else %}
										<br><span style="font-size:0.65rem; color: var(--ag-dim);">{{ connection.account.metaId }}</span>
									{% endif %}
								{% endif %}
							</td>
							<td>
								<strong>{{ connection.account.name }}</strong><br>
								<span style="font-size:0.72rem; color:var(--ag-dim); text-transform:uppercase;">{{ connection.account.login }}
									&bull;
									{{ connection.account.platform }}</span>
							</td>
							<td>
								<strong>{{ connection.agent.name }}</strong><br>
								<span style="font-size:0.72rem; color:var(--ag-dim);">{{ connection.name }}</span>
							</td>
							<td>
								{{ connection.multiplier }}
								<button type="button" class="sub-btn-edit" data-bs-toggle="modal" data-bs-target="#multiplierModal{{ connection.account.id }}">
									<i class="fas fa-pen" style="font-size:0.7rem;"></i>
								</button>

								<div class="modal fade" id="multiplierModal{{ connection.account.id }}" tabindex="-1" role="dialog" aria-hidden="true">
									<div class="modal-dialog modal-dialog-centered" role="document">
										<div class="modal-content" style="border-radius: 20px; border: none;">
											<div class="modal-header border-0 pb-0">
												<h5 class="fw-bold">
													<i class="fas fa-sliders-h me-2"></i>
													{{ connection.account.name }}
													-
													{{ connection.agent.name }}</h5>
												<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
											</div>
											<form action="{{ path('app_agents_update_subscriber') }}" method="post">
												<div class="modal-body">
													<label for="subscriberId" class="form-label fw-bold" style="font-size:0.82rem;">Account</label>
													<select class="form-control rounded-pill" id="subscriberId" name="subscriberId">
														<option value="{{ connection.account.metaId ? connection.account.metaId : '' }}" {{ connection.account.metaId ? '' : 'disabled' }} {{ connection.account.type == 3 ? '' : 'disabled' }}>{{ connection.account.name }}
															-
															{{ connection.account.login }}</option>
													</select>
													<input type="hidden" name="strategyId" value="{{ connection.agent ? connection.agent.metaId : '' }}">
													<label for="multiplier" class="form-label fw-bold mt-3" style="font-size:0.82rem;">Risiko Multiplier</label>
													<select class="form-control rounded-pill" id="multiplier" name="multiplier">
														<option value="1">1</option>
													</select>
												</div>
												<div class="modal-footer border-0 pt-0">
													<button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Abbrechen</button>
													<button type="submit" class="btn btn-dark rounded-pill fw-bold">
														<i class="fas fa-save me-1"></i>
														Speichern</button>
												</div>
											</form>
										</div>
									</div>
								</div>
							</td>
							<td>
								{% if connection.account.isActive %}
									<span class="sub-badge sub-badge-active">
										<span style="width:6px;height:6px;background:#16a34a;border-radius:50%;display:inline-block;box-shadow:0 0 6px rgba(22,163,74,0.5);"></span>
										Abonniert</span>
								{% else %}
									<span class="sub-badge sub-badge-paused">
										<span style="width:6px;height:6px;background:#94a3b8;border-radius:50%;display:inline-block;"></span>
										Pausiert</span>
								{% endif %}
							</td>
							<td>
								<form action="{{ path('app_agents_remove_subscriber') }}" method="post" style="display:inline;">
									<input type="hidden" name="subscriberId" value="{{ connection.account.metaId }}">
									<input type="hidden" name="strategyId" value="{{ connection.agent.metaId }}">
									<button type="submit" class="sub-btn">Trennen</button>
								</form>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>

	</div>
</div>

<script>window.__MASTER_ACCOUNT_LOGIN__ = {{ master_account_login }};</script>
<script src="/js/agents.js"></script>{% endblock %}
