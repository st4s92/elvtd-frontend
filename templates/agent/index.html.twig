<script>
	// ═══════════════════════════════════════════════════════
// LOADING OVERLAY — 1200 Particle Canvas
// ═══════════════════════════════════════════════════════
(function () {
const canvas = document.getElementById('agentsCanvas');
const ctx = canvas.getContext('2d');
let W,
H,
particles = [],
gridLines = [],
animId;
const PC = 1200,
GC = 20;

function resize() {
W = canvas.width = window.innerWidth;
H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

for (let i = 0; i < PC; i++) {
const s = Math.random() * 3.5 + 0.5,
sp = Math.random() * 0.8 + 0.1,
a = Math.random() * Math.PI * 2;
particles.push({
x: Math.random() * W,
y: Math.random() * H,
size: s,
baseSize: s,
vx: Math.cos(a) * sp,
vy: Math.sin(a) * sp,
opacity: Math.random() * 0.6 + 0.1,
pulse: Math.random() * Math.PI * 2,
pulseSpeed: Math.random() * 0.03 + 0.01,
hue: Math.random() > 0.6 ? 160 : 142
});
}
for (let i = 0; i < GC; i++) 
gridLines.push({
isH: i < GC / 2,
pos: Math.random() * (i < GC / 2 ? H : W),
opacity: Math.random() * 0.04 + 0.01
});


function drawLoading() {
ctx.clearRect(0, 0, W, H);
ctx.lineWidth = 0.5;
gridLines.forEach(g => {
ctx.strokeStyle = `rgba(22,163,74,${
g.opacity
})`;
ctx.beginPath();
if (g.isH) {
ctx.moveTo(0, g.pos);
ctx.lineTo(W, g.pos);
} else {
ctx.moveTo(g.pos, 0);
ctx.lineTo(g.pos, H);
} ctx.stroke();
});
const cx = W / 2,
cy = H / 2 - H * 0.05;
particles.forEach(p => {
p.pulse += p.pulseSpeed;
p.size = p.baseSize + Math.sin(p.pulse) * 0.8;
p.x += p.vx;
p.y += p.vy;
const dx = cx - p.x,
dy = cy - p.y,
dist = Math.sqrt(dx * dx + dy * dy);
if (dist > 50) {
p.vx += dx / dist * 0.003;
p.vy += dy / dist * 0.003;
}
const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
if (spd > 1.5) {
p.vx *= 0.98;
p.vy *= 0.98;
}
if (p.x<-10)p.x=W+10;if(p.x>W + 10) 
p.x = -10;

if (p.y<-10)p.y=H+10;if(p.y>H + 10) 
p.y = -10;

const alpha = p.opacity * (1 - Math.min(dist / (Math.max(W, H) * 0.5), 1) * 0.5);
ctx.beginPath();
ctx.arc(p.x, p.y, Math.max(p.size, 0.3), 0, Math.PI * 2);
ctx.fillStyle = `hsla(${
p.hue
},80%,50%,${alpha})`;
ctx.fill();
if (p.baseSize > 2.5) {
ctx.beginPath();
ctx.arc(p.x, p.y, p.size * 3, 0, Math.PI * 2);
ctx.fillStyle = `hsla(${
p.hue
},80%,50%,${
alpha * 0.15
})`;
ctx.fill();
}
});
for (let i = 0; i < particles.length; i++) {
const a = particles[i];
const ad = Math.sqrt((a.x - cx) ** 2 + (a.y - cy) ** 2);
if (ad > 250) 
continue;

for (let j = i + 1; j < particles.length; j++) {
const b = particles[j];
const d = Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
if (d < 60) {
ctx.strokeStyle = `rgba(22,163,74,${
0.15 * (1 - d / 60)
})`;
ctx.lineWidth = 0.5;
ctx.beginPath();
ctx.moveTo(a.x, a.y);
ctx.lineTo(b.x, b.y);
ctx.stroke();
}
}
}
animId = requestAnimationFrame(drawLoading);
}
drawLoading();

const fill = document.getElementById('agLoadFill'),
pct = document.getElementById('agLoadPct'),
sub = document.getElementById('agLoadSub');
const steps = [
{
p: 15,
t: 'Marktdaten synchronisieren...'
},
