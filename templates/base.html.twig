<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}ELVTD Finance{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, minimum-scale=1.0">

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
        {# Run `composer require symfony/webpack-encore-bundle` to start using Symfony UX #}
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        <!-- Fonts -->
        <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet">
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />
        <script src="https://kit.fontawesome.com/2810542c8f.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>

        <!-- Main Style -->
        <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('assets/css/material-dashboard.css') }}">
        <link rel="stylesheet" href="{{ asset('css/styles.css') }}">

        {% if app.user.darkmode >= 1 %}
        <link rel="stylesheet" href="{{ asset('css/darkmode.css') }}">
        {% endif %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

        <style>
            .navbar-nav {
                justify-content: flex-end !important;
            }
            @media (max-width: 1199.98px) {
                .navbar-nav {
                    justify-content: space-between !important;
                }
            }
        </style>

    </head>
    <body class="g-sidenav-show bg-gray-100">
        <aside class="sidenav navbar navbar-vertical navbar-expand-xs border-radius-lg fixed-start ms-2 my-2" id="sidenav-main">
            <div class="sidenav-header">
                <i class="fas fa-times p-3 cursor-pointer opacity-5 position-absolute end-0 top-0 d-none d-xl-none" aria-hidden="true" id="iconSidenav"></i>
                <a class="navbar-brand px-4 py-3 m-0" href="/">
                    <img src="{{ asset('assets/img/elvtd_logo.png') }}">
                    <span class="ms-1 text-md text-bolder">ELVTD Finance</span> <span>{{ app.request.locale }}</span>
                </a>
            </div>
            <hr class="horizontal dark mt-0 mb-2">
            <div class="collapse navbar-collapse  w-auto " id="sidenav-collapse-main">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'index' ? ' active' : '' }}" href="/">
                            <i class="material-symbols-rounded opacity-5">dashboard</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Dashboard</span>
                        </a>
                    </li>
                    {% if app.user.maxAccounts >= 1 %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_accounts' ? ' active' : '' }}" href="{{ path('app_account_index') }}">
                            <i class="material-symbols-rounded opacity-5">leaderboard</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Portfolio </span>
                        </a>
                    </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_agents' ? ' active' : '' }}" href="{{ path('app_agents_index') }}">
                            <i class="material-symbols-rounded opacity-5">partner_exchange</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Agents</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_signal' ? ' active' : '' }}" href="{{ path('app_signal_index') }}">
                            <i class="material-symbols-rounded opacity-5">view_in_ar</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Signale</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_copytrader' ? ' active' : '' }}" href="{{ path('app_copytrader_index') }}">
                            <i class="material-symbols-rounded opacity-5">move_group</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Copytrader</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'app_market_news' ? ' active' : '' }}" href="{{ path('app_market_news') }}">
                            <i class="material-symbols-rounded opacity-5">newspaper</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Market News</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'app_economic_calendar' ? ' active' : '' }}" href="{{ path('app_economic_calendar') }}">
                            <i class="material-symbols-rounded opacity-5">event</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Economic Calendar</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_helpdesk_faq' ? ' active' : '' }}" href="{{ path('app_helpdesk_faq') }}">
                            <i class="material-symbols-rounded opacity-5">help</i>
                            <span class="nav-link-text ms-3 text-md text-bold">Helpdesk</span>
                        </a>
                    </li>
                </ul>
            </div>
            <div class="sidenav-footer position-absolute w-100 bottom-0 ">
                <div class="mx-3">

                    <div class="sidenav-header text-center">
                        <span class="btn btn-outline-dark pb-2 text-sm  w-100"><i class="text-success text-lg mx-1">●</i>Alle Systeme sind aktiv</span>
                        <span class="btn btn-outline-dark pb-2 text-sm  w-100"><i class="text-success text-lg mx-1">●</i>Server: London-B</span>
                    </div>

                    {% if is_granted('ROLE_ADMIN') %}
                    <div class="sidenav-header h2 mb-0 font-size-large py-3 text-center">
                        <span class="text-md">Administration</span>
                    </div>
                    <a class="btn btn-outline-dark w-100" href="{{ path('app_user_index') }}">Users</a>
                    <a class="btn btn-outline-dark w-100" href="{{ path('app_admin_account_index') }}">Accounts</a>
                    <a class="btn btn-outline-dark w-100" href="{{ path('app_admin_helpdesk_index') }}">Tickets</a>
                        <br>
                    <a class="btn btn-light w-100" href="{{ path('app_duplikium_index') }}">Duplikium</a>
                    <a class="btn btn-outline-dark w-100" href="{{ path('app_order_index') }}">Orders</a>
                    <a class="btn btn-outline-dark w-100" href="{{ path('app_trade_log_index') }}" type="button">Trade Log</a>
                    <a class="btn bg-gradient-dark w-100" href="{{ path('app_send_signal') }}" type="button">Test Signal senden</a>
                    <a class="btn bg-gradient-dark w-100" href="{{ path('app_subscription_api_start') }}" type="button">Test Subscription senden</a>
                    {% endif %}
                </div>
            </div>
        </aside>
        <main class="main-content position-relative max-height-vh-100 h-100 border-radius-lg">
            <nav class="navbar navbar-main navbar-expand-lg px-0 mx-3 shadow-none border-radius-xl" id="navbarBlur" data-scroll="true">
                <div class="container-fluid py-1 px-3">
                    <div class="collapse navbar-collapse mt-sm-0 mt-2 me-md-0 me-sm-4" id="navbar">
                        <div class="ms-md-auto pe-md-3 d-flex align-items-center w-100">
                            <div class="input-group input-group-outline">
                                <ul class="navbar-nav d-flex align-items-center w-100">
                                    <li class="nav-item d-xl-none d-flex align-items-center">
                                        <a class="m-0" href="/" ><img src="{{ asset('assets/img/elvtd_logo.png') }}" style="max-width: 32px; max-height: 32px;"></a>
                                    </li>
                                    <li class="nav-item d-xl-none ps-3 d-flex align-items-center">
                                        <a href="javascript:;" class="nav-link text-body p-0" id="iconNavbarSidenav">
                                            <div class="sidenav-toggler-inner">
                                                <i class="sidenav-toggler-line"></i>
                                                <i class="sidenav-toggler-line"></i>
                                                <i class="sidenav-toggler-line"></i>
                                            </div>
                                        </a>
                                    </li>
       {#                             <li class="nav-item d-flex align-items-cente px-3">
                                        <a href="/" class="nav-link text-body p-0">
                                            <i class="material-symbols-rounded fixed-plugin-button-nav">settings</i>
                                        </a>
                                    </li>#}
                                    <li class="nav-item dropdown px-3 d-flex align-items-center">
                                        <a href="javascript:;" class="nav-link text-body p-0" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="material-symbols-rounded">notifications</i>
                                        </a>
                                        <ul class="dropdown-menu  dropdown-menu-end px-2 py-3 me-sm-n4" aria-labelledby="dropdownMenuButton">
                                            <li class="mb-2">
                                                <a class="dropdown-item border-radius-md" href="javascript:;">
                                                    <div class="d-flex py-1">
                                                        <div class="my-auto">
                                                            <img src="../assets/img/elvtd_logo.png" class="avatar avatar-sm  me-3 ">
                                                        </div>
                                                        <div class="d-flex flex-column justify-content-center">
                                                            <p class="text-xs text-secondary mb-0">
                                                                <i class="fa fa-clock me-1"></i>
                                                                keine neuen Nachrichten
                                                            </p>
                                                        </div>
                                                    </div>
                                                </a>
                                            </li>
                                            {#<li class="mb-2">
                                                <a class="dropdown-item border-radius-md" href="javascript:;">
                                                    <div class="d-flex py-1">
                                                        <div class="my-auto">
                                                            <img src="../assets/img/team-2.jpg" class="avatar avatar-sm  me-3 ">
                                                        </div>
                                                        <div class="d-flex flex-column justify-content-center">
                                                            <h6 class="text-sm font-weight-normal mb-1">
                                                                <span class="font-weight-bold">New message</span> from Laur
                                                            </h6>
                                                            <p class="text-xs text-secondary mb-0">
                                                                <i class="fa fa-clock me-1"></i>
                                                                13 minutes ago
                                                            </p>
                                                        </div>
                                                    </div>
                                                </a>
                                            </li>
                                            <li class="mb-2">
                                                <a class="dropdown-item border-radius-md" href="javascript:;">
                                                    <div class="d-flex py-1">
                                                        <div class="my-auto">
                                                            <img src="../assets/img/small-logos/logo-spotify.svg" class="avatar avatar-sm bg-gradient-dark  me-3 ">
                                                        </div>
                                                        <div class="d-flex flex-column justify-content-center">
                                                            <h6 class="text-sm font-weight-normal mb-1">
                                                                <span class="font-weight-bold">Welcome</span> back
                                                            </h6>
                                                            <p class="text-xs text-secondary mb-0">
                                                                <i class="fa fa-clock me-1"></i>
                                                                1 day
                                                            </p>
                                                        </div>
                                                    </div>
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item border-radius-md" href="javascript:;">
                                                    <div class="d-flex py-1">
                                                        <div class="avatar avatar-sm bg-gradient-secondary  me-3  my-auto">
                                                            <svg width="12px" height="12px" viewBox="0 0 43 36" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                                                                <title>credit-card</title>
                                                                <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                                                    <g transform="translate(-2169.000000, -745.000000)" fill="#FFFFFF" fill-rule="nonzero">
                                                                        <g transform="translate(1716.000000, 291.000000)">
                                                                            <g transform="translate(453.000000, 454.000000)">
                                                                                <path class="color-background" d="M43,10.7482083 L43,3.58333333 C43,1.60354167 41.3964583,0 39.4166667,0 L3.58333333,0 C1.60354167,0 0,1.60354167 0,3.58333333 L0,10.7482083 L43,10.7482083 Z" opacity="0.593633743"></path>
                                                                                <path class="color-background" d="M0,16.125 L0,32.25 C0,34.2297917 1.60354167,35.8333333 3.58333333,35.8333333 L39.4166667,35.8333333 C41.3964583,35.8333333 43,34.2297917 43,32.25 L43,16.125 L0,16.125 Z M19.7083333,26.875 L7.16666667,26.875 L7.16666667,23.2916667 L19.7083333,23.2916667 L19.7083333,26.875 Z M35.8333333,26.875 L28.6666667,26.875 L28.6666667,23.2916667 L35.8333333,23.2916667 L35.8333333,26.875 Z"></path>
                                                                            </g>
                                                                        </g>
                                                                    </g>
                                                                </g>
                                                            </svg>
                                                        </div>
                                                        <div class="d-flex flex-column justify-content-center">
                                                            <h6 class="text-sm font-weight-normal mb-1">
                                                                Payment successfully completed
                                                            </h6>
                                                            <p class="text-xs text-secondary mb-0">
                                                                <i class="fa fa-clock me-1"></i>
                                                                2 days
                                                            </p>
                                                        </div>
                                                    </div>
                                                </a>
                                            </li>#}
                                        </ul>
                                    </li>
                                    <li class="nav-item d-flex align-items-center">
                                        <a href="{{ path('app_user_profile') }}" class="nav-link text-body font-weight-bold pe-4">
                                            <i class="material-symbols-rounded">account_circle</i>
                                        </a>
                                    </li>
                                    <li class="nav-item d-flex align-items-center">
                                        <a class="btn btn-outline-primary btn-sm mb-0 me-3" href="/logout">Logout</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid py-2">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-dismissible alert-{{ label }}">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                {% if app.user.subscriptionStatus == 'deactivated' %}
                    <div class="alert alert-dismissible alert-danger">
                        Dein Abonnement ist abgelaufen und die Automatisierung wurde gesperrt. Neues Abonnement buchen, um das Trading fortzusetzen.
                    </div>
                {% endif %}

                {% block body %}{% endblock %}
            </div>
            <footer class="footer py-2 px-4">
                <div class="container-fluid ">
                    <div class="row align-items-center justify-content-lg-between">
                        <div class="col-lg-6 mb-lg-0 mb-4">
                            <div class="copyright text-center text-sm text-muted text-lg-start">
                                © <script>
                                    document.write(new Date().getFullYear())
                                </script>, by
                                <a href="https://elvtdfinance.com/" class="font-weight-bold" target="_blank">ELVTD Finance</a>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <ul class="nav nav-footer justify-content-center justify-content-lg-end">
                                <li class="nav-item">
                                    <a href="{{ path('app_agb') }}" class="nav-link text-muted">Allgemeine Geschäftsbedingungen</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </main>

        {# HELPDESK START #}
        {% include 'HelpdeskBundle/helpdesk/widget.html.twig' %}
        {# HELPDESK ENDE #}

    </body>

    <script src="{{ asset('assets/js/core/popper.min.js') }}"></script>
    <script src="{{ asset('assets/js/core/bootstrap.min.js') }}"></script>

    <!-- Theme JS -->
    <script src="{{ asset('assets/js/material-dashboard.min.js') }}"></script>
</html>
