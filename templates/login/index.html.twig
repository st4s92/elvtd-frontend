<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}ELVTD Finance - Login{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    {# Run `composer require symfony/webpack-encore-bundle` to start using Symfony UX #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />
    <script src="https://kit.fontawesome.com/2810542c8f.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>

    <!-- Main Style -->
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/material-dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}

</head>
<body class="d-flex align-items-center justify-content-center" style="background-color: #eae8e1 !important; width: 100%; height: 100vh; overflow: hidden">
    <div class="container m-auto mx-2 p-4" style="max-width: 600px;">
        <div class="row">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
        </div>
    {% block body %}
        <div class="row">
            <div class="card" style="background-image: linear-gradient(180deg, #f9f7f6 0%, rgba(247, 244, 242, 50%) 80%); box-shadow: 0px 2px 15px 15px rgba(0, 0, 0, 0.05);">
                <div class="card-body mx-2 mt-3 ">
                    <h2 class="mb-2 text-center"><img src="{{ asset('assets/img/elvtd_logo.png') }}" width="50"></h2>
                    <h3 class="mb-3 text-center text-bolder">ELVTD Finance</h3>
                    <h3 class="text-center">LOGIN</h3>
                    {% if error %}
                        <div class="alert alert-danger">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    {{ form_start(form, { 'attr': { 'name': '' } }) }}
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input type="text" id="username" name="_username" value="{{ last_username }}" required autofocus class="form-control">
                    </div>

                    <div class="form-group mt-4">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="_password" required class="form-control">
                    </div>

                    {{ form_row(form.recaptcha) }}

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <p class="mt-3">
                        <a href="{{ path('app_register') }}" class="text-decoration-underline">Jetzt registrieren</a>
                        <a href="{{ path('app_forgot_password') }}" class="text-decoration-underline float-end">Passwort vergessen</a>
                    </p>

                    <button type="submit" class="btn btn-dark btn-block mt-3 float-end w-25">Login</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
        {% endblock %}
    </div>
    <script>
        window.intercomSettings = {
            api_base: "https://api-iam.intercom.io",
            app_id: "ntrz1ql7",
        };
    </script>
    <script>
        // We pre-filled your app ID in the widget URL: 'https://widget.intercom.io/widget/ntrz1ql7'
        (function(){var w=window;var ic=w.Intercom;if(typeof ic==="function"){ic('reattach_activator');ic('update',w.intercomSettings);}else{var d=document;var i=function(){i.c(arguments);};i.q=[];i.c=function(args){i.q.push(args);};w.Intercom=i;var l=function(){var s=d.createElement('script');s.type='text/javascript';s.async=true;s.src='https://widget.intercom.io/widget/ntrz1ql7';var x=d.getElementsByTagName('script')[0];x.parentNode.insertBefore(s,x);};if(document.readyState==='complete'){l();}else if(w.attachEvent){w.attachEvent('onload',l);}else{w.addEventListener('load',l,false);}}})();
    </script>
</body>

<script src="{{ asset('assets/js/core/popper.min.js') }}"></script>
<script src="{{ asset('assets/js/core/bootstrap.min.js') }}"></script>

<!-- Theme JS -->
<script src="{{ asset('assets/js/material-dashboard.min.js') }}"></script>
</html>