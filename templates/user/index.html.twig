{% extends 'base.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<style>
	:root {
		--u-card: #ffffff;
		--u-dark: #0f172a;
		--u-dim: #64748b;
		--u-border: rgba(0,0,0,0.06);
		--u-green: #16a34a;
		--u-blue: #3b82f6;
		--u-purple: #8b5cf6;
		--u-amber: #f59e0b;
		--u-red: #ef4444;
		--u-cyan: #06b6d4;
		--u-radius: 16px;
	}
	.u-wrap {
		max-width: 1400px;
		margin: 0 auto;
		padding: 1.5rem 1.5rem 4rem;
	}

	/* ── Header ── */
	.u-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.u-header h1 {
		font-size: 1.6rem;
		font-weight: 800;
		color: var(--u-dark);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.u-header h1 i { color: var(--u-purple); font-size: 1.3rem; }
	.u-user-count {
		font-size: 0.75rem;
		font-weight: 700;
		background: rgba(139,92,246,0.1);
		color: var(--u-purple);
		padding: 0.25rem 0.7rem;
		border-radius: 20px;
	}
	.u-btn-new {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.55rem 1.2rem;
		background: linear-gradient(135deg, #8b5cf6, #a78bfa);
		color: #fff;
		border: none;
		border-radius: 10px;
		font-size: 0.85rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.25s;
	}
	.u-btn-new:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(139,92,246,0.3);
		color: #fff;
	}

	/* ── Stats ── */
	.u-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 0.8rem;
		margin-bottom: 1.5rem;
	}
	.u-stat {
		background: var(--u-card);
		border: 1px solid var(--u-border);
		border-radius: 12px;
		padding: 1rem 1.2rem;
		position: relative;
		overflow: hidden;
	}
	.u-stat::after {
		content: '';
		position: absolute;
		top: 0; left: 0;
		width: 3px; height: 100%;
	}
	.u-stat.s1::after { background: var(--u-purple); }
	.u-stat.s2::after { background: var(--u-green); }
	.u-stat.s3::after { background: var(--u-red); }
	.u-stat.s4::after { background: var(--u-amber); }
	.u-stat-label {
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--u-dim);
	}
	.u-stat-val {
		font-size: 1.5rem;
		font-weight: 800;
		color: var(--u-dark);
		line-height: 1.2;
	}

	/* ── Search ── */
	.u-search-wrap {
		margin-bottom: 1rem;
		position: relative;
	}
	.u-search-wrap i {
		position: absolute;
		left: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--u-dim);
		font-size: 0.85rem;
	}
	.u-search {
		width: 100%;
		max-width: 400px;
		padding: 0.6rem 1rem 0.6rem 2.5rem;
		border: 1px solid var(--u-border);
		border-radius: 10px;
		font-size: 0.85rem;
		transition: border-color 0.2s, box-shadow 0.2s;
		background: var(--u-card);
	}
	.u-search:focus {
		outline: none;
		border-color: var(--u-purple);
		box-shadow: 0 0 0 3px rgba(139,92,246,0.1);
	}

	/* ── Table ── */
	.u-table-wrap {
		background: var(--u-card);
		border: 1px solid var(--u-border);
		border-radius: var(--u-radius);
		overflow: hidden;
	}
	.u-table {
		width: 100%;
		border-collapse: collapse;
	}
	.u-table thead th {
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--u-dim);
		padding: 0.8rem 1rem;
		border-bottom: 1px solid var(--u-border);
		text-align: left;
		white-space: nowrap;
		cursor: pointer;
		user-select: none;
		transition: color 0.2s;
	}
	.u-table thead th:hover { color: var(--u-dark); }
	.u-table tbody tr {
		border-bottom: 1px solid var(--u-border);
		transition: background 0.15s;
	}
	.u-table tbody tr:last-child { border-bottom: none; }
	.u-table tbody tr:hover { background: rgba(0,0,0,0.012); }
	.u-table tbody td {
		padding: 0.75rem 1rem;
		font-size: 0.82rem;
		color: var(--u-dark);
		vertical-align: top;
	}

	/* User cell */
	.u-user-cell { display: flex; align-items: center; gap: 0.7rem; }
	.u-avatar {
		width: 34px; height: 34px;
		border-radius: 9px;
		background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(59,130,246,0.1));
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.7rem;
		font-weight: 700;
		color: var(--u-purple);
		flex-shrink: 0;
	}
	.u-user-name { font-weight: 600; font-size: 0.83rem; }
	.u-user-username { font-size: 0.72rem; color: var(--u-dim); }
	.u-user-id { font-size: 0.65rem; color: var(--u-dim); opacity: 0.6; }

	/* Status badges */
	.u-sub-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.7rem;
		font-weight: 600;
		padding: 0.2rem 0.6rem;
		border-radius: 6px;
	}
	.u-sub-badge.active { background: rgba(22,163,74,0.1); color: var(--u-green); }
	.u-sub-badge.trial { background: rgba(245,158,11,0.1); color: var(--u-amber); }
	.u-sub-badge.expired { background: rgba(239,68,68,0.1); color: var(--u-red); }
	.u-sub-badge.deactivated { background: var(--u-red); color: #fff; }
	.u-sub-badge.none { background: rgba(100,116,139,0.08); color: var(--u-dim); }
	.u-sub-badge .dot {
		width: 6px; height: 6px; border-radius: 50%;
	}
	.u-sub-badge.active .dot { background: var(--u-green); }
	.u-sub-badge.expired .dot { background: var(--u-red); }
	.u-sub-badge.deactivated .dot { background: #fff; }

	.u-days { font-size: 0.78rem; font-weight: 600; }
	.u-days.ok { color: var(--u-green); }
	.u-days.warn { color: var(--u-amber); }
	.u-days.expired { color: var(--u-red); }

	/* Accounts */
	.u-acc-count {
		font-weight: 700;
		font-size: 0.82rem;
	}
	.u-acc-link {
		display: block;
		font-size: 0.72rem;
		color: var(--u-blue);
		text-decoration: none;
		margin-top: 0.15rem;
		transition: color 0.15s;
	}
	.u-acc-link:hover { color: var(--u-purple); text-decoration: underline; }
	.u-acc-err {
		font-size: 0.65rem;
		color: var(--u-red);
		opacity: 0.8;
	}

	/* Actions */
	.u-actions {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		min-width: 160px;
	}
	.u-act-row {
		display: flex;
		gap: 0.3rem;
	}
	.u-act-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.3rem 0.6rem;
		border: 1px solid var(--u-border);
		border-radius: 6px;
		font-size: 0.68rem;
		font-weight: 600;
		text-decoration: none;
		cursor: pointer;
		transition: all 0.2s;
		background: var(--u-card);
		color: var(--u-dark);
		white-space: nowrap;
	}
	.u-act-btn:hover {
		border-color: var(--u-purple);
		color: var(--u-purple);
		background: rgba(139,92,246,0.03);
	}
	.u-act-btn.danger {
		border-color: rgba(239,68,68,0.2);
		color: var(--u-red);
	}
	.u-act-btn.danger:hover {
		background: rgba(239,68,68,0.05);
		border-color: var(--u-red);
	}
	.u-act-btn.success {
		border-color: rgba(22,163,74,0.2);
		color: var(--u-green);
	}
	.u-act-btn.success:hover {
		background: rgba(22,163,74,0.05);
		border-color: var(--u-green);
	}

	/* Subscription form */
	.u-sub-form {
		display: flex;
		gap: 0.3rem;
		margin-top: 0.3rem;
	}
	.u-sub-select {
		font-size: 0.7rem;
		padding: 0.25rem 0.4rem;
		border: 1px solid var(--u-border);
		border-radius: 5px;
		background: #fff;
		flex: 1;
	}
	.u-sub-submit {
		font-size: 0.68rem;
		padding: 0.25rem 0.5rem;
		background: var(--u-dark);
		color: #fff;
		border: none;
		border-radius: 5px;
		cursor: pointer;
		white-space: nowrap;
		transition: opacity 0.2s;
	}
	.u-sub-submit:hover { opacity: 0.85; }

	/* Date info */
	.u-date-main { font-size: 0.78rem; color: var(--u-dark); }
	.u-date-sub { font-size: 0.68rem; color: var(--u-dim); }

	/* Deactivated row */
	.u-row-deactivated {
		background: rgba(239,68,68,0.04) !important;
	}
	.u-row-expired {
		background: rgba(245,158,11,0.03) !important;
	}

	/* Filter tabs */
	.u-filters {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}
	.u-filter-btn {
		padding: 0.45rem 1rem;
		border: 1px solid var(--u-border);
		border-radius: 8px;
		background: var(--u-card);
		color: var(--u-dim);
		font-size: 0.8rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s;
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}
	.u-filter-btn:hover { border-color: var(--u-purple); color: var(--u-purple); }
	.u-filter-btn.active {
		background: var(--u-dark);
		color: #fff;
		border-color: var(--u-dark);
	}
	.u-filter-badge {
		font-size: 0.65rem;
		background: rgba(0,0,0,0.08);
		padding: 0.1rem 0.4rem;
		border-radius: 4px;
	}
	.u-filter-btn.active .u-filter-badge {
		background: rgba(255,255,255,0.2);
	}
	.u-filter-dot {
		display: inline-block;
		width: 7px; height: 7px;
		border-radius: 50%;
	}

	.u-empty {
		text-align: center;
		padding: 3rem;
		color: var(--u-dim);
		font-size: 0.88rem;
	}

	@media(max-width: 1200px) {
		.u-table-wrap { overflow-x: auto; }
		.u-table { min-width: 1100px; }
	}
</style>

<div class="u-wrap">
	{# ═══ HEADER ═══ #}
	<div class="u-header">
		<h1>
			<i class="fas fa-users-cog"></i> User Management
			<span class="u-user-count">{{ users|length }} User</span>
		</h1>
		<div style="display:flex;gap:0.6rem;">
			<a href="{{ path('app_user_export_review') }}" class="u-btn-new" style="background:linear-gradient(135deg,#ef4444,#f87171);" target="_blank">
				<i class="fas fa-file-pdf"></i> Export Prüfbericht
			</a>
			<a href="{{ path('app_user_new') }}" class="u-btn-new">
				<i class="fas fa-user-plus"></i> Neuer User
			</a>
		</div>
	</div>

	{# ═══ STATS ═══ #}
	{% set active_count = 0 %}
	{% set expired_count = 0 %}
	{% set deactivated_count = 0 %}
	{% set trial_count = 0 %}
	{% for user in users %}
		{% set subscription = subscriptions|filter(s => s.user.id == user.id)|first %}
		{% if user.subscriptionStatus == 'deactivated' %}
			{% set deactivated_count = deactivated_count + 1 %}
		{% elseif subscription %}
			{% set end_date = subscription.currentPeriodEnd %}
			{% if subscription.trialEnd and (not subscription.currentPeriodEnd or subscription.trialEnd > subscription.currentPeriodEnd) %}
				{% set end_date = subscription.trialEnd %}
			{% endif %}
			{% if end_date and end_date < date() %}
				{% set expired_count = expired_count + 1 %}
			{% elseif subscription.trialEnd and subscription.trialEnd > date() and not subscription.currentPeriodEnd %}
				{% set trial_count = trial_count + 1 %}
			{% else %}
				{% set active_count = active_count + 1 %}
			{% endif %}
		{% endif %}
	{% endfor %}

	<div class="u-stats">
		<div class="u-stat s1">
			<div class="u-stat-label">Gesamt User</div>
			<div class="u-stat-val">{{ users|length }}</div>
		</div>
		<div class="u-stat s2">
			<div class="u-stat-label">Aktive Subs</div>
			<div class="u-stat-val">{{ active_count }}</div>
		</div>
		<div class="u-stat s3">
			<div class="u-stat-label">Abgelaufen</div>
			<div class="u-stat-val">{{ expired_count }}</div>
		</div>
		<div class="u-stat s4">
			<div class="u-stat-label">Gesperrt</div>
			<div class="u-stat-val">{{ deactivated_count }}</div>
		</div>
	</div>

	{# ═══ FILTERS ═══ #}
	<div class="u-filters">
		<button class="u-filter-btn active" data-filter="all">
			Alle <span class="u-filter-badge">{{ users|length }}</span>
		</button>
		<button class="u-filter-btn" data-filter="active">
			<span class="u-filter-dot" style="background:var(--u-green);"></span>
			Aktiv <span class="u-filter-badge">{{ active_count }}</span>
		</button>
		<button class="u-filter-btn" data-filter="expired">
			<span class="u-filter-dot" style="background:var(--u-red);"></span>
			Abgelaufen <span class="u-filter-badge">{{ expired_count }}</span>
		</button>
		<button class="u-filter-btn" data-filter="deactivated">
			<span class="u-filter-dot" style="background:var(--u-red);"></span>
			Gesperrt <span class="u-filter-badge">{{ deactivated_count }}</span>
		</button>
		<button class="u-filter-btn" data-filter="trial">
			<span class="u-filter-dot" style="background:var(--u-amber);"></span>
			Trial <span class="u-filter-badge">{{ trial_count }}</span>
		</button>
		<button class="u-filter-btn" data-filter="nosub">
			<span class="u-filter-dot" style="background:var(--u-dim);"></span>
			Keine Sub
		</button>
	</div>

	{# ═══ SEARCH ═══ #}
	<div class="u-search-wrap">
		<i class="fas fa-search"></i>
		<input type="text" class="u-search" id="uSearch" placeholder="User suchen (Name, Email, Username...)">
	</div>

	{# ═══ TABLE ═══ #}
	<div class="u-table-wrap">
		<table class="u-table" id="userTable">
			<thead>
				<tr>
					<th>User</th>
					<th>Email</th>
					<th>Registriert</th>
					<th>Letzter Login</th>
					<th>Subscription</th>
					<th>Verbleibend</th>
					<th>Accounts</th>
					<th>Aktionen</th>
				</tr>
			</thead>
			<tbody>
				{% for user in users %}
					{% set subscription = subscriptions|filter(s => s.user.id == user.id)|first %}
					{% set is_expired = false %}
					{% set is_deactivated = false %}
					{% set days_remaining = null %}
					{% if subscription %}
						{% set end_date = subscription.currentPeriodEnd %}
						{% if subscription.trialEnd and (not subscription.currentPeriodEnd or subscription.trialEnd > subscription.currentPeriodEnd) %}
							{% set end_date = subscription.trialEnd %}
						{% endif %}
						{% if end_date %}
							{% set days_remaining = ((end_date|date('U') - date()|date('U')) / 86400)|round(0, 'floor') %}
							{% if days_remaining < 0 %}
								{% set is_expired = true %}
							{% endif %}
						{% endif %}
					{% endif %}
					{% if user.subscriptionStatus == 'deactivated' %}
						{% set is_deactivated = true %}
					{% endif %}

					<tr class="u-row {% if is_deactivated %}u-row-deactivated{% elseif is_expired %}u-row-expired{% endif %}" data-search="{{ user.firstname|lower }} {{ user.lastname|lower }} {{ user.username|lower }} {{ user.email|lower }} {{ user.affiliateCode|lower }}" data-status="{% if is_deactivated %}deactivated{% elseif is_expired %}expired{% elseif subscription and subscription.trialEnd and subscription.trialEnd > date() and not subscription.currentPeriodEnd %}trial{% elseif subscription %}active{% else %}nosub{% endif %}">
						<td>
							<div class="u-user-cell">
								<div class="u-avatar">
									{{ user.firstname|first|upper }}{{ user.lastname|first|upper }}
								</div>
								<div>
									<div class="u-user-name">{{ user.firstname }} {{ user.lastname }}</div>
									<div class="u-user-username">{{ user.username }}</div>
									<div class="u-user-id">#{{ user.id }} {% if user.affiliateCode %}&middot; {{ user.affiliateCode }}{% endif %}</div>
								</div>
							</div>
						</td>
						<td>
							<span style="font-size:0.82rem;">{{ user.email }}</span>
						</td>
						<td>
							<div class="u-date-main">{{ user.createdAt ? user.createdAt|date('d.m.Y') : '-' }}</div>
							<div class="u-date-sub">{{ user.createdAt ? user.createdAt|date('H:i') : '' }}</div>
						</td>
						<td>
							{% if user.lastLogin %}
								<div class="u-date-main">{{ user.lastLogin|date('d.m.Y') }}</div>
								<div class="u-date-sub">{{ user.lastLogin|date('H:i') }}</div>
							{% else %}
								<span style="font-size:0.75rem;color:var(--u-dim);">Nie</span>
							{% endif %}
						</td>
						<td>
							{% if is_deactivated %}
								<span class="u-sub-badge deactivated"><span class="dot"></span> Gesperrt</span>
							{% elseif is_expired %}
								<span class="u-sub-badge expired"><span class="dot"></span> Abgelaufen</span>
							{% elseif subscription %}
								<span class="u-sub-badge active"><span class="dot"></span> {{ user.subscriptionStatus }}</span>
								{% if subscription.currentPeriodEnd %}
									<div class="u-date-sub" style="margin-top:0.2rem;">
										bis {{ subscription.currentPeriodEnd|date('d.m.Y') }}
									</div>
								{% endif %}
								{% if subscription.trialEnd and subscription.trialEnd > date() %}
									<div class="u-date-sub">Trial: {{ subscription.trialEnd|date('d.m.Y') }}</div>
								{% endif %}
							{% else %}
								<span class="u-sub-badge none">Keine</span>
							{% endif %}
						</td>
						<td>
							{% if days_remaining is not null %}
								{% if days_remaining > 30 %}
									<span class="u-days ok">{{ days_remaining }}d</span>
								{% elseif days_remaining > 0 %}
									<span class="u-days warn">{{ days_remaining }}d</span>
								{% else %}
									<span class="u-days expired">{{ days_remaining }}d</span>
								{% endif %}
							{% else %}
								<span style="font-size:0.75rem;color:var(--u-dim);">-</span>
							{% endif %}
						</td>
						<td>
							<span class="u-acc-count">{{ user.accounts|length }}/{{ user.maxAccounts }}</span>
							{% for account in user.accounts %}
								<a href="/account/{{ account.metaId }}" target="_blank" class="u-acc-link">
									{{ account.login }} &middot; {{ account.platform }}
									{% if account.error %}<span class="u-acc-err">{{ account.error }}</span>{% endif %}
								</a>
							{% endfor %}
						</td>
						<td>
							<div class="u-actions">
								<div class="u-act-row">
									<a href="{{ path('app_user_edit', {'id': user.id}) }}" class="u-act-btn">
										<i class="fas fa-pen"></i> Edit
									</a>
									<a href="{{ path('app_user_reset_password', {'id': user.id}) }}" class="u-act-btn">
										<i class="fas fa-key"></i> PW
									</a>
								</div>
								<form action="{{ path('app_subscription_api_manual') }}" method="post" class="u-sub-form">
									<input type="hidden" name="email" value="{{ user.email }}">
									<select name="product" class="u-sub-select">
										<option value="2month">2M</option>
										<option value="3month">3M</option>
										<option value="6month">6M</option>
										<option value="12month">12M</option>
										<option value="12month_onetime">12M 1x</option>
									</select>
									<button type="submit" class="u-sub-submit"><i class="fas fa-sync"></i> Sub</button>
								</form>
								<div class="u-act-row">
									{% if is_deactivated %}
										<a href="{{ path('app_user_activate', {'id': user.id}) }}" class="u-act-btn success" style="flex:1;">
											<i class="fas fa-play"></i> Aktivieren
										</a>
									{% else %}
										<a href="{{ path('app_user_deactivate', {'id': user.id}) }}" class="u-act-btn danger" style="flex:1;">
											<i class="fas fa-ban"></i> Sperren
										</a>
									{% endif %}
								</div>
							</div>
						</td>
					</tr>
				{% else %}
					<tr><td colspan="8" class="u-empty">Keine User gefunden</td></tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
</div>

<script>
var currentFilter = 'all';
var currentSearch = '';

function applyFilters() {
	document.querySelectorAll('.u-table tbody .u-row').forEach(function(row) {
		var matchSearch = !currentSearch || (row.getAttribute('data-search') || '').indexOf(currentSearch) !== -1;
		var matchFilter = currentFilter === 'all' || row.getAttribute('data-status') === currentFilter;
		row.style.display = (matchSearch && matchFilter) ? '' : 'none';
	});
}

document.getElementById('uSearch').addEventListener('input', function() {
	currentSearch = this.value.toLowerCase().trim();
	applyFilters();
});

document.querySelectorAll('.u-filter-btn').forEach(function(btn) {
	btn.addEventListener('click', function() {
		document.querySelectorAll('.u-filter-btn').forEach(function(b) { b.classList.remove('active'); });
		btn.classList.add('active');
		currentFilter = btn.getAttribute('data-filter');
		applyFilters();
	});
});
</script>
{% endblock %}
