							box-shadow: 0 0 20px rgba(74,222,128,0.25), 0 0 40px rgba(139,92,246,0.15), 0 8px 25px rgba(0,0,0,0.2);
						}
						.btn-agent-cta:hover::after { opacity: 1; }
						.btn-agent-cta:hover .btn-agent-arrow {
