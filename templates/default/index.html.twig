{% extends 'base.html.twig' %}

{% block title %}ELVTD Finance - Dashboard
{% endblock %}

{% block body %}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	<style>
	/* ── Premium Home Design System ── */:root
	{
		--p: #6366f1; /* Indigo */
		--p-rgb: 99, 102, 241;
		--s: #10b981; /* Success */
		--s-rgb: 16, 185, 129;
		--d: #ef4444; /* Danger */
		--d-rgb: 239, 68, 68;
		--bg-mesh: fixed radial-gradient(at 100% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%), fixed radial-gradient(at 0% 100%, rgba(16, 185, 129, 0.15) 0px, transparent 50%), fixed radial-gradient(at 100% 100%, rgba(99, 102, 241, 0.1) 0px, transparent 50%), fixed radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.1) 0px, transparent 50%), #f8fafc;
		--glass: rgba(255, 255, 255, 0.85);
		--glass-border: rgba(255, 255, 255, 0.5);
		--shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.1);
		--font: 'Outfit', sans-serif;
		--txt-main: #0f172a;
		--txt-dim: #64748b;
	}

	body {
		background: var(--bg-mesh);
		background-attachment: fixed;
		font-family: var(--font);
		color: var(--txt-main);
		min-height: 100vh;
	}

	.pf-wrap {
		padding: 2rem 0 5rem;
		animation: entry-fade 1s cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.container-custom {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.glass-card {
		background: var(--glass);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--glass-border);
		box-shadow: var(--shadow);
		border-radius: 24px;
		transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.glass-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.1);
		border-color: rgba(var(--p-rgb), 0.3);
	}

	.dash-title {
		font-size: 2.5rem;
		font-weight: 800;
		letter-spacing: -0.05em;
		background: linear-gradient(135deg, #0f172a 0%, #475569 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		margin-bottom: 0.25rem;
	}

	.dash-subtitle {
		font-size: 1rem;
		font-weight: 500;
		color: #64748b;
	}

	.step-badge {
		padding: 0.75rem 1.25rem;
		border-radius: 16px;
		font-weight: 700;
		font-size: 0.85rem;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		transition: all 0.3s;
		border: 1px solid transparent;
	}

	.step-done {
		background: rgba(var(--s-rgb), 0.1);
		color: var(--s);
		border-color: rgba(var(--s-rgb), 0.2);
	}

	.step-pending {
		background: rgba(148, 163, 184, 0.1);
		color: #64748b;
		border-color: rgba(148, 163, 184, 0.15);
	}

	.pf-table th {
		font-size: 0.7rem;
		font-weight: 800;
		color: var(--txt-dim);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 1.25rem 1.5rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.05);
	}

	.pf-table td {
		padding: 1.25rem 1.5rem;
		vertical-align: middle;
	}

	@keyframes entry-fade {
		from {
			opacity: 0;
			transform: translateY(20px);
			filter: blur(5px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0);
		}
	}

	.stagger-1 {
		animation: entry-fade 0.8s 0.1s both;
	}
	.stagger-2 {
		animation: entry-fade 0.8s 0.2s both;
	}
	.stagger-3 {
		animation: entry-fade 0.8s 0.3s both;
	}
	.stagger-4 {
		animation: entry-fade 0.8s 0.4s both;
	}

	/* ── Subscription Status Enhancements ── */
	.sub-item {
		margin-bottom: 1.5rem;
	}
	.sub-label-wrap {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 0.5rem;
	}
	.sub-label {
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--txt-dim);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.sub-value {
		font-size: 0.9rem;
		font-weight: 800;
		color: var(--txt-main);
	}
	.sub-progress-bg {
		height: 8px;
		background: rgba(0, 0, 0, 0.05);
		border-radius: 10px;
		overflow: hidden;
		position: relative;
	}
	.sub-progress-fill {
		height: 100%;
		border-radius: 10px;
		background: linear-gradient(90deg, var(--p), #818cf8);
		box-shadow: 0 0 15px rgba(var(--p-rgb), 0.3);
		transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1);
	}
	.sub-progress-fill.success {
		background: linear-gradient(90deg, var(--s), #34d399);
		box-shadow: 0 0 15px rgba(var(--s-rgb), 0.3);
	}

	.status-pill {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 0.5rem 1rem;
		background: rgba(var(--s-rgb), 0.1);
		border: 1px solid rgba(var(--s-rgb), 0.2);
		border-radius: 100px;
		color: var(--s);
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.status-dot {
		width: 8px;
		height: 8px;
		background: var(--s);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--s);
		animation: pulse-dot 2s infinite;
	}
	@keyframes pulse-dot {
		0% {
			transform: scale(1);
			opacity: 1;
		}
		50% {
			transform: scale(1.5);
			opacity: 0.5;
		}
		100% {
			transform: scale(1);
			opacity: 1;
		}
	}

	.expiry-box {
		background: #f1f5f9;
		border-radius: 16px;
		padding: 1rem;
		text-align: center;
		margin-top: 2rem;
	}
	.expiry-label {
		display: block;
		font-size: 0.7rem;
		font-weight: 700;
		color: var(--txt-dim);
		text-transform: uppercase;
		margin-bottom: 0.25rem;
	}
	.expiry-date {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--txt-main);
	}

	.bg-gradient-dark {
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;
		color: white !important;
	}
	.bg-gradient-dark * {
		color: white !important;
	}

	/* ── Master Trades Premium Glassmorphism ── */
	.glass-premium {
		background: rgba(15, 23, 42, 0.75) !important;
		backdrop-filter: blur(28px) saturate(200%);
		-webkit-backdrop-filter: blur(28px) saturate(200%);
		border: 1px solid rgba(255, 255, 255, 0.12) !important;
		border-radius: 32px !important;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), inset 0 0 20px rgba(255, 255, 255, 0.02) !important;
		position: relative;
		overflow: hidden;
	}
	.glass-premium::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: url("data:image/svg+xml, %3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
		filter: contrast(120%) brightness(100%);
		opacity: 0.03;
		pointer-events: none;
		z-index: 1;
	}
	.glass-premium > * {
		position: relative;
		z-index: 2;
	}
	.glass-premium .card-title {
		color: #ffffff !important;
		font-weight: 900;
		letter-spacing: 0.08em;
	}
	.badge-master-premium {
		background: rgba(255, 255, 255, 0.1);
		color: white;
		border: 1px solid rgba(255, 255, 255, 0.2);
		text-transform: uppercase;
		font-weight: 900;
		padding: 6px 14px;
		font-size: 0.65rem;
		letter-spacing: 0.12em;
		box-shadow: 0 0 15px rgba(255, 255, 255, 0.05);
	}
	.trade-featured-glass {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 24px;
		padding: 1.75rem;
		margin-bottom: 1.25rem;
		position: relative;
		transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
	}
	.trade-featured-glass:hover {
		background: rgba(255, 255, 255, 0.07);
		border-color: rgba(255, 255, 255, 0.15);
		transform: translateY(-4px) scale(1.02);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}
	.trade-symbol-premium {
		color: white;
		font-weight: 900;
		font-size: 1.5rem;
		letter-spacing: -0.04em;
	}
	.trade-meta-premium {
		color: rgba(255, 255, 255, 0.5);
		font-weight: 700;
		font-size: 0.75rem;
	}
	.text-glow-success {
		color: #10b981 !important;
		text-shadow: 0 0 20px rgba(16, 185, 129, 0.6);
	}
	.text-glow-danger {
		color: #ef4444 !important;
		text-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
	}
	.trade-item-frosted {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 18px;
		padding: 1.15rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transition: all 0.25s ease;
	}
	.trade-item-frosted:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.1);
		transform: scale(1.02);
	}
	.badge-buy-premium {
		background: rgba(16, 185, 129, 0.15);
		color: #10b981;
		border: 1px solid rgba(16, 185, 129, 0.3);
	}
	.badge-sell-premium {
		background: rgba(239, 68, 68, 0.15);
		color: #ef4444;
		border: 1px solid rgba(239, 68, 68, 0.3);
	}
	.sub-item-premium .sub-label {
		color: rgba(255, 255, 255, 0.5) !important;
		font-weight: 800 !important;
		font-size: 0.65rem !important;
		letter-spacing: 0.05em;
	}
	.sub-item-premium .sub-value {
		color: white !important;
		font-weight: 900 !important;
	}
	.sub-progress-fill-premium {
		box-shadow: 0 0 15px currentColor;
		border-radius: 10px;
	}
	.expiry-box-premium {
		background: rgba(255, 255, 255, 0.03);
		border: 1px dashed rgba(255, 255, 255, 0.1);
		border-radius: 20px;
		padding: 1.25rem;
		text-align: center;
	}
	.expiry-date-premium {
		color: white !important;
		font-weight: 900 !important;
		font-size: 1.1rem !important;
	}

	/* ══════════════════════════════════════════════════════
	   PRICING SECTION — Premium Animated Design
	   ══════════════════════════════════════════════════════ */
	.pricing-section {
		position: relative;
		padding: 3rem 0 2rem;
	}
	.pricing-section-header {
		text-align: center;
		margin-bottom: 3rem;
	}
	.pricing-section-header h2 {
		font-size: 2.2rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		background: linear-gradient(135deg, #0f172a 0%, #334155 50%, #16a34a 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 0.5rem;
	}
	.pricing-section-header p {
		font-size: 1rem;
		color: var(--txt-dim);
		font-weight: 500;
	}

	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		align-items: stretch;
	}
	@media(max-width: 768px) {
		.pricing-grid {
			grid-template-columns: 1fr;
		}
	}

	/* ── Individual Pricing Card ── */
	.pricing-card {
		position: relative;
		border-radius: 24px;
		overflow: hidden;
		transition: all 0.5s cubic-bezier(0.175,0.885,0.32,1.275);
	}
	.pricing-card:hover {
		transform: translateY(-8px);
	}

	/* Animated gradient border */
	.pricing-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: 24px;
		padding: 2px;
		background: linear-gradient(135deg, rgba(22,163,74,0.3), rgba(99,102,241,0.2), rgba(22,163,74,0.3));
		background-size: 200% 200%;
		animation: borderShift 4s ease infinite;
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		pointer-events: none;
		z-index: 1;
	}
	@keyframes borderShift {
		0,
		100% {
			background-position: 0 50%;
		}
		50% {
			background-position: 100% 50%;
		}
	}

	.pricing-card-inner {
		position: relative;
		background: linear-gradient(160deg, #1a2332 0%, #0d1520 40%, #111b27 100%);
		border-radius: 24px;
		padding: 2rem 1.75rem 1.75rem;
		height: 100%;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	/* Subtle mesh glow inside card */
	.pricing-card-inner::before {
		content: '';
		position: absolute;
		top: -60%;
		right: -40%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle at 70% 30%, rgba(22,163,74,0.08) 0%, transparent 50%);
		pointer-events: none;
	}
	.pricing-card-inner::after {
		content: '';
		position: absolute;
		bottom: -50%;
		left: -30%;
		width: 160%;
		height: 160%;
		background: radial-gradient(circle at 30% 70%, rgba(99,102,241,0.06) 0%, transparent 50%);
		pointer-events: none;
	}

	/* ── Featured card (Empfehlung) ── */
	.pricing-card.featured {
		z-index: 2;
	}
	.pricing-card.featured::before {
		padding: 2px;
		background: linear-gradient(135deg, #16a34a, #22d3ee, #8b5cf6, #16a34a);
		background-size: 300% 300%;
		animation: borderShiftFeatured 3s ease infinite;
	}
	@keyframes borderShiftFeatured {
		0,
		100% {
			background-position: 0 50%;
		}
		50% {
			background-position: 100% 50%;
		}
	}
	.pricing-card.featured .pricing-card-inner::before {
		background: radial-gradient(circle at 70% 30%, rgba(22,163,74,0.12) 0%, transparent 50%);
	}
	.pricing-card.featured:hover {
		box-shadow: 0 20px 60px rgba(22, 163, 74, 0.2), 0 0 40px rgba(22, 163, 74, 0.1);
	}

	/* ── Professional card ── */
	.pricing-card.professional::before {
		background: linear-gradient(135deg, rgba(59,130,246,0.4), rgba(139,92,246,0.3), rgba(59,130,246,0.4));
		background-size: 200% 200%;
		animation: borderShift 4s ease infinite;
	}
	.pricing-card.professional:hover {
		box-shadow: 0 20px 60px rgba(59, 130, 246, 0.15), 0 0 30px rgba(59, 130, 246, 0.08);
	}

	/* ── Badge ── */
	.pricing-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 16px;
		border-radius: 100px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 1.25rem;
		position: relative;
		z-index: 1;
	}
	.pricing-badge.badge-standard {
		background: rgba(22, 163, 74, 0.15);
		color: #4ade80;
		border: 1px solid rgba(22, 163, 74, 0.2);
	}
	.pricing-badge.badge-featured {
		background: linear-gradient(135deg, rgba(22,163,74,0.2), rgba(34,211,238,0.15));
		color: #4ade80;
		border: 1px solid rgba(22, 163, 74, 0.3);
		box-shadow: 0 0 20px rgba(22, 163, 74, 0.15);
		animation: badgeGlow 2s ease-in-out infinite;
	}
	@keyframes badgeGlow {
		0,
		100% {
			box-shadow: 0 0 15px rgba(22, 163, 74, 0.15);
		}
		50% {
			box-shadow: 0 0 25px rgba(22, 163, 74, 0.3);
		}
	}
	.pricing-badge.badge-pro {
		background: rgba(59, 130, 246, 0.15);
		color: #93c5fd;
		border: 1px solid rgba(59, 130, 246, 0.2);
	}

	/* ── Card Title ── */
	.pricing-title {
		text-align: center;
		margin-bottom: 0.75rem;
		position: relative;
		z-index: 1;
	}
	.pricing-title h4 {
		font-size: 1.15rem;
		font-weight: 700;
		color: #e2e8f0 !important;
		line-height: 1.4;
		margin: 0;
	}

	/* ── Price ── */
	.pricing-price {
		text-align: center;
		margin-bottom: 1.75rem;
		position: relative;
		z-index: 1;
	}
	.pricing-amount {
		font-size: 3.5rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		background: linear-gradient(135deg, #ffffff 0%, #94a3b8 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.pricing-card.featured .pricing-amount {
		background: linear-gradient(135deg, #4ade80 0%, #22d3ee 50%, #ffffff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.pricing-card.professional .pricing-amount {
		background: linear-gradient(135deg, #93c5fd 0%, #c4b5fd 50%, #ffffff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.pricing-period {
		font-size: 1rem;
		font-weight: 500;
		color: #64748b !important;
		margin-left: 4px;
	}

	/* ── Divider ── */
	.pricing-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
		margin-bottom: 1.5rem;
		position: relative;
		z-index: 1;
	}

	/* ── Features List ── */
	.pricing-features {
		list-style: none;
		padding: 0;
		margin: 0 0 1.75rem;
		flex: 1;
		position: relative;
		z-index: 1;
	}
	.pricing-features li {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 10px 0;
		font-size: 0.88rem;
		font-weight: 500;
		color: #cbd5e1 !important;
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
	}
	.pricing-features li:last-child {
		border-bottom: none;
	}
	.pricing-features li .check-icon {
		width: 22px;
		height: 22px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		font-size: 0.65rem;
	}
	.check-green {
		background: rgba(22, 163, 74, 0.15);
		color: #4ade80 !important;
		box-shadow: 0 0 10px rgba(22, 163, 74, 0.15);
	}
	.check-blue {
		background: rgba(59, 130, 246, 0.15);
		color: #93c5fd !important;
		box-shadow: 0 0 10px rgba(59, 130, 246, 0.15);
	}

	/* ── CTA Button ── */
	.pricing-cta {
		display: block;
		width: 100%;
		padding: 14px 24px;
		border: none;
		border-radius: 14px;
		font-size: 0.95rem;
		font-weight: 700;
		text-align: center;
		text-decoration: none;
		cursor: pointer;
		transition: all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
		position: relative;
		z-index: 1;
		overflow: hidden;
	}
	.pricing-cta::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
		opacity: 0;
		transition: opacity 0.3s;
	}
	.pricing-cta:hover::before {
		opacity: 1;
	}
	.pricing-cta-green {
		background: linear-gradient(135deg, #16a34a, #15803d);
		color: #fff !important;
		box-shadow: 0 4px 20px rgba(22, 163, 74, 0.3);
	}
	.pricing-cta-green:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(22, 163, 74, 0.45);
		color: #fff !important;
	}
	.pricing-cta-glow {
		background: linear-gradient(135deg, #16a34a, #0ea5e9);
		color: #fff !important;
		box-shadow: 0 4px 24px rgba(22, 163, 74, 0.35), 0 0 40px rgba(22, 163, 74, 0.1);
		animation: ctaGlow 2s ease-in-out infinite;
	}
	@keyframes ctaGlow {
		0,
		100% {
			box-shadow: 0 4px 24px rgba(22, 163, 74, 0.35), 0 0 30px rgba(22, 163, 74, 0.1);
		}
		50% {
			box-shadow: 0 4px 30px rgba(22, 163, 74, 0.5), 0 0 50px rgba(22, 163, 74, 0.2);
		}
	}
	.pricing-cta-glow:hover {
		transform: translateY(-2px);
		color: #fff !important;
		animation: none;
		box-shadow: 0 8px 40px rgba(22, 163, 74, 0.5), 0 0 60px rgba(22, 163, 74, 0.2);
	}
	.pricing-cta-blue {
		background: linear-gradient(135deg, #3b82f6, #6366f1);
		color: #fff !important;
		box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);
	}
	.pricing-cta-blue:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(59, 130, 246, 0.45);
		color: #fff !important;
	}

	/* ── Savings tag ── */
	.pricing-save {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 700;
		color: #fbbf24 !important;
		background: rgba(251, 191, 36, 0.1);
		padding: 3px 10px;
		border-radius: 100px;
		margin-top: 6px;
		border: 1px solid rgba(251, 191, 36, 0.15);
	}

	/* ── Floating particles for featured card ── */
	.pricing-particles {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		z-index: 0;
	}
	.pricing-particles span {
		position: absolute;
		width: 3px;
		height: 3px;
		background: rgba(22, 163, 74, 0.4);
		border-radius: 50%;
		animation: pFloat linear infinite;
	}
	.pricing-particles span:nth-child(1) {
		left: 15%;
		animation-duration: 6s;
		animation-delay: 0s;
	}
	.pricing-particles span:nth-child(2) {
		left: 35%;
		animation-duration: 8s;
		animation-delay: 1s;
	}
	.pricing-particles span:nth-child(3) {
		left: 55%;
		animation-duration: 7s;
		animation-delay: 2s;
	}
	.pricing-particles span:nth-child(4) {
		left: 75%;
		animation-duration: 9s;
		animation-delay: 0.5s;
	}
	.pricing-particles span:nth-child(5) {
		left: 90%;
		animation-duration: 6.5s;
		animation-delay: 1.5s;
	}
	.pricing-particles span:nth-child(6) {
		left: 25%;
		animation-duration: 7.5s;
		animation-delay: 3s;
	}
}

@media(max-width: 768px) {
	.pf-table thead {
		display: none;
	}
	.pf-table,
	.pf-table tbody,
	.pf-table tr,
	.pf-table td {
		display: block;
		width: 100%;
	}
	.pf-table tr {
		margin-bottom: 1.25rem;
		border: 1px solid rgba(255, 255, 255, 0.1) !important;
		border-radius: 20px;
		padding: 1.25rem;
		background: rgba(255, 255, 255, 0.02);
		transition: background 0.2s;
	}
	.pf-table tr:active {
		background: rgba(255, 255, 255, 0.08);
	}
	.pf-table td {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.6rem 0 !important;
		border: none !important;
		text-align: right !important;
	}
	.pf-table td:first-child {
		display: block;
		text-align: left !important;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
		padding-bottom: 0.75rem !important;
		margin-bottom: 0.5rem;
	}
	.pf-table td:not(:first-child)::before {
		content: attr(data-label);
		font-size: 0.65rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.35);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
}

@keyframes pFloat {
	0% {
		bottom: -5%;
		opacity: 0;
		transform: translateX(0);
	}
	10% {
		opacity: 0.6;
	}
	90% {
		opacity: 0.6;
	}
	100% {
		bottom: 105%;
		opacity: 0;
		transform: translateX(20px);
	}
}

.clickable-row {
	transition: all 0.2s ease;
}
.clickable-row:hover {
	background: rgba(255, 255, 255, 0.05) !important;
}
.clickable-row:active {
	transform: scale(0.98);
	background: rgba(255, 255, 255, 0.1) !important;
}
@keyframes pulse-neon {
	0% {
		transform: scale(1);
		box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
	}
	50% {
		transform: scale(1.1);
		box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
	}
	100% {
		transform: scale(1);
		box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
	}
}
.animate-pulse-neon {
	animation: pulse-neon 2s infinite ease-in-out;
}
.countdown-capsule {
	background: rgba(255, 255, 255, 0.02);
	border: 1px solid rgba(255, 255, 255, 0.06);
	border-radius: 24px;
	padding: 1.5rem 1.75rem;
	min-width: 120px;
	text-align: center;
	backdrop-filter: blur(12px);
	transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.countdown-capsule:hover {
	background: rgba(255, 255, 255, 0.06);
	border-color: rgba(99, 102, 241, 0.3);
	transform: translateY(-5px);
	box-shadow: 0 15px 30px -10px rgba(99, 102, 241, 0.2);
}
.countdown-num {
	font-size: 3rem;
	font-weight: 950;
	line-height: 1;
	display: block;
	letter-spacing: -0.05em;
}
.gradient-text-premium {
	background: linear-gradient(135deg, #fff 10%, #6366f1 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.4));
}
.countdown-unit-label {
	font-size: 0.65rem;
	font-weight: 800;
	color: rgba(255, 255, 255, 0.3);
	letter-spacing: 0.25em;
	margin-top: 10px;
	text-transform: uppercase;
}
.countdown-sep-premium {
	font-size: 2.2rem;
	font-weight: 900;
	color: rgba(255, 255, 255, 0.05);
	margin-bottom: 25px;
}
.animate-pulse-subtle {
	animation: pulse-subtle 4s infinite ease-in-out;
}
@keyframes pulse-subtle {
	0,
	100% {
		opacity: 1;
	}
	50% {
		opacity: 0.7;
	}
}
</style>
<div class="pf-wrap">
	<div
		class="container-custom">
		{# ── Dashboard Header ── #}
		<div class="row mb-5 stagger-1">
			<div class="col-12">
				<h1 class="dash-title">Dashboard</h1>
				<p class="dash-subtitle">Willkommen zurück,
					{{ app.user.firstName }}! Dein finanzielles Ökosystem auf einen Blick.</p>
			</div>
		</div>

		{# ── Profile & Steps ── #}
		<div class="row mb-4 stagger-2">
			<div class="col-12">
				<div class="glass-card p-4">
					<div class="row align-items-center">
						<div class="col-md-3">
							<h5 class="fw-800 mb-1">Dein Profil</h5>
							<p class="text-xs text-dim mb-0">Deine Onboarding-Schritte</p>
						</div>
						<div class="col-md-9">
							<div class="d-flex flex-wrap gap-2 justify-content-md-end">
								{% set step1 = user.username and user.firstName and user.lastName %}
								<div class="step-badge {{ step1 ? 'step-done' : 'step-pending' }}">
									<i class="fas {{ step1 ? 'fa-check-circle' : 'fa-circle' }}"></i>
									<span>Persönliche Daten</span>
								</div>
								{% set step2 = subscription|length >= 1 and app.user.subscriptionStatus != 'deactivated' %}
								<div class="step-badge {{ step2 ? 'step-done' : 'step-pending' }}">
									<i class="fas {{ step2 ? 'fa-check-circle' : 'fa-circle' }}"></i>
									<span>Abo aktiviert</span>
								</div>
								{% set step3 = user_accounts|length > 0 %}
								<div class="step-badge {{ step3 ? 'step-done' : 'step-pending' }}">
									<i class="fas {{ step3 ? 'fa-check-circle' : 'fa-circle' }}"></i>
									<span>Account verknüpft</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# ── Subscription & Master Trades Briefing ── #}
		<div
			class="row mb-5 stagger-3 g-4">
			<!-- Abonnement-Status (Premium Glass) -->
			<div class="col-md-6">
				<div class="glass-card glass-premium p-4 h-100 position-relative animate__animated animate__fadeInLeft">
					{% set isActive = subscription is iterable and subscription|length >= 1 or (subscription is not null and subscription.currentPeriodEnd is not null and subscription.currentPeriodEnd|date('U') >= "now"|date('U')) %}

					<div class="d-flex justify-content-between align-items-center mb-4">
						<h6 class="card-title fw-900 mb-0 opacity-80" style="letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.75rem;">Abonnement-Status</h6>
						{% if isActive %}
							<div class="status-pill d-flex align-items-center gap-2 bg-success bg-opacity-10 px-3 py-1 rounded-pill" style="border: 1px solid rgba(16, 185, 129, 0.3);">
								<span class="status-dot-on" style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; box-shadow: 0 0 10px #10b981;"></span>
								<span class="fw-900 text-white" style="font-size: 0.65rem; letter-spacing: 0.1em; text-shadow: 0 0 8px rgba(16, 185, 129, 0.8);">AKTIV</span>
							</div>
						{% else %}
							<div class="status-pill d-flex align-items-center gap-2 bg-danger bg-opacity-10 px-3 py-1 rounded-pill" style="border: 1px solid rgba(239, 68, 68, 0.3);">
								<span class="status-dot-off" style="width: 8px; height: 8px; background: #ef4444; border-radius: 50%; box-shadow: 0 0 10px #ef4444;"></span>
								<span class="fw-900 text-white" style="font-size: 0.65rem; letter-spacing: 0.1em; text-shadow: 0 0 8px rgba(239, 68, 68, 0.8);">INAKTIV</span>
							</div>
						{% endif %}
					</div>

					<div class="subscription-details-premium">
						{% if isActive %}
							{% set maxAcc = user.maxAccounts > 0 ? user.maxAccounts : 10 %}
							{# Account Usage #}
							<div class="sub-item-premium mb-4">
								<div class="d-flex justify-content-between mb-2">
									<span class="sub-label">Account-Kapazität</span>
									<span class="sub-value">{{ user_accounts|length }}
										/
										{{ maxAcc }}</span>
								</div>
								{% set acc_pct = (user_accounts|length / maxAcc) * 100 %}
								<div class="progress bg-white bg-opacity-5" style="height: 6px; border-radius: 10px; overflow: visible;">
									<div class="progress-bar sub-progress-fill-premium bg-primary" style="width: {{ acc_pct }}%; height: 100%; border-radius: 10px;"></div>
								</div>
							</div>

							{# Agent Usage #}
							<div class="sub-item-premium mb-4">
								<div class="d-flex justify-content-between mb-2">
									<span class="sub-label">Agent-Automatisierung</span>
									<span class="sub-value">{{ account_agent_connections|length }}
										/
										{{ maxAcc }}</span>
								</div>
								{% set agent_pct = (account_agent_connections|length / maxAcc) * 100 %}
								<div class="progress bg-white bg-opacity-5" style="height: 6px; border-radius: 10px; overflow: visible;">
									<div class="progress-bar sub-progress-fill-premium bg-success" style="width: {{ agent_pct }}%; height: 100%; border-radius: 10px;"></div>
								</div>
							</div>

							{# Expiry Box #}
							<div class="expiry-box-premium mt-5">
								<div class="sub-label mb-2">GÜLTIG BIS ZUM</div>
								<div class="expiry-date-premium">
									{% if subscription is not empty and subscription.status == "trialing" %}
										<i class="fas fa-magic me-2 text-white text-opacity-40"></i>
										{{ subscription.currentPeriodEnd|date('d.m.Y H:i') }}
										(Testphase)
									{% else %}
										<i class="far fa-calendar-alt me-2 text-white text-opacity-40"></i>
										{{ subscription and subscription.currentPeriodEnd ? subscription.currentPeriodEnd|date('d.m.Y H:i') : 'Unbegrenzt' }}
									{% endif %}
								</div>
							</div>

							{# Animated Seconds Remaining #}
							{% if subscription and subscription.currentPeriodEnd %}
								{% set remaining_seconds = subscription.currentPeriodEnd|date('U') - "now"|date('U') %}
								{% set remaining_days = (remaining_seconds / 86400)|round(0, 'floor') %}
								{% set remaining_hours = ((remaining_seconds % 86400) / 3600)|round(0, 'floor') %}

								<div class="mt-5 pt-4 border-top border-white border-opacity-10">
									<div class="mb-4 text-center">
										<span class="sub-label d-flex align-items-center justify-content-center gap-2" style="letter-spacing: 0.25em; font-size: 0.6rem; opacity: 0.5;">
											<span class="status-dot-mini animate-pulse-subtle" style="width: 6px; height: 6px; background: #10b981; border-radius: 50%; box-shadow: 0 0 10px #10b981;"></span>
											DASHBOARD STATUS:
											<span class="text-white text-opacity-80 fw-900">ACTIVE</span>
										</span>
									</div>

									<div
										class="d-flex align-items-center justify-content-center gap-3">
										{# Days Capsule #}
										<div class="countdown-capsule animate__animated animate__fadeInLeft">
											<div class="countdown-num gradient-text-premium">{{ remaining_days }}</div>
											<div class="countdown-unit-label">TAGE</div>
										</div>

										<div class="countdown-sep-premium animate__animated animate__fadeIn animate__delay-1s">:</div>

										{# Hours Capsule #}
										<div class="countdown-capsule animate__animated animate__fadeInRight">
											<div class="countdown-num text-white text-opacity-80">{{ remaining_hours }}</div>
											<div class="countdown-unit-label">STUNDEN</div>
										</div>
									</div>
								</div>
							{% endif %}
						{% else %}
							<div class="text-center py-5">
								<i class="fas fa-exclamation-triangle text-glow-danger mb-3" style="font-size: 2rem;"></i>
								<p class="small fw-900 text-white text-opacity-40 text-uppercase mb-4" style="letter-spacing: 0.1em;">Kein aktives Abonnement</p>
								<a href="https://shop.elaliholding.com/?add-to-cart=55229" target="_blank" class="btn btn-primary rounded-pill px-5 fw-900 shadow-lg" style="font-size: 0.8rem; letter-spacing: 0.05em; padding: 1rem 0;">Premium jetzt aktivieren</a>
							</div>
						{% endif %}
					</div>
				</div>
			</div>

			<!-- Live Master-Trades (Premium Glass) -->
			<div class="col-md-6">
				<div class="glass-card glass-premium p-4 h-100 position-relative animate__animated animate__fadeInRight">
					<div class="d-flex justify-content-between align-items-center mb-4">
						<h6 class="card-title fw-900 mb-0 opacity-80" style="letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.75rem; color: white !important;">Live Master-Trades</h6>
						<span class="badge badge-master-premium rounded-pill px-3 py-1">MASTER</span>
					</div>

					{% if master_trades|length > 0 %}
						{% set latest = master_trades[0] %}
						<div class="trade-featured-glass shadow-lg">
							<div class="d-flex justify-content-between align-items-start mb-3">
								<div>
									<div class="trade-symbol-premium">{{ latest.order_symbol }}</div>
									<div class="trade-meta-premium mt-1">
										<i class="far fa-clock me-1 opacity-50"></i>
										{{ latest.order_open_at|date('d.m.Y H:i') }}
										<span class="mx-2 opacity-20">|</span>
										<i class="fas fa-layer-group me-1 opacity-50"></i>
										{{ latest.order_lot }}
										Lot
									</div>
								</div>
								<div class="badge {{ latest.order_type == 'DEAL_TYPE_BUY' ? 'badge-buy-premium' : 'badge-sell-premium' }} rounded-pill px-3 py-1 fw-900" style="font-size: 0.65rem;">
									{{ latest.order_type == 'DEAL_TYPE_BUY' ? 'BUY' : 'SELL' }}
								</div>
							</div>

							<div class="mt-4 pt-3 border-top border-white border-opacity-10 d-flex justify-content-between align-items-center">
								<div>
									<div class="text-white text-opacity-40 fw-800" style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em;">Real-In Profit</div>
									{% if is_granted('ROLE_ADMIN') %}
										<form method="post" action="{{ path('app_admin_delete_order', {'orderId': latest.id}) }}" style="margin:0;margin-top:6px;" onsubmit="return confirm('Order #{{ latest.id }} ({{ latest.order_symbol }}) wirklich löschen?')">
											<button type="submit" style="background:rgba(220,38,38,0.15);color:#f87171;border:1px solid rgba(220,38,38,0.3);border-radius:8px;font-size:.65rem;font-weight:700;padding:3px 10px;cursor:pointer;transition:all .2s;">
												<i class="fas fa-trash-alt" style="font-size:.55rem;margin-right:3px;"></i> DEL #{{ latest.id }}
											</button>
										</form>
									{% endif %}
								</div>
								<div class="fw-900 {{ latest.order_profit >= 0 ? 'text-glow-success' : 'text-glow-danger' }}" style="font-size: 2.2rem; letter-spacing: -0.04em;">
									{{ latest.order_profit >= 0 ? '+' : '' }}{{ latest.order_profit|number_format(2, ',', '.') }}
									€
								</div>
							</div>
						</div>

						{# ── Maintenance Notice (Premium Refined) ── #}
						<div class="maintenance-notice mt-4 mb-3">
							<div class="p-4 rounded-24 position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(37, 99, 235, 0.05));
																																												        border: 1px solid rgba(59, 130, 246, 0.2);
																																														backdrop-filter: blur(12px);">
								<div class="d-flex align-items-start gap-3 position-relative" style="z-index: 2;">
									<div class="flex-shrink-0">
										<div class="d-flex align-items-center justify-content-center rounded-circle bg-info bg-opacity-20 animate-pulse-neon" style="width: 36px; height: 36px;">
											<i class="fas fa-info-circle text-info" style="font-size: 1rem;"></i>
										</div>
									</div>
									<div>
										<h6 class="fw-900 text-white mb-1" style="font-size: 0.85rem; letter-spacing: 0.02em;">System-Optimierung</h6>
										<p class="text-white text-opacity-60 mb-0" style="font-size: 0.7rem; line-height: 1.6; font-weight: 500;">
											Wir führen derzeit planmäßige Wartungsarbeiten durch.
											<span class="text-info fw-800">Master-Trades</span>
											werden angezeigt, jedoch gegebenenfalls nicht kopiert. Nach Abschluss wird der Betrieb vollautomatisch fortgesetzt.
										</p>
									</div>
								</div>
								{# Decorative Icon #}
								<div class="position-absolute top-0 end-0 p-3 opacity-10" style="transform: rotate(15deg) translateY(-10px);">
									<i class="fas fa-shield-alt fa-3x text-white"></i>
								</div>
							</div>
						</div>

						<div class="trade-list-container d-flex flex-column gap-2">
							{% for trade in master_trades|slice(1, 2) %}
								<div class="trade-item-frosted">
									<div class="d-flex align-items-center gap-3">
										<div class="badge {{ trade.order_type == 'DEAL_TYPE_BUY' ? 'text-success' : 'text-danger' }} fw-900 border border-current border-opacity-20" style="font-size: 0.55rem; min-width: 42px; background: none;">
											{{ trade.order_type == 'DEAL_TYPE_BUY' ? 'BUY' : 'SELL' }}
										</div>
										<div>
											<div class="fw-800 text-white" style="font-size: 0.95rem;">{{ trade.order_symbol }}</div>
											<div class="text-white text-opacity-40 fw-700" style="font-size: 0.65rem;">{{ trade.order_lot }}
												Lot</div>
										</div>
									</div>
									<div class="text-end">
										<div class="fw-900 {{ trade.order_profit >= 0 ? 'text-glow-success' : 'text-glow-danger' }}" style="font-size: 1.1rem;">
											{{ trade.order_profit >= 0 ? '+' : '' }}{{ trade.order_profit|number_format(2, ',', '.') }}
											€
										</div>
										<div class="text-white text-opacity-30 fw-600" style="font-size: 0.6rem;">{{ trade.order_close_at|date('d.m.Y H:i') }}</div>
									</div>
								</div>
							{% endfor %}
						</div>

						<style>
						.btn-agent-cta {
							position: relative;
							overflow: hidden;
							background: linear-gradient(135deg, rgba(74,222,128,0.12), rgba(139,92,246,0.12));
							border: 1px solid rgba(74,222,128,0.25);
							color: #4ade80;
							border-radius: 14px;
							padding: 0.8rem;
							font-size: 0.75rem;
							letter-spacing: 0.06em;
							transition: all 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
							box-shadow: 0 0 0 0 rgba(74,222,128,0), 0 4px 15px rgba(0,0,0,0.1);
							animation: agentBtnPulse 3s ease-in-out infinite;
						}
						.btn-agent-cta::before {
							content: '';
							position: absolute;
							top: 0; left: -100%;
							width: 100%; height: 100%;
