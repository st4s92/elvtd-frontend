{% extends 'login/index.html.twig' %}

{% block title %}ELVTD Finance - Passwort vergessen{% endblock %}

{% block body %}
    <div class="login-heading">
        <h1>Passwort vergessen?</h1>
        <p>Wir senden dir einen Link zum Zurücksetzen</p>
    </div>

    <div class="login-card">
        {% for flash_message in app.flashes('success') %}
            <div class="alert alert-success" style="border-radius:12px;font-size:0.82rem;font-weight:500;border:none;padding:0.75rem 1rem;margin-bottom:1rem;background:rgba(22,163,74,0.08);color:#16a34a;">
                {{ flash_message }}
            </div>
        {% endfor %}
        {% for flash_message in app.flashes('danger') %}
            <div class="alert alert-danger" style="border-radius:12px;font-size:0.82rem;font-weight:500;border:none;padding:0.75rem 1rem;margin-bottom:1rem;background:rgba(220,38,38,0.08);color:#dc2626;">
                {{ flash_message }}
            </div>
        {% endfor %}

        <form method="post" action="{{ path('app_forgot_password') }}">
            <div class="form-group" style="animation: fadeUp 0.5s 0.35s cubic-bezier(0.16,1,0.3,1) both;">
                <label for="email">E-Mail Adresse</label>
                <input type="email" id="email" name="email" class="form-input" required placeholder="max@beispiel.de">
            </div>

            <div class="login-links" style="animation: fadeUp 0.5s 0.45s cubic-bezier(0.16,1,0.3,1) both;">
                <a href="{{ path('app_login') }}"><i class="fas fa-arrow-left" style="font-size:0.7rem;margin-right:4px;"></i> Zurück zum Login</a>
            </div>

            <button type="submit" class="btn-login" style="animation: fadeUp 0.5s 0.5s cubic-bezier(0.16,1,0.3,1) both;">
                <span class="btn-shine"></span>
                Link senden
            </button>
        </form>
    </div>

    <div class="login-footer">
        <p>Noch kein Konto? <a href="{{ path('app_register') }}">Jetzt registrieren</a></p>
    </div>
{% endblock %}
