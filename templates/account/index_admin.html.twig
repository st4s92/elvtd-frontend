<script>
	document.addEventListener('DOMContentLoaded', function () {

const fmt = (n, d = 2) => Number(n).toLocaleString('de-DE', {
minimumFractionDigits: d,
maximumFractionDigits: d
});
const overlay = document.getElementById('loadingOverlay');
const content = document.getElementById('portfolioContent');
const statusMsg = document.getElementById('statusMessage');

// Rotate status messages during load
const messages = [
'Fetching account data from all brokers...',
'Synchronising balances & equity...',
'Scanning open positions across accounts...',
'Aggregating global performance metrics...',
'Analysing risk exposure...',
'Building admin overview...'
];
let msgIdx = 0;
const msgInterval = setInterval(() => {
msgIdx = (msgIdx + 1) % messages.length;
statusMsg.style.opacity = '0';
setTimeout(() => {
statusMsg.textContent = messages[msgIdx];
statusMsg.style.opacity = '1';
}, 200);
}, 2200);

// Fetch data
fetch('{{ path("app_admin_account_api_data") }}?errorOnly=      {{ errorOnly ? '1' : '0' }}').then(r => r.json()).then(data => {
clearInterval(msgInterval);

// Update JSON display with results
const jAccounts = document.getElementById('jAccounts');
const jUsers = document.getElementById('jUsers');
const jPositions = document.getElementById('jPositions');
const jRisk = document.getElementById('jRisk');
const jMonitoring = document.getElementById('jMonitoring');

const progressFill = document.getElementById('progressFill');
const progressLabel = document.getElementById('progressLabel');
const setProgress = (pct) => {
progressFill.style.width = pct + '%';
progressLabel.textContent = pct + '%';
};

const setDone = (el, val) => {
el.className = 'json-val-done';
el.textContent = val;
};
const setNum = (el, val) => {
el.className = 'json-val-number';
el.textContent = val;
};

setTimeout(() => {
setDone(jAccounts, `"${
data.accounts.length
} accounts loaded"`);
setProgress(20);
}, 200);
setTimeout(() => {
setNum(jUsers, data.userCount || 0);
setProgress(40);
}, 500);
setTimeout(() => {
setDone(jPositions, '"synced"');
setProgress(60);
}, 800);
setTimeout(() => {
setDone(jRisk, '"calculated"');
setProgress(80);
}, 1100);
setTimeout(() => {
setDone(jMonitoring, '"ready"');
setProgress(100);
}, 1400);

setTimeout(() => {
statusMsg.textContent = 'Dashboard ready.';
statusMsg.style.color = '#10b981';
}, 1600);

// Transition to real content
setTimeout(() => {
overlay.classList.add('fade-out');
if (window._stopParticles) 
window._stopParticles();



setTimeout(() => {
overlay.style.display = 'none';
renderPortfolio(data);
}, 800);
}, 2200);
}).catch(err => {
clearInterval(msgInterval);
statusMsg.textContent = 'Fehler beim Laden. Seite wird neu geladen...';
statusMsg.style.color = '#ef4444';
setTimeout(() => location.reload(), 2000);
});

function renderPortfolio(data) {
const {
accounts,
totalEquity,
totalBalance,
totalProfit,
totalDeposits,
accountCount,
userCount,
activeLast30Min,
activeLast24h
} = data;

// Header
document.getElementById('headerSubtitle').textContent = `${accountCount} Konten \u2022 ${userCount} Kunden \u2022 ${
fmt(totalBalance)
} \u20ac Gesamtdepot`;

// Stats
document.getElementById('valBalance').textContent = fmt(totalBalance) + ' \u20ac';
document.getElementById('valProfit').textContent = fmt(totalProfit) + ' \u20ac';

// Growth %
if (totalDeposits > 0) {
const growthPct = ((totalBalance - totalDeposits) / totalDeposits) * 100;
const growthColor = growthPct >= 0 ? 'var(--g)' : 'var(--r)';
document.getElementById('valGrowth').style.color = growthColor;
document.getElementById('valGrowth').textContent = fmt(growthPct) + ' %';
} else {
document.getElementById('valGrowth').textContent = '0,00 %';
}

// Open Profit
const openPnl = totalEquity - totalBalance;
const openColor = openPnl >= 0 ? 'var(--g)' : 'var(--r)';
document.getElementById('valOpenProfit').style.color = openColor;
document.getElementById('valOpenProfit').textContent = fmt(openPnl) + ' \u20ac';

document.getElementById('valAccountCount').textContent = accountCount;
document.getElementById('valUserCount').textContent = userCount;
document.getElementById('valActive30').textContent = activeLast30Min || 0;
document.getElementById('valActive24').textContent = activeLast24h || 0;

// Accounts table
const tbody = document.getElementById('accountsBody');
accounts.forEach((acc, idx) => {
const openPnL = acc.equity - acc.balance;
const ddPct = acc.balance > 0 ? (openPnL / acc.balance * 100) : 0;
const pnlColor = openPnL >= 0 ? 'var(--g)' : 'var(--r)';
const profitColor = acc.profit >= 0 ? 'var(--g)' : 'var(--r)';
const profitBadge = acc.profit >= 0 ? 'bg-success' : 'bg-danger';
const gainPct = acc.gain ? Number(acc.gain).toFixed(2) : '0.00';
const platformIcon = acc.platform === 'ctrader' ? 'dna' : 'bolt';

// Status
let statusHtml = '';
const isDisc = acc.error === 'DISCONNECTED' || acc.error === 'ST\u00d6RUNG';
const isError = acc.error && acc.error.length > 0;
if (isDisc) {
const label = acc.error === 'ST\u00d6RUNG' ? 'St\u00f6rung' : 'Disconnected';
statusHtml = `<div class="pill pill-error"><span class="dot dot-r"></span> ${label}</div>`;
} else if (isError && acc.error !== 'subscription expired') {
const label = acc.isActive ? 'Online' : 'St\u00f6rung';
statusHtml = `<div class="pill pill-offline"><span class="dot dot-off"></span> ${label}</div>`;
} else {
const pillClass = acc.isActive ? 'pill-online' : 'pill-offline';
const dotClass = acc.isActive ? 'dot-on' : 'dot-off';
const label = acc.isActive ? 'Online' : 'Pausiert';
statusHtml = `<div class="pill ${pillClass}"><span class="dot ${dotClass}"></span> ${label}</div>`;
}

// Build actions
let actionsHtml = `
		<a href="${
acc.showUrl
}" class="btn-modern btn-ghost p-2" title="Ansehen"><i class="fas fa-eye"></i></a>
		<a href="${
acc.editUrl
}" class="btn-modern btn-ghost p-2" title="Bearbeiten"><i class="fas fa-pen"></i></a>
		<form method="post" action="${
acc.deleteUrl
}" onsubmit="return confirm('L\u00f6schen?');" style="display:inline;">
			<input type="hidden" name="_token" value="${
acc.deleteToken
}">
			<button class="btn-modern btn-ghost p-2 text-danger" type="submit"><i class="fas fa-trash"></i></button>
		</form>`;

if (acc.flattenUrl) {
actionsHtml += `
		<a href="${
acc.flattenUrl
}" class="btn-modern btn-warning-outline p-2" title="Flatten" onclick="return confirm('Alle Positionen schliessen?');">
			<i class="fas fa-compress-arrows-alt"></i> FLATTEN
		</a>`;
}

const tr = document.createElement('tr');
tr.className = 'clickable-row';
tr.onclick = (e) => {
if (!e.target.closest('a') && !e.target.closest('form') && !e.target.closest('button')) {
window.location.href = acc.showUrl;
}
};
tr.style.opacity = '0';
tr.style.transform = 'translateY(10px)';
tr.style.transition = `opacity 0.4s ease ${
idx * 0.05
}s, transform 0.4s ease ${
idx * 0.05
}s`;
tr.innerHTML = `
						<td data-label="Account">
							<div class="d-flex align-items-center">
								<div class="me-3" style="background:var(--bg-root);border-radius:12px;padding:10px;">
									<i class="fas fa-${platformIcon} opacity-50"></i>
								</div>
								<div>
									<a href="${
acc.showUrl
}" class="text-dark" style="font-weight:700;text-decoration:none;">${
acc.name
}</a><br>
									<span class="badge-acc">${
acc.login
}</span>
									<span class="badge-acc">${
acc.broker
}</span>
									${
acc.username ? `<br><span class="badge-user">${
acc.username
}${
acc.fullName ? ' \u2022 ' + acc.fullName : ''
}</span>` : ''
}
								</div>
							</div>
						</td>
						<td data-label="Status">${statusHtml}</td>
						<td data-label="Platform">
							${
acc.host ? `<span class="badge-host">${
acc.host
}</span> ` : ''
}
							<span class="badge-platform">${
acc.platform || '-'
}</span>
							${
acc.lastUpdate ? `<br><span style="font-size:0.65rem;color:var(--txt-dim);">${
acc.lastUpdate
}</span>` : ''
}
						</td>
						<td data-label="Equity" class="text-end">
							<span style="font-weight:800;">${
fmt(acc.equity)
}</span>
						</td>
						<td data-label="Balance" class="text-end">
							<span style="font-weight:700;">${
fmt(acc.balance)
}</span>
						</td>
						<td data-label="Offener Profit" class="text-center">
							<span style="font-weight:700;color:${pnlColor}">${
fmt(openPnL)
} \u20ac</span><br>
							<span class="badge ${
openPnL >= 0 ? 'bg-success' : 'bg-danger'
} p-1" style="font-size:0.6rem;">${
ddPct.toFixed(2)
}% DD</span>
						</td>
						<td data-label="Gesamtprofit" class="text-center">
							<span style="font-weight:700;color:${profitColor}">${
fmt(acc.profit)
} \u20ac</span><br>
							<span class="badge ${profitBadge} p-1" style="font-size:0.65rem;">${gainPct}%</span>
						</td>
						<td data-label="Aktionen" class="text-end">
							<div class="d-flex justify-content-end gap-2 flex-wrap">
								${actionsHtml}
							</div>
						</td>
					`;
tbody.appendChild(tr);
});

// Show content with staggered reveals
content.classList.add('revealed');

requestAnimationFrame(() => { // Reveal stat cards
document.querySelectorAll('.stat-card').forEach((el, i) => {
setTimeout(() => el.classList.add('revealed'), i * 100);
});
// Reveal accounts table
setTimeout(() => {
document.getElementById('tableWrap').classList.add('revealed');
tbody.querySelectorAll('tr').forEach(tr => {
requestAnimationFrame(() => {
tr.style.opacity = '1';
tr.style.transform = 'translateY(0)';
});
});
}, 700);
});
}

});
</script>{% endblock %}
