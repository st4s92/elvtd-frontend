	{% set api = apiData %}
	{% set bal = api ? api.account.balance : account.balance %}
	{% set eq = api ? api.account.equity : account.equity %}
	{% set orders = api ? (api.orders ?? []) : [] %}
	{% set trades = allClosedTrades ?? [] %}
	{% set sa = api ? (api.serverAccount ?? null) : null %}
	{% set apiUpdatedAt = (api and api.account.updated_at is defined and api.account.updated_at) ? api.account.updated_at : null %}
	{% set isStale = apiUpdatedAt is null or (date().timestamp - apiUpdatedAt|date('U') > 300) %}
	{% set isOn = api and api.account is defined and not isStale %}
	{% set isDisconnected = account.platform == 'ctrader' and isStale %}
	{% set tokenExpiresAt = (api and api.account.token_expired_at is defined and api.account.token_expired_at) ? api.account.token_expired_at : null %}
	{% set tokenExpiresSoon = tokenExpiresAt and (tokenExpiresAt|date('U') - date().timestamp < 259200) %}

	{# Open profit = sum of all active position profits #}
	{% set op = 0 %}
	{% for o in orders %}
		{% set op = op + (o.OrderProfit ?? o.orderProfit ?? o.order_profit ?? 0) %}
	{% endfor %}
	{% set opPct = bal > 0 ? ((op / bal) * 100) : 0 %}

	<div class="dn">
		<div class="dn-wrap">
			<div
				class="container" style="max-width:1160px;">

				{# ═══ AI LOADING OVERLAY ═══ #}
				<div id="aiLoader" class="card-d p-4 mb-3" style="text-align:center;">
					<div class="ai-loader">
						<div class="ai-spinner"></div>
						<div class="ai-text" style="font-weight:600;font-size:.85rem;color:var(--txt);">Analysing Account Data</div>
						<div class="ai-bar"></div>
						<div style="display:flex;gap:1.5rem;font-size:.7rem;color:var(--txt2);margin-top:.5rem;">
							<span>
								<i class="fas fa-server" style="margin-right:4px;"></i>Fetching positions</span>
							<span>
								<i class="fas fa-chart-bar" style="margin-right:4px;"></i>Computing analytics</span>
							<span>
								<i class="fas fa-calendar" style="margin-right:4px;"></i>Building calendar</span>
						</div>
					</div>
				</div>

				<div
					id="aiContent" style="display:none;">

					{# ═══ HEADER ═══ #}
					<div class="card-d p-4 mb-3 fu{{ isStale ? ' header-offline' : '' }}">
						{% if isStale %}
						<div class="offline-banner">
							<div class="offline-banner-icon"><i class="fas fa-exclamation-triangle"></i></div>
							<div class="offline-banner-text">
								Account ist offline — keine Verbindung zum Trading-Server
								<span>Letzte Aktualisierung: {{ apiUpdatedAt ? apiUpdatedAt|date('d.m.Y H:i:s') : 'unbekannt' }}</span>
							</div>
							<a href="{{ path('app_helpdesk_new') }}?subject={{ ('Account Offline: ' ~ account.login ~ ' (' ~ account.name ~ ')')|url_encode }}" class="offline-ticket-btn">
								<i class="fas fa-ticket-alt"></i> Support-Ticket
							</a>
						</div>
						{% endif %}
						<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 header-content" style="{{ isStale ? 'margin-top:0.75rem;' : '' }}">
							<div>
								{% if is_granted('ROLE_ADMIN') and account.user %}
									<span style="opacity:.3;font-size:.75rem;">{{ account.user.username }}
										{% if account.user.firstname|length > 1 %}
											—
											{{ account.user.firstname }}
											{{ account.user.lastname }}
										{% endif %}
									</span><br>
								{% endif %}
								<h3 style="font-weight:800;font-size:1.4rem;margin:0;">
									{{ account.name }}
									<span style="opacity:.25">#{{ account.login }}</span>
								</h3>
								<div class="d-flex flex-wrap gap-2 mt-2">
									{% if isDisconnected %}
										<span class="pill" style="color:var(--r);">
											<span class="dot dot-off"></span>
											Disconnected</span>
										<a href="{{ path('app_auth_ctrader_reauth', {meta_id: account.metaId}) }}" class="pill" style="color:var(--warn,#f0ad4e);cursor:pointer;text-decoration:none;" onclick="return confirm('Tokens bei cTrader neu autorisieren?');">
											<i class="fas fa-key" style="font-size:.55rem;"></i>
											Neu autorisieren</a>
									{% else %}
										<span class="pill">
											<span class="dot {{ isOn ? 'dot-on' : 'dot-off' }}"></span>
											{{ isOn ? 'Live' : 'Offline' }}</span>
										{% if tokenExpiresSoon %}
											<a href="{{ path('app_auth_ctrader_reauth', {meta_id: account.metaId}) }}" class="pill" style="color:var(--warn,#f0ad4e);cursor:pointer;text-decoration:none;" onclick="return confirm('Token läuft bald ab. Jetzt neu autorisieren?');">
												<i class="fas fa-exclamation-triangle" style="font-size:.55rem;"></i>
												Token läuft ab
												{{ tokenExpiresAt|date('d.m.Y') }}</a>
										{% endif %}
									{% endif %}
									<span class="pill">{{ account.platform|upper }}</span>
									<span class="pill">{{ account.type == 1 ? 'Agent' : (account.type == 2 ? 'Leader' : 'Subscriber') }}</span>
									{% if account.broker is defined and account.broker %}
										<span class="pill">
											<i class="fas fa-building" style="font-size:.55rem;opacity:.4;"></i>
											{{ account.broker }}</span>
									{% endif %}
									<span class="pill">
										<i class="fas fa-server" style="font-size:.55rem;opacity:.4;"></i>
										{{ account.tradeServer ?? '-' }}</span>
								</div>
								<div style="font-size:.7rem;color:var(--txt2);margin-top:.4rem;" id="liveUpdatedAt">
									<i class="fas fa-clock" style="font-size:.55rem;"></i>
									Aktualisiert:
									<span id="liveUpdatedAtTime">{{ apiUpdatedAt ? apiUpdatedAt|date('d.m.Y H:i:s') : (account.lastUpdate ? account.lastUpdate|date('d.m.Y H:i:s') : '-') }}</span>
								</div>
							</div>
							<div class="d-flex gap-2 header-actions">
								{% if ctraderWs %}
								<button id="autoUpdateBtn" class="btn btn-sm mb-0" title="Live Auto-Update via WebSocket">
									<span class="live-dot"></span><span>LIVE</span>
								</button>
								<button id="openStandaloneChart" class="btn btn-sm mb-0" title="USTEC Chart öffnen" style="background:linear-gradient(135deg,#312e81,#4338ca);color:#fff;border:none;font-size:.75rem;letter-spacing:.02em;">
									<i class="fas fa-chart-area me-1"></i>Chart
								</button>
								{% endif %}
								<a href="{{ path('app_account_update', {'meta_id': account.login}) }}" class="btn btn-sm btn-dark mb-0">
									<i class="fas fa-sync-alt me-1"></i>Update</a>
								<a href="{{ path('app_account_edit', {'meta_id': account.metaId}) }}" class="btn btn-sm btn-outline-secondary mb-0">
									<i class="fas fa-pen me-1"></i>Edit</a>
								<form method="post" action="{{ path('app_account_delete', {'meta_id': account.metaId}) }}" style="display:inline;" onsubmit="return confirm('Account wirklich löschen?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.metaId) }}">
									<button class="btn btn-sm btn-outline-danger mb-0" type="submit">
										<i class="fas fa-trash me-1"></i>Delete</button>
								</form>
								{% if is_granted('ROLE_ADMIN') %}
									<a href="{{ path('app_account_transfer_denies', {'meta_id': account.metaId}) }}" class="btn btn-sm btn-outline-danger mb-0" title="Auf Denies übertragen">
										<i class="fas fa-exchange-alt"></i>
									</a>
								{% endif %}
							</div>
						</div>
					</div>

					{% if agent is not null and multiplier.multiplier > 0 %}
						<div class="card-d p-3 mb-3 fu d1" style="border-left:3px solid var(--g);">
							<div class="d-flex flex-column flex-md-row align-items-md-center gap-2" style="font-size:.82rem;">
								<div class="d-flex align-items-center gap-2">
									<i class="fas fa-link tg"></i>
									<span>Verbunden mit
										<strong>{{ agent.name }}</strong>
										&middot; Multiplikator
										<strong>{{ multiplier.multiplier }}</strong>
									</span>
								</div>
								<div class="d-flex gap-2 ms-md-auto mt-2 mt-md-0">
									<a href="/agents" class="btn btn-sm btn-dark mb-0 flex-grow-1 flex-md-grow-0">Agents
										<i class="fas fa-arrow-right ms-1"></i>
									</a>
									<form action="{{ path('app_agents_remove_subscriber') }}" method="post" class="d-inline flex-grow-1 flex-md-grow-0" onsubmit="return confirm('Verbindung wirklich trennen?');">
										<input type="hidden" name="subscriberId" value="{{ account.metaId }}">
										<input type="hidden" name="strategyId" value="{{ agent.metaId }}">
										<input type="hidden" name="redirectTo" value="{{ path('app_account_show', {meta_id: account.metaId}) }}">
										<button type="submit" class="btn btn-sm btn-outline-danger mb-0 w-100">
											<i class="fas fa-unlink me-1"></i>Trennen
										</button>
									</form>
								</div>
							</div>
						</div>
					{% else %}
						<div class="card-d p-3 mb-3 fu d1" style="border-left:3px solid var(--r);">
							<div class="d-flex flex-column flex-md-row align-items-md-center gap-2" style="font-size:.82rem;">
								<div class="d-flex align-items-center gap-2">
									<i class="fas fa-unlink tr"></i>
									<span>Nicht mit einem Agent verbunden</span>
								</div>
								<button type="button" class="btn btn-sm btn-dark mb-0 ms-md-auto mt-2 mt-md-0" data-bs-toggle="modal" data-bs-target="#connectAgentModal">
									<i class="fas fa-link me-1"></i>Verbinden
								</button>
							</div>
						</div>

						{# ═══ CONNECT AGENT MODAL ═══ #}
						<div class="modal fade" id="connectAgentModal" tabindex="-1" aria-labelledby="connectAgentModalLabel" aria-hidden="true">
							<div class="modal-dialog modal-dialog-centered">
								<div class="modal-content">
									<div class="modal-header">
										<h5 class="modal-title" id="connectAgentModalLabel">
											<i class="fas fa-link me-2"></i>Agent verbinden</h5>
										<button type="button" class="btn-close text-dark" data-bs-dismiss="modal" aria-label="Close">
											<span aria-hidden="true">&times;</span>
										</button>
									</div>
									<form action="{{ path('app_agents_update_subscriber') }}" method="post">
										<div class="modal-body">
											<div class="py-2">
												<p>
													<strong>Risikohinweis:</strong><br>
													Die Nutzung dieser automatisierten Handelsplattform erfolgt auf eigenes Risiko. Aufgrund von Marktvolatilität, wirtschaftlichen sowie politischen Unwägbarkeiten kann es zu erheblichen Verlusten bis hin zum vollständigen Verlust des eingesetzten Kapitals kommen.
													<br>
													Mit der Teilnahme an der Automatisierung erkennen Sie diese Risiken ausdrücklich an und erklären sich mit deren Bedingungen einverstanden.
												</p>
											</div>
											<label for="agentSelect" class="ms-0">Agent auswählen</label>
											<select class="form-control" id="agentSelect" name="strategyId">
												{% for ag in agents %}
													<option value="{{ ag.metaId }}">{{ ag.name }}</option>
												{% endfor %}
											</select>
											<input type="hidden" name="subscriberId" value="{{ account.metaId }}">
											<input type="hidden" name="multiplier" value="1">
											<input type="hidden" name="redirectTo" value="{{ path('app_account_show', {meta_id: account.metaId}) }}">
										</div>
										<div class="modal-footer">
											<button type="button" class="btn bg-danger-soft" data-bs-dismiss="modal">Abbrechen</button>
											<button type="submit" class="btn btn-dark">
												<i class="fas fa-link me-1"></i>Verbinden</button>
										</div>
									</form>
								</div>
							</div>
						</div>
					{% endif %}

					{# ═══ STATS ═══ #}
					<div class="row g-3 mb-3" id="liveStatsRow">
						<div class="col-6 col-lg-3 fu d1">
							<div class="card-d p-3 h-100 accent-top">
								<div class="lbl mb-1">Balance</div>
								<div class="val" id="liveBalance">${{ bal|number_format(2, ',', '.') }}</div>
							</div>
						</div>
						<div class="col-6 col-lg-3 fu d2">
							<div class="card-d p-3 h-100 accent-top">
								<div class="lbl mb-1">Equity</div>
								<div class="val" id="liveEquity">${{ eq|number_format(2, ',', '.') }}</div>
							</div>
						</div>
						<div class="col-6 col-lg-3 fu d3">
							<div class="card-d p-3 h-100 {{ op >= 0 ? 'accent-top' : 'accent-top-r' }}" id="liveOpenProfitCard">
								<div class="lbl mb-1">Open Profit</div>
								<div class="val {{ op >= 0 ? 'tg' : 'tr' }}" id="liveOpenProfit">{{ op >= 0 ? '+' : '' }}${{ op|number_format(2, ',', '.') }}</div>
								<div style="font-size:.72rem;color:var(--txt2);" id="liveOpenProfitPct">{{ opPct|number_format(2) }}%</div>
							</div>
						</div>
						<div class="col-6 col-lg-3 fu d4">
							<div class="card-d p-3 h-100 accent-top">
								<div class="lbl mb-1">Positions</div>
								<div class="val" id="livePositionCount">{{ orders|length }}</div>
							</div>
						</div>
					</div>

					{# ═══ OPEN POSITIONS ═══ #}
					<div class="card-d p-4 mb-3 fu d4" id="livePositionsCard">
						<div class="d-flex justify-content-between align-items-center mb-3">
							<div class="sec-t mb-0">
								<i class="fas fa-chart-line"></i>
								Open Positions
								<span id="liveIndicator" class="pill ms-2" style="display:none;color:var(--g);"><span class="dot dot-on" style="width:6px;height:6px;"></span> Live</span>
							</div>
							{% if orders|length > 0 %}
								{% if account.platform == 'ctrader' %}
									<button type="button" id="closeAllBtn" class="btn btn-sm close-all-disabled" style="background:var(--r);color:#fff;border:none;border-radius:8px;font-size:.75rem;padding:.35rem .8rem;">
										<i class="fas fa-times-circle me-1"></i>Alle schließen
									</button>
								{% else %}
									<form method="post" action="{{ path('app_account_flush_positions', {'meta_id': account.metaId}) }}" style="display:inline;" onsubmit="return confirm('Alle {{ orders|length }} Positionen schließen?');">
										<input type="hidden" name="_token" value="{{ csrf_token('flush' ~ account.metaId) }}">
										<button type="submit" class="btn btn-sm" style="background:var(--r);color:#fff;border:none;border-radius:8px;font-size:.75rem;padding:.35rem .8rem;">
											<i class="fas fa-times-circle me-1"></i>Alle schließen
										</button>
									</form>
								{% endif %}
							{% endif %}
						</div>
						{% if orders|length > 0 %}
							<div class="scroll-t">
								<table class="tt">
									<thead>
										<tr>
											<th>Ticket</th>
											<th>Open Time</th>
											<th>Symbol</th>
											<th>Type</th>
											<th>Lot</th>
											<th>Entry</th>
											<th style="text-align:right">Profit</th>
											<th style="text-align:center;width:40px;"></th>
										</tr>
									</thead>
									<tbody>
										{% for o in orders %}
											{% set buy = 'BUY' in (o.OrderType ?? o.orderType ?? o.order_type ?? '')|upper %}
											{% set pnl = o.OrderProfit ?? o.orderProfit ?? o.order_profit ?? 0 %}
											{% set oid = o.Id ?? o.id ?? 0 %}
											<tr>
												<td style="opacity:.4;">{{ o.OrderTicket ?? o.orderTicket ?? o.order_ticket ?? '-' }}</td>
												<td style="opacity:.6; font-size: 0.72rem;">{{ o.OrderOpenAt ?? o.orderOpenAt ?? o.order_open_at ?? o.OpenTime ?? o.openTime ?? o.open_time ?? o.CreatedAt ?? o.createdAt ?? o.created_at ?? '-' }}</td>
												<td>
													<strong>{{ o.OrderSymbol ?? o.orderSymbol ?? o.order_symbol ?? '-' }}</strong>
													{% if account.platform == 'ctrader' %}
														{% set sym = o.OrderSymbol ?? o.orderSymbol ?? o.order_symbol ?? '' %}
														<a href="#" class="open-chart-btn"
														   data-symbol="{{ sym }}"
														   data-account="{{ account.login }}"
														   data-order-id="{{ oid }}"
														   data-meta-id="{{ account.metaId }}"
														   data-entry="{{ o.OrderPrice ?? o.orderPrice ?? o.order_price ?? 0 }}"
														   data-lot="{{ o.OrderLot ?? o.orderLot ?? o.order_lot ?? 0 }}"
														   data-pnl="{{ pnl }}"
														   data-type="{{ buy ? 'BUY' : 'SELL' }}"
														   data-csrf="{{ csrf_token('close' ~ oid) }}"
														   title="Chart öffnen">
															<i class="fas fa-chart-area"></i> Chart
														</a>
													{% endif %}
												</td>
												<td>
													<span class="{{ buy ? 'b-buy' : 'b-sell' }}">{{ buy ? 'BUY' : 'SELL' }}</span>
												</td>
												<td>{{ (o.OrderLot ?? o.orderLot ?? o.order_lot ?? 0)|number_format(2) }}</td>
												<td>{{ (o.OrderPrice ?? o.orderPrice ?? o.order_price ?? 0)|number_format(5) }}</td>
												<td style="text-align:right;font-weight:700" class="{{ pnl >= 0 ? 'tg' : 'tr' }}">{{ pnl >= 0 ? '+' : '' }}{{ pnl|number_format(2) }}</td>
												<td style="text-align:center;">
													{% if oid > 0 %}
														{% if account.platform == 'ctrader' %}
															<button type="button" class="ws-close-btn close-btn-disabled"
																data-position-id="{{ oid }}"
																data-raw-volume="{{ ((o.OrderLot ?? o.orderLot ?? o.order_lot ?? 0) * 10000)|round }}"
																style="background:none;border:none;color:var(--r);font-size:.85rem;padding:2px 6px;"
																title="Position schließen (Live Modus erforderlich)">
																<i class="fas fa-times"></i>
															</button>
														{% else %}
															<form method="post" action="{{ path('app_account_close_order', {'meta_id': account.metaId, 'orderId': oid}) }}" style="display:inline;" onsubmit="return confirm('Position schließen?');">
																<input type="hidden" name="_token" value="{{ csrf_token('close' ~ oid) }}">
																<button type="submit" style="background:none;border:none;cursor:pointer;color:var(--r);font-size:.85rem;padding:2px 6px;" title="Position schließen">
																	<i class="fas fa-times"></i>
																</button>
															</form>
														{% endif %}
													{% endif %}
												</td>
											</tr>
										{% endfor %}
									</tbody>
								</table>
							</div>
						{% else %}
							<div class="empty">
								<i class="fas fa-inbox"></i>No open positions</div>
						{% endif %}
					</div>

					{# ═══ ANALYTICS STATS (computed in JS) ═══ #}
					<div id="analyticsStats" class="fu d5"></div>

					{# ═══ TRADE CALENDAR ═══ #}
					<div class="card-d p-4 mb-3 fu d5">
						<div class="sec-t">
							<i class="fas fa-calendar-alt"></i>
							Trade Calendar</div>
						<div id="tradeCalendar"></div>
						<div id="dayTradesPanel" class="day-trades-panel">
							<div class="day-trades-inner">
								<div class="day-trades-header">
									<h4>
										<i class="fas fa-list-ul" style="opacity:.35;font-size:.75rem;"></i>
										<span id="dayTradesTitle"></span>
									</h4>
									<button class="close-btn" id="closeDayTrades">
										<i class="fas fa-times"></i>
									</button>
								</div>
								<div id="dayTradesList"></div>
							</div>
						</div>
					</div>

					{# ═══ DAILY P/L CHART ═══ #}
					<div class="card-d p-4 mb-3 fu d6">
						<div class="sec-t">
							<i class="fas fa-chart-bar"></i>
							Daily Performance</div>
						<div style="position:relative;height:260px;">
							<canvas id="dailyPnlChart"></canvas>
						</div>
					</div>

					{# ═══ CUMULATIVE P/L CHART ═══ #}
					<div class="card-d p-4 mb-3 fu d6">
						<div class="sec-t">
							<i class="fas fa-chart-area"></i>
							Cumulative P/L</div>
						<div style="position:relative;height:260px;">
							<canvas id="cumulativeChart"></canvas>
						</div>
					</div>

					{# ═══ TRADE HISTORY (ALL TRADES) ═══ #}
					<div class="card-d p-4 mb-3 fu d7">
						<div class="sec-t">
							<i class="fas fa-history"></i>
							Trade History
							{% if trades|length > 0 %}
								<span class="pill ms-2">{{ trades|length }}
									trades</span>
							{% endif %}
						</div>
						{% if trades|length > 0 %}
							<div class="scroll-t">
								<table class="tt">
									<thead>
										<tr>
											<th>Ticket</th>
											<th>Symbol</th>
											<th>Type</th>
											<th>Lot</th>
											<th>Entry</th>
											<th>Close</th>
											<th>Profit</th>
											<th>Opened</th>
											<th>Closed</th>
										</tr>
									</thead>
									<tbody>
										{% for t in trades %}
											{% set ticket_num = t.order_ticket ?? t.orderTicket ?? t.id ?? 0 %}
											{% set label = t.order_label ?? t.orderLabel ?? '' %}
											{% set copyMsg = t.copy_message ?? t.copyMessage ?? '' %}
											{% set isAgent = 'copy_' in label %}
											{% set isZeroTicket = (ticket_num == 0 or ticket_num == '0') %}
											{% set isCopyError = isZeroTicket and copyMsg and isAgent %}
											{% if not isZeroTicket or isCopyError %}
											{% set buy = 'BUY' in (t.order_type ?? t.orderType ?? '')|upper %}
											{% set pnl = t.order_profit ?? t.orderProfit ?? 0 %}
											<tr{% if isCopyError %} style="background:rgba(220,38,38,0.03);"{% endif %}>
												<td>
													{% if not isZeroTicket %}<span style="background:rgba(99,102,241,0.08);color:#6366f1;font-size:.68rem;font-weight:700;padding:3px 8px;border-radius:6px;white-space:nowrap;">#{{ ticket_num }}</span>{% endif %}
													{% if isAgent %}<span style="background:rgba(22,163,74,0.08);color:#16a34a;font-size:.62rem;font-weight:700;padding:2px 6px;border-radius:5px;margin-left:3px;white-space:nowrap;">AGENT</span>{% endif %}
													{% if isCopyError %}<span style="background:rgba(220,38,38,0.08);color:#dc2626;font-size:.62rem;font-weight:700;padding:2px 6px;border-radius:5px;white-space:nowrap;">FEHLER</span>{% endif %}
												</td>
												<td>
													<strong>{{ t.order_symbol ?? t.orderSymbol ?? '-' }}</strong>
													{% if isCopyError %}<div style="font-size:.65rem;color:#dc2626;font-weight:600;margin-top:2px;">{{ copyMsg }}</div>{% endif %}
												</td>
												<td>
													<span class="{{ buy ? 'b-buy' : 'b-sell' }}">{{ buy ? 'BUY' : 'SELL' }}</span>
												</td>
												<td>{{ (t.order_lot ?? t.orderLot ?? 0)|number_format(2) }}</td>
												<td>{{ (t.order_price ?? t.orderPrice ?? 0)|number_format(5) }}</td>
												<td>{{ (t.close_price ?? t.closePrice ?? t.order_close_price ?? t.orderClosePrice ?? 0)|number_format(5) }}</td>
												<td class="{{ pnl >= 0 ? 'tg' : 'tr' }}" style="font-weight:700">{{ pnl >= 0 ? '+' : '' }}{{ pnl|number_format(2) }}</td>
												<td style="opacity:.35;font-size:.72rem;">{{ t.order_open_at ?? t.orderOpenAt ?? '-' }}</td>
												<td style="opacity:.35;font-size:.72rem;">{{ t.order_close_at ?? t.orderCloseAt ?? '-' }}</td>
											</tr>
											{% endif %}
										{% endfor %}
									</tbody>
								</table>
							</div>
						{% else %}
							<div class="empty">
								<i class="fas fa-inbox"></i>No trade history</div>
						{% endif %}
					</div>

				</div>
				{# /aiContent #}

			</div>
		</div>
	</div>

	{# ═══ FULLSCREEN CHART MODAL ═══ #}
	<div class="chart-overlay" id="chartOverlay">
		<div class="chart-modal">
			<div class="chart-modal-header">
				<div class="cm-title">
					<div class="cm-symbol-picker" id="cmSymbolPicker" style="position:relative;">
						<button id="cmSymbolBtn" style="display:flex;align-items:center;gap:6px;background:none;border:1px solid var(--border);border-radius:8px;padding:4px 10px;cursor:pointer;font-size:1.05rem;font-weight:700;letter-spacing:-.02em;color:var(--txt);transition:all .15s;">
							<span id="cmSymbol">-</span>
							<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:.5;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
						</button>
						<div id="cmSymbolDropdown" style="display:none;position:absolute;top:calc(100% + 4px);left:0;width:260px;max-height:340px;background:var(--bg2,#fff);border:1px solid var(--border,#e2e8f0);border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,.15);z-index:9999;overflow:hidden;">
							<div style="padding:8px;">
								<input id="cmSymbolSearch" type="text" placeholder="Symbol suchen..." style="width:100%;padding:8px 10px;border:1px solid var(--border,#e2e8f0);border-radius:8px;font-size:.85rem;outline:none;background:var(--bg,#f7fafc);color:var(--txt,#2d3748);box-sizing:border-box;">
							</div>
							<div id="cmSymbolList" style="max-height:280px;overflow-y:auto;padding:0 4px 4px;"></div>
						</div>
					</div>
					<span id="cmBadge" class="b-buy">BUY</span>
					<span id="cmLiveBadge" class="cm-live-badge" style="display:none;">
						<span class="cm-live-dot"></span>LIVE
					</span>
				</div>
				<div class="cm-info">
					<span class="cm-info-item">
						<span class="cm-info-label">Entry</span>
						<strong id="cmEntry">-</strong>
					</span>
					<span class="cm-info-item">
						<span class="cm-info-label">Exit</span>
						<strong id="cmExit">-</strong>
					</span>
					<span class="cm-info-item">
						<span class="cm-info-label">Lot</span>
						<strong id="cmLot">-</strong>
					</span>
					<span id="cmPnlWrap" class="cm-info-item">
						<span class="cm-info-label">P/L</span>
						<strong id="cmPnl">-</strong>
					</span>
				</div>
				<div class="cm-header-stats">
					<span>P&L: <strong id="cmHeaderPnl" class="pnl-pos">$0.00</strong></span>
					<span>Bal: <strong id="cmHeaderBalance">-</strong></span>
				</div>
				<button class="cm-close-position" id="cmClosePosition" style="display:none;">
					<i class="fas fa-times-circle"></i>
					Close Position</button>
				<button class="cm-close" id="cmClose">
					<i class="fas fa-times"></i>
					ESC</button>
			</div>
			<div class="cm-chart-wrapper">
				<div class="chart-modal-body" id="chartContainer"></div>
				<div class="cm-bottom-area">
					<div class="cm-order-panel" id="cmOrderPanel" style="display:none;">
						<div class="op-head">Order Entry</div>
						<div class="op-types">
							<button class="op-type-btn active" data-type="market">Market</button>
							<button class="op-type-btn" data-type="limit">Limit</button>
							<button class="op-type-btn" data-type="stop">Stop</button>
							<button class="op-type-btn" data-type="stoplimit">Stop Limit</button>
						</div>
						<div class="op-sides">
							<button class="op-side-btn active-buy" id="cmSideBuy">Buy</button>
							<button class="op-side-btn active-sell" id="cmSideSell">Sell</button>
						</div>
						<div class="op-qlabel">Quantity</div>
						<div class="op-qty-wrap">
							<button class="op-qty-btn" id="cmQtyMinus">&minus;</button>
							<input type="number" class="op-qty-input" id="cmQtyInput" value="1" min="0.01" step="1">
							<button class="op-qty-btn" id="cmQtyPlus">+</button>
						</div>
						<div class="op-presets">
							<button class="op-preset-btn active" data-qty="1">1</button>
							<button class="op-preset-btn" data-qty="2">2</button>
							<button class="op-preset-btn" data-qty="3">3</button>
							<button class="op-preset-btn" data-qty="5">5</button>
							<button class="op-preset-btn" data-qty="10">10</button>
						</div>
						<button class="op-submit buy" id="cmSubmitOrder">Buy 1 Market</button>
						<div class="op-mobile-row">
							<button class="op-submit sell op-mobile-sell" id="cmMobileSell">Sell <span class="op-mob-qty">1</span></button>
							<div class="op-qty-wrap op-mobile-qty">
								<button class="op-qty-btn" onclick="document.getElementById('cmQtyInput').stepDown();document.getElementById('cmQtyInput').dispatchEvent(new Event('input'));">&minus;</button>
								<input type="number" class="op-qty-input" value="1" min="0.01" step="1" id="cmQtyInputMobile" style="font-size:16px;">
								<button class="op-qty-btn" onclick="document.getElementById('cmQtyInput').stepUp();document.getElementById('cmQtyInput').dispatchEvent(new Event('input'));">+</button>
							</div>
							<button class="op-submit buy op-mobile-buy" id="cmMobileBuy">Buy <span class="op-mob-qty">1</span></button>
						</div>
						<div class="op-status" id="cmOrderStatus"></div>
					</div>
					<div class="cm-positions-panel" id="cmPositionsPanel" style="display:none;">
						<div class="cm-positions-tabs">
							<div class="cm-positions-tab active" data-panel-tab="positions">Positions <span class="tab-count" id="cmPosCount">0</span></div>
							<div class="cm-positions-tab" data-panel-tab="accounts">Accounts <span class="tab-count">{{ userAccounts|length }}</span></div>
							<div class="cm-positions-tab" data-panel-tab="studies">Studies <span class="tab-count">2</span></div>
							<div class="cm-positions-summary">
								<span>P&L: <strong id="cmPosPnl" class="pnl-pos">$0.00</strong></span>
								<span>Balance: <strong id="cmPosBalance">-</strong></span>
							</div>
						</div>
						<div class="cm-pos-table-wrap" id="cmTabPositions">
							<table class="cm-pos-table">
								<thead>
									<tr>
										<th>Symbol</th>
										<th>Side</th>
										<th>Qty</th>
										<th>Entry</th>
										<th>P&L</th>
										<th>Time</th>
										<th>Action</th>
									</tr>
								</thead>
								<tbody id="cmPosBody"></tbody>
							</table>
						</div>
						<div class="cm-pos-table-wrap" id="cmTabAccounts" style="display:none;">
							<table class="cm-pos-table">
								<thead>
									<tr>
										<th>Account</th>
										<th>Platform</th>
										<th>Balance</th>
										<th>Equity</th>
										<th>Profit</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									{% for ua in userAccounts %}
										<tr{% if ua.metaId == account.metaId %} style="background:rgba(59,130,246,0.06);"{% endif %}>
											<td>
												<strong>{{ ua.name }}</strong><br>
												<span style="opacity:.5;">{{ ua.login }}</span>
											</td>
											<td><span style="text-transform:uppercase;font-weight:600;">{{ ua.platform }}</span></td>
											<td>{{ ua.balance|number_format(2, ',', '.') }}</td>
											<td>{{ ua.equity|number_format(2, ',', '.') }}</td>
											<td class="{{ (ua.equity - ua.balance) >= 0 ? 'pnl-pos' : 'pnl-neg' }}" style="font-weight:700;">
												{{ (ua.equity - ua.balance) >= 0 ? '+' : '' }}{{ (ua.equity - ua.balance)|number_format(2, ',', '.') }}
											</td>
											<td>
												{% if ua.metaId != account.metaId %}
													<a href="{{ path('app_account_show', {meta_id: ua.metaId}) }}" style="color:#3b82f6;text-decoration:none;font-weight:600;font-size:.7rem;">View</a>
												{% else %}
													<span style="color:#94a3b8;font-size:.65rem;">current</span>
												{% endif %}
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
						<div class="cm-pos-table-wrap" id="cmTabStudies" style="display:none;padding:8px 12px;">
							<div class="cm-study-list">
								<label class="cm-study-toggle">
									<input type="checkbox" checked data-study="killzones">
									<span class="cm-study-name">ELVTD Killzones</span>
									<span class="cm-study-desc">ICT Session High/Low</span>
								</label>
								<label class="cm-study-toggle">
									<input type="checkbox" checked data-study="liquidityProfile">
									<span class="cm-study-name">ELVTD Depth Zones</span>
									<span class="cm-study-desc">Order Flow Structure</span>
								</label>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	{# ═══ DATA + EXTERNAL SCRIPT ═══ #}
	<script>
		window.__DENIES_TRADES__ = {{ trades|json_encode|raw }};
window.__ACCOUNT_LOGIN__ = {{ account.login }};
window.__ACCOUNT_PLATFORM__ = '{{ account.platform }}';
window.__ACCOUNT_META_ID__ = '{{ account.metaId }}';
{% if ctraderWs %}
window.__CTRADER_WS__ = {{ ctraderWs|json_encode|raw }};
{% endif %}
{% if apiData is defined and apiData and apiData.orders is defined %}
window.__OPEN_POSITIONS__ = {{ apiData.orders|json_encode|raw }};
{% endif %}
{% if apiData is defined and apiData %}
window.__ACCOUNT_BALANCE__ = {{ apiData.balance|default(0) }};
window.__ACCOUNT_EQUITY__ = {{ apiData.equity|default(0) }};
{% endif %}
	</script>
	<script src="/assets/js/denies-account.js?v={{ "now"|date('U') }}"></script>
	<script>
	document.querySelectorAll('.cm-positions-tab[data-panel-tab]').forEach(function(tab) {
		tab.addEventListener('click', function() {
			document.querySelectorAll('.cm-positions-tab[data-panel-tab]').forEach(function(t) { t.classList.remove('active'); });
			tab.classList.add('active');
			var target = tab.getAttribute('data-panel-tab');
			document.getElementById('cmTabPositions').style.display = target === 'positions' ? '' : 'none';
			document.getElementById('cmTabAccounts').style.display = target === 'accounts' ? '' : 'none';
			document.getElementById('cmTabStudies').style.display = target === 'studies' ? '' : 'none';
		});
	});
	// Prevent pinch-zoom inside chart modal
	document.getElementById('chartOverlay').addEventListener('touchmove', function(e) {
		if (e.touches.length > 1) e.preventDefault();
	}, { passive: false });
	// Prevent iOS zoom on input focus
	document.querySelectorAll('.chart-modal input, .chart-modal select').forEach(function(el) {
		el.addEventListener('focus', function() { document.querySelector('meta[name=viewport]').setAttribute('content', 'width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no'); });
	});
	// Sync mobile qty input with main qty input
	var mainQty = document.getElementById('cmQtyInput');
	var mobQty = document.getElementById('cmQtyInputMobile');
	var mobQtySpans = document.querySelectorAll('.op-mob-qty');
	function syncQty(src) {
		var v = src.value;
		mainQty.value = v;
		if (mobQty) mobQty.value = v;
		mobQtySpans.forEach(function(s) { s.textContent = v; });
		var sub = document.getElementById('cmSubmitOrder');
		if (sub) sub.textContent = sub.textContent.replace(/\d+/, v);
	}
	if (mainQty) mainQty.addEventListener('input', function() { syncQty(mainQty); });
	if (mobQty) {
		mobQty.addEventListener('input', function() { syncQty(mobQty); });
		mobQty.addEventListener('change', function() { syncQty(mobQty); });
	}
	// Mobile buy/sell buttons trigger the main submit
	var mobileSell = document.getElementById('cmMobileSell');
	var mobileBuy = document.getElementById('cmMobileBuy');
	if (mobileSell) mobileSell.addEventListener('click', function() {
		var sellBtn = document.getElementById('cmSideSell');
		if (sellBtn) sellBtn.click();
		setTimeout(function() { document.getElementById('cmSubmitOrder').click(); }, 50);
	});
	if (mobileBuy) mobileBuy.addEventListener('click', function() {
		var buyBtn = document.getElementById('cmSideBuy');
		if (buyBtn) buyBtn.click();
		setTimeout(function() { document.getElementById('cmSubmitOrder').click(); }, 50);
	});
	// Study toggles — remove + re-draw shapes
	document.querySelectorAll('.cm-study-toggle input[data-study]').forEach(function(cb) {
		cb.addEventListener('change', function() {
			var study = cb.getAttribute('data-study');
			var w = window._tvWidgetInstance;
			if (!w) return;
			try {
				var chart = w.activeChart();
				if (!cb.checked) {
					var shapes = window._studyShapes[study] || [];
					shapes.forEach(function(id) { try { chart.removeEntity(id); } catch(e) {} });
					window._studyShapes[study] = [];
				} else {
					if (study === 'liquidityProfile' && typeof window._drawOrderFlowStructure === 'function' && window._collectedBarsRef) {
						window._studyShapes[study] = window._drawOrderFlowStructure(chart, window._collectedBarsRef);
					} else {
						var data = window._studyData[study] || [];
						window._studyShapes[study] = [];
						data.forEach(function(d) {
							var id = chart.createMultipointShape(d.pts, d.opts);
							if (id) window._studyShapes[study].push(id);
						});
					}
				}
			} catch(e) { console.warn('[Studies] Toggle error:', e); }
		});
	});
	</script>
{% endblock %}
