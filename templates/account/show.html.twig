{# templates/account/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Account Details -
	{{ account.name }}
{% endblock %}

{% block body %}
	<div class="wrapper">
		<div class="container mt-5">
			<div class="container my-4 mx-0 p-4 card">
				<h3>
					{% if is_granted('ROLE_ADMIN') %}
						{{ account.user.username }}
						{% if account.user.firstname|length > 1 %}
							-
							{{ account.user.firstname }}
							{{ account.user.lastname }}
						{% endif %}
						|
					{% endif %}

					{{ account.name }}
					#{{ account.login }}
					<span class="text-xs badge badge-sm bg-gradient-success text-uppercase mx-1">{{ account.platform }}</span>
					{{ account.type == 1 ? '<span class="text-xs badge badge-sm bg-gradient-success ">Agent</span>' : (account.type == 2 ? '<span class="text-xs badge badge-sm bg-gradient-primary mx-1">Leader</span>' : '<span class="text-xs badge badge-sm bg-gradient-info mx-1">Subscriber</span>') }}
					{{ account.isActive ? '<span class="text-xs badge badge-sm bg-gradient-success mx-1">Online</span>' : '<span class="text-xs badge badge-sm bg-gradient-danger mx-1">Pausiert</span>' }}
					{% if is_granted('ROLE_ADMIN') %}
						<span class="text-xs text-dark">{{ account.host }}</span>
						<a href="{{ path('app_account_transfer_denies', {'meta_id': account.metaId}) }}" class="btn btn-link text-dark px-3 mb-0 float-sm-end" data-bs-toggle="tooltip" data-bs-placement="bottom" aria-label="Auf Denies übertragen" data-bs-original-title="Auf Denies übertragen">
							<i class="fa-classic fa-solid fa-exchange"></i>
						</a>
					{% endif %}
					{% if account.host == 'denies' %}
						<a href="{{ path('app_account_update', {'meta_id': account.login}) }}" class="ms-auto btn bg-gradient-dark mb-0 float-end" data-bs-toggle="tooltip" data-bs-placement="bottom" aria-label="Account aktualisieren" data-bs-original-title="Account aktualisieren">
							Account aktualisieren
							<i class="fa-classic fa-solid fa-refresh ms-1"></i>
						</a>
					{% else %}
						<a href="{{ path('app_account_update', {'meta_id': account.metaId}) }}" class="ms-auto btn bg-gradient-dark mb-0 float-end" data-bs-toggle="tooltip" data-bs-placement="bottom" aria-label="Account aktualisieren" data-bs-original-title="Account aktualisieren">
							Account aktualisieren
							<i class="fa-classic fa-solid fa-refresh ms-1"></i>
						</a>
					{% endif %}
				</h3>
				<p class="mb-0 font-weight-normal text-sm">
					{{ account.tradeServer }}
					<i class="material-symbols-rounded text-xs my-auto mx-1">schedule</i>aktualisiert am
					{{ account.lastUpdate|date('d.m.Y H:i:s') }}
				</p>
			</div>

			{% if account.error|length < 1 %}
				{% if agent|length > 0 and multiplier.multiplier > 0 %}
					<div class="container my-4 mx-0 p-0">
						<div class="row">
							<div class="col-12 mb-1">
								<div class="p-4 ps-3 badge-info border-radius-2xl">
									Dieser Account ist mit dem Agent
									<strong>{{ agent.name }}</strong>
									und einem Multiplikator
									<strong>{{ multiplier.multiplier }}</strong>
									verbunden.
									<a href="/agents" class="ms-auto btn bg-gradient-dark mb-0 float-end">Zu den Agents
										<i class="fas fa-arrow-right ms-1" aria-hidden="true"></i>
									</a>
								</div>
							</div>
						</div>
					</div>
				{% else %}
					<div class="container my-4 mx-0 p-0">
						<div class="row">
							<div class="col-12 mb-1">
								<div class="p-4 ps-3 badge-danger border-radius-2xl">
									{% if agent|length > 0 and multiplier.multiplier > 0 %}
										Dieser Account ist mit keinem Agent verbunden. Du musst diesen Account mit einem Agent verbinden um die Automatisierung zu nutzen.
										<a href="/agents" class="ms-auto btn bg-gradient-dark mb-0 float-end">Zu den Agents
											<i class="fas fa-arrow-right ms-1" aria-hidden="true"></i>
										</a>
									{% else %}
										Dieser Account ist mit keinem Agent verbunden. Bitte den Agent verbinden um die Automatisierung zu nutzen.
										<a href="/agents" class="ms-auto btn bg-gradient-dark mb-0 float-end">Zu den Agents
											<i class="fas fa-arrow-right ms-1" aria-hidden="true"></i>
										</a>
									{% endif %}
								</div>
							</div>
						</div>
					</div>
				{% endif %}
			{% endif %}

			{% if account.host != 'metapi' %}
				{% if account.error|length > 0  %}
					<div class="container my-4 mx-0 p-0">
						<div class="row">
							<div class="col-12 mb-1">
								{% if account.error != 'NONE' %}
									<div class="p-4 ps-3 badge-danger border-radius-2xl">
										{% if account.error == "EMPTY_EWALLET" %}
											Dein Account wird derzeit aktualisiert ...
										{% elseif account.error == "DISCONNECTED" %}
											<i class="material-symbols-rounded text-sm my-auto me-1">cloud_off</i>
											Dieser Account ist
											<strong>nicht verbunden</strong>. Die letzte Aktivität liegt mehr als 5 Minuten zurück.
										{% else %}
											Fehler beim Verbinden mit dem Account auf
											{{ account.tradeServer }}
											({{ account.platform }}):
											<strong>{{ account.error }}</strong>.
											<form method="post" action="{{ path('app_account_delete', {'meta_id': account.metaId}) }}" style="display:inline;">
												<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.metaId) }}">
												<button class="ms-auto btn bg-gradient-dark mb-0 float-end" type="submit" data-bs-toggle="tooltip" data-bs-placement="bottom" aria-label="löschen" data-bs-original-title="löschen">Account löschen</button>
											</form>
										{% endif %}
									</div>
								</div>
							{% else %}
								<div class="p-4 ps-3 badge-info border-radius-2xl">
									Account wird derzeit verbunden ...
								</div>
							</div>
						{% endif %}
					</div>
				</div>
			{% endif %}
		{% endif %}

		<div class="container my-4 mx-0 p-0">
			<div class="row">
				<div class="col-6 mb-4">
					<div class="card">
						<div class="card-header p-2 ps-3">
							<h6 class="text-sm mb-0 text-capitalize pt-2">Balance</h6>
							<h4 class="mb-0">{{ account.balance|number_format(2, ',', '.') }}</h4>
							{% if account.host != 'metapi' %}
								<span class="text-sm">
									<i class="material-symbols-rounded text-xs my-auto mx-1">schedule</i>
									Aktualisierung alle 15 Minuten</span>
							{% endif %}
						</div>
						{% if account.host == 'metapi' %}
							<hr class="dark horizontal my-0">
							<div class="card-footer p-2 ps-3">
								{% set totalYesterdayProfit = 0 %}
								{% set totalYesterdayGain = 0 %}

								{% set yesterday = "now"|date_modify("-1 day")|date("Y-m-d") %}

								{% for growth in account.dailyGrowth %}
									{% if growth.date == yesterday %}
										{% set totalYesterdayProfit = totalYesterdayProfit + (growth.profit ?? 0) %}
										{% set totalYesterdayGain = totalYesterdayGain + (growth.gain ?? 0) %}
									{% endif %}
								{% endfor %}
								<p class="mb-0 text-sm">
									<span class="{% if totalYesterdayProfit >= 0 %}text-success{% else %}text-danger{% endif %} font-weight-bolder">
										{% if totalYesterdayProfit > 0 %}+
										{% endif %}
										{{ totalYesterdayProfit|number_format(2, ',', '.') }}
									</span>
									am Vortag
								</p>
							</div>
						{% endif %}
					</div>
				</div>
				<div class="col-6 mb-4">
					<div class="card">
						<div class="card-header p-2 ps-3">
							<h6 class="text-sm mb-0 text-capitalize pt-2">Equity</h6>
							<h4 class="mb-0">{{ account.equity|number_format(2, ',', '.') }}</h4>
							{% if account.host != 'metapi' %}
								<span class="text-sm">
									<i class="material-symbols-rounded text-xs my-auto mx-1">schedule</i>
									Aktualisierung alle 15 Minuten</span>
							{% endif %}
						</div>
						{% if account.host == 'metapi' %}
							<hr class="dark horizontal my-0">
							<div class="card-footer p-2 ps-3">
								{% set totalYesterdayProfit = 0 %}
								{% set totalYesterdayGain = 0 %}

								{% set yesterday = "now"|date_modify("-1 day")|date("Y-m-d") %}

								{% for growth in account.dailyGrowth %}
									{% if growth.date == yesterday %}
										{% set totalYesterdayProfit = totalYesterdayProfit + (growth.profit ?? 0) %}
										{% set totalYesterdayGain = totalYesterdayGain + (growth.gain ?? 0) %}
									{% endif %}
								{% endfor %}
								<p class="mb-0 text-sm">
									<span class="{% if totalYesterdayProfit >= 0 %}text-success{% else %}text-danger{% endif %} font-weight-bolder">
										{% if totalYesterdayProfit > 0 %}+
										{% endif %}
										{{ totalYesterdayProfit|number_format(2, ',', '.') }}
									</span>
									am Vortag
								</p>
							</div>
						{% endif %}
					</div>
				</div>
				<div class="col-6">
					<div class="card">
						<div class="card-header p-2 ps-3">
							<h6 class="text-sm mb-0 text-capitalize pt-2">Offener Profit</h6>
							<h4 class="mb-0">
								{{ (account.equity - account.balance)|number_format(2, ',', '.') }}

								{% set equity = account.equity|default(0) %}
								{% set balance = account.balance|default(1) %}
								{% set openProfit = equity - balance %}
								{% set openProfitPercent = balance > 0 ? ((openProfit / balance) * 100) : 0 %}

								{% if openProfitPercent > 0 %}
									<span class="badge badge-success my-auto">
										<i class="material-symbols-rounded text-xs">arrow_upward</i>
										<span class="text-lg">{{ openProfitPercent|number_format(2, ',', '.') }}%</span>
									</span>
								{% elseif openProfitPercent|round(0) == 0 %}
									<span class="badge badge-secondary">
										<i class="material-symbols-rounded text-xs">swap_horiz</i>
										<span class="text-lg">{{ openProfitPercent|number_format(2, ',', '.') }}%</span>
									</span>
								{% else %}
									<span class="badge badge-danger">
										<i class="material-symbols-rounded text-xs">arrow_downward</i>
										<span class="text-lg">{{ openProfitPercent|number_format(2, ',', '.') }}%</span>
									</span>
								{% endif %}
							</h4>
							{% if account.host != 'metapi' %}
								<span class="text-sm">
									<i class="material-symbols-rounded text-xs my-auto mx-1">schedule</i>
									Aktualisierung alle 15 Minuten</span>
							{% endif %}
						</div>
						<hr class="dark horizontal my-0">
						<div
							class="card-footer p-2 ps-3">{#                            <p class="mb-0 text-sm"><span class="text-success font-weight-bolder">+55% </span>than last week</p>#}
						</div>
					</div>
				</div>
				<div class="col-6">
					<div class="card">
						<div class="card-header p-2 ps-3">
							<h6 class="text-sm mb-0 text-capitalize pt-2">Offene Positionen</h6>
							<h4 class="mb-0">{{ openPositions|length }}</h4>
							{% if account.host != 'metapi' %}
								<span class="text-sm">
									<i class="material-symbols-rounded text-xs my-auto mx-1">schedule</i>
									Aktualisierung alle 15 Minuten</span>
							{% endif %}
						</div>
						<hr class="dark horizontal my-0">
						<div
							class="card-footer p-2 ps-3">{#                            <p class="mb-0 text-sm"><span class="text-success font-weight-bolder">+55% </span>than last week</p>#}
						</div>
					</div>
				</div>
			</div>
		</div>

		<h3>Analytics Report</h3>

		<div class="row">
			<div class="{% if account.host == 'metapi' %}col-lg-6 col-md-6{% else %}col-lg-12 col-md-12{% endif %} mt-0 mb-3">
				<div class="card">
					<div class="card-body">
						<h6 class="mb-0 ">Wachstum</h6>
						{% if account.host == 'metapi' %}
							<p class="text-sm ">Wachstum hat
								<strong>{{ account.absoluteGain|round(2) }}%</strong>
								erreicht</p>
						{% endif %}
						<div class="pe-2">
							<div class="chart">
								<div style="width: 100%; margin: auto;">
									<canvas id="profitChart"></canvas>
								</div>

								<script>
									// Extrahiere die Daten aus Twig
const dailyGrowth = {{ dailyGrowth|json_encode|raw }};

// Bereite die Daten für die Chart.js-Konfiguration vor
const labels = dailyGrowth.map(entry => entry.date); // x-Achse: "date"

{% if account.host == 'metapi' %}
const data = dailyGrowth.map(entry => entry.balance || 0); // y-Achse: "balance"
{% else %}
const data = dailyGrowth.map(entry => entry.profit || 0); // y-Achse: "profit"
{% endif %}

// Berechne die akkumulierten Profite/Verluste
let accumulatedProfit = 0;
const accumulatedData = dailyGrowth.map(entry => {
accumulatedProfit += entry.profit || 0;
return accumulatedProfit;
});

// Initialisierung des Charts
const ctx = document.getElementById('profitChart').getContext('2d');
const profitChart = new Chart(ctx, {
type: 'line',
data: {
labels: labels,
datasets: [
{
label: '{% if account.host == "metapi" %}
Balance
{% else %}
Tagesprofit
{% endif %}
',
data: data,
borderColor: 'rgba(75, 220, 192, 1)',
backgroundColor: 'rgba(75, 192, 192, 0.4)',
tension: 0.2,
fill: true,
pointRadius: 2
}, {
label: 'Akkumulierter Profit/Verlust',
data: accumulatedData,
borderColor: 'rgba(75, 192, 180, 1)',
backgroundColor: 'rgba(75, 145, 180, 0.1)',
tension: 0.2,
fill: true,
pointRadius: 2
}
]
},
options: {
responsive: true,
plugins: {
legend: {
position: 'top'
},
title: {
display: false,
text: 'Wachstum'
}
},
scales: {
x: {
title: {
display: false,
text: 'Datum'
},
grid: {
display: false // Vertikales Grid entfernen
},
ticks: {
display: false // Beschriftung auf der x-Achse entfernen
}
},
y: {
title: {
display: false,
text: '{% if account.host == "metapi" %}
Balance
{% else %}
Tagesprofit
{% endif %}
'

},
beginAtZero: true // Startet die y-Achse bei 0
}
}
}
});
								</script>
							</div>
						</div>
						<hr class="dark horizontal">
						<div class="d-flex ">
							<i class="material-symbols-rounded text-sm my-auto me-1">schedule</i>
							<p class="mb-0 text-sm">
								aktualisiert am
								{{ account.lastUpdate|date('d.m.Y H:i:s') }}</p>
						</div>
					</div>
				</div>
			</div>
			{# <div class="col-lg-4 col-md-6 mt-0 mb-4">
																																																																																	                    <div class="card">
																																																																																	                        <div class="card-body">
