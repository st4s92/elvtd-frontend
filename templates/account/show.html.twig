		<script>
			document.addEventListener('DOMContentLoaded', function () { // Die dailyGrowth-Daten aus der Twig-Variable holen
const dailyGrowth = {{ dailyGrowth|json_encode|raw }};

// Events für FullCalendar erstellen
const events = dailyGrowth.filter(day => day.profit !== undefined).map(day => { // Profit formatieren (z. B. $443, $1.78K, -$4.99K)
let profit = day.profit || 0;
let formattedProfit = '';
if (profit < 0) {
formattedProfit = '-$' + Math.abs(profit).toFixed(2);
} else {
formattedProfit = '$' + profit.toFixed(2);
}
if (Math.abs(profit) >= 1000) {
formattedProfit = (profit < 0 ? '-$' : '$') + (Math.abs(profit) / 1000).toFixed(2) + 'K';
}

// Prozentsatz (gains)
const percent = (day.gains || 0).toFixed(2) + '%';

// Hintergrundfarbe basierend auf Profit
const backgroundColor = profit < 0 ? '#f8d7da' : '#d4edda'; // Rot für Verluste, Grün für Gewinne

return {
title: formattedProfit,
start: day.date,
backgroundColor: backgroundColor,
borderColor: backgroundColor,
extendedProps: {
percent: percent
}
};
});

// Kalender initialisieren
var calendarEl = document.getElementById('calendar');
var calendar = new FullCalendar.Calendar(calendarEl, {
initialView: 'dayGridMonth',
headerToolbar: {
left: 'prev,next',
center: 'title',
right: 'today'
},
events: events,
eventContent: function (arg) {
let title = arg.event.title;
let percent = arg.event.extendedProps.percent;
let colorClass = title.startsWith('-') ? 'text-dark' : 'text-dark';

return {html: `
                                    <div class="${colorClass} text-xs py-4">
                                        <div class="text-bolder">${title}</div>
                                        <div>${percent}</div>
                                    </div>
                                `};
},
datesSet: function (dateInfo) {
calculateStats(dateInfo.start, dateInfo.end);
}
});
calendar.render();

// Funktion zum Berechnen der Statistiken
function calculateStats(startDate, endDate) {
const monthData = dailyGrowth.filter(day => {
const dayDate = new Date(day.date);
return dayDate >= startDate && dayDate <= endDate && day.profit !== undefined;
});

const monthlyProfit = monthData.reduce((sum, day) => sum + (day.profit || 0), 0);
const tradingDays = monthData.length;

const weeks = {};
monthData.forEach(day => {
const date = new Date(day.date);
const weekNumber = Math.ceil((date.getDate() + (new Date(date.getFullYear(), date.getMonth(), 1).getDay() + 6) % 7) / 7);
if (! weeks[weekNumber]) {
weeks[weekNumber] = {
profit: 0,
days: 0
};
}
weeks[weekNumber].profit += day.profit || 0;
weeks[weekNumber].days += 1;
});

let formattedMonthlyProfit = monthlyProfit >= 1000 ? (monthlyProfit < 0 ? '-$' : '$') + (Math.abs(monthlyProfit) / 1000).toFixed(2) + 'K' : (monthlyProfit < 0 ? '-$' : '$') + monthlyProfit.toFixed(2);
let statsHtml = `
                            <p><strong>Dieser Monat:</strong> ${formattedMonthlyProfit}, ${tradingDays} Tage</p>
                            <div class="row">
                        `;
for (const [week, data] of Object.entries(weeks)) {
let formattedWeekProfit = data.profit >= 1000 ? (data.profit < 0 ? '-$' : '$') + (Math.abs(data.profit) / 1000).toFixed(2) + 'K' : (data.profit < 0 ? '-$' : '$') + data.profit.toFixed(2);
statsHtml += `<div class="col-xl-6 col-sm-6 mb-4"><div class="card px-3 py-2"><strong>Woche ${week}:</strong> ${formattedWeekProfit}, ${
data.days
} Tage</div></div>`;
}
statsHtml += '</div>';

document.getElementById('calendar-stats').innerHTML = statsHtml;
}

// Teilen-Button-Handler
document.getElementById('shareButton').addEventListener('click', function () {
const calendarWrapper = document.getElementById('calendarWrapper');
if (calendarWrapper) { // Speichere die ursprüngliche Breite
const calendarElement = document.getElementById('calendar');
const calendarHeader = calendarWrapper.querySelector('.fc-col-header ');
const calendarDays = calendarWrapper.querySelector('.fc-scrollgrid-sync-table');
const originalWidth = calendarWrapper.style.width || calendarWrapper.offsetWidth + 'px';
const originalWidthCalendar = calendarHeader.style.width || calendarHeader.offsetWidth + 'px';
const printWith = '1550px';
const elementWith = '1410px';

// Setze eine minimale Breite für den Export (z. B. 800px)
calendarWrapper.style.minWidth = printWith;
calendarWrapper.style.width = printWith;
calendarElement.style.minWidth = elementWith;
calendarElement.style.width = elementWith;
calendarHeader.style.minWidth = elementWith;
calendarHeader.style.width = elementWith;
calendarDays.style.minWidth = elementWith;
calendarDays.style.width = elementWith;

// Temporäre CSS-Klassen hinzufügen, um Button-Gruppe und Today-Button auszublenden
const buttonGroup = calendarWrapper.querySelector('.fc-button-group');
const todayButton = calendarWrapper.querySelector('.fc-today-button');
if (buttonGroup) 
buttonGroup.style.display = 'none';



if (todayButton) 
todayButton.style.display = 'none';



document.getElementById('exportLogo').style.display = 'block'; // Logo für den Export sichtbar machen

setTimeout(() => {
html2canvas(calendarWrapper, {
scale: 2, // Erhöht die Auflösung
useCORS: true // Für externe Ressourcen (falls vorhanden)
}).then(canvas => {
const link = document.createElement('a');
link.download = 'trade_calendar_                           {{ account.name|replace({" ": "_"}) }}_' + new Date().toISOString().slice(0, 10) + '.png';
link.href = canvas.toDataURL('image/png');
link.click();

// Nach dem Export wiederherstellen
calendarWrapper.style.minWidth = originalWidth;
calendarWrapper.style.width = originalWidth;
calendarElement.style.minWidth = originalWidthCalendar;
calendarElement.style.width = originalWidthCalendar;
calendarHeader.style.minWidth = originalWidthCalendar;
calendarHeader.style.width = originalWidthCalendar;
calendarDays.style.minWidth = originalWidthCalendar;
calendarDays.style.width = originalWidthCalendar;
if (buttonGroup) 
buttonGroup.style.display = '';



if (todayButton) 
todayButton.style.display = '';



document.getElementById('exportLogo').style.display = 'none';
}).catch(error => {
console.error('Fehler beim Erstellen des Bildes:', error);
});
}, 500); // Verzögerung, um sicherzustellen, dass der Kalender geladen ist
} else {
console.error('Kalender-Wrapper-Element nicht gefunden!');
}
});
});
		</script>

