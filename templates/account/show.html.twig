			{% if account.host == 'metapi' %}
				<div class="col-lg-6 mt-0 mb-3">
					<div class="card">
						<div class="card-body">
							<h6 class="mb-0 ">Risk to Reward</h6>
							<p class="text-sm ">Profit Faktor liegt bei
								<strong>{{ account.profitFactor|round(2) }}</strong>
							</p>
							<div class="pe-2">
								<div class="chart">
									<div style="width: 100%; margin: auto;">
										<canvas id="profitChart3"></canvas>
									</div>

									<script>
										// Extrahiere die Daten aus Twig
const monthlyAnalytics = {{ account.monthlyAnalytics|json_encode|raw }};

// Labels (x-Achse): Monate
const months = monthlyAnalytics.map(entry => entry.date);

// Daten für jede Währung vorbereiten
const currencies = [...new Set(monthlyAnalytics.flatMap(entry => entry.currencies.map(c => c.currency)))];
const datasets = currencies.map(currency => {
const data = monthlyAnalytics.map(entry => {
const currencyData = entry.currencies.find(c => c.currency === currency);
return currencyData ? currencyData.rewardToRiskRatio : null;
});
return {
label: currency,
data: data,
borderColor: `hsl(${
Math.random() * 360
}, 70%, 50%)`,
backgroundColor: `hsl(${
Math.random() * 360
}, 70%, 70%)`,
tension: 0.1, // Glättung der Linie
spanGaps: true // Verbindet Punkte mit fehlenden Daten
};
});

// Initialisierung des dritten Charts (Reward to Risk Ratio Chart)
const ctx3 = document.getElementById('profitChart3').getContext('2d');
const profitChart3 = new Chart(ctx3, {
type: 'line',
data: {
labels: months,
datasets: datasets,
pointRadius: 2
},
options: {
responsive: true,
plugins: {
legend: {
position: 'top'
},
title: {
display: false,
text: 'Risk to Reward pro Asset'
}
},
scales: {
x: {
title: {
display: false,
text: 'Monat'
},
grid: {
display: false // Vertikales Grid entfernen
},
ticks: {
display: false // Beschriftung auf der x-Achse entfernen
}
},
y: {
title: {
display: false,
text: 'Risk to Reward'
}
}
}
}
});
									</script>
								</div>
