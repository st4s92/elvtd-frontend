{% extends 'base.html.twig' %}

{% block title %}Installation — {{ account.name }}{% endblock %}

{% block body %}
<style>
:root {
	--g: #16a34a;
	--r: #dc2626;
	--y: #f59e0b;
	--bg-root: #f8fafc;
	--border: rgba(0, 0, 0, 0.06);
	--txt-main: #0f172a;
	--txt-dim: #64748b;
}
body { background: var(--bg-root); }

#setupOverlay {
	position: fixed;
	inset: 0;
	z-index: 9999;
	background: var(--bg-root);
	overflow: hidden;
}
#particleCanvas {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
}
.setup-ui {
	position: absolute;
	bottom: 8%;
	left: 50%;
	transform: translateX(-50%);
	z-index: 2;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1rem;
	width: 90%;
	max-width: 460px;
}
.json-display {
	background: rgba(255, 255, 255, 0.92);
	backdrop-filter: blur(12px);
	border: 1px solid var(--border);
	border-radius: 16px;
	padding: 1.25rem 1.75rem;
	font-family: 'JetBrains Mono', 'Fira Code', monospace;
	font-size: 0.78rem;
	color: var(--txt-dim);
	line-height: 1.8;
	width: 100%;
	box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
}
.json-key { color: var(--txt-main); font-weight: 600; }
.json-val-wait { color: var(--y); animation: valPulse 2s ease-in-out infinite; }
.json-val-ok { color: var(--g); font-weight: 600; }
.json-val-err { color: var(--r); font-weight: 600; }
.json-val-num { color: var(--txt-main); font-weight: 700; }
@keyframes valPulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* Progress bar */
.setup-progress { width: 100%; }
.setup-progress-bar {
	width: 100%;
	height: 6px;
	background: rgba(0,0,0,0.06);
	border-radius: 6px;
	overflow: hidden;
}
.setup-progress-fill {
	height: 100%;
	width: 0%;
	background: linear-gradient(90deg, #16a34a, #10b981);
	border-radius: 6px;
	transition: width 0.6s ease;
}
.setup-progress-fill.error { background: linear-gradient(90deg, #dc2626, #ef4444); }
.setup-progress-label {
	display: flex;
	justify-content: space-between;
	margin-top: 0.4rem;
	font-size: 0.72rem;
	font-weight: 600;
}
.setup-progress-pct { color: var(--g); }
.setup-progress-pct.error { color: var(--r); }
.setup-progress-step { color: var(--txt-dim); }

.status-text { text-align: center; }
.status-title {
	font-size: 1.1rem;
	font-weight: 800;
	color: var(--txt-main);
	letter-spacing: -0.02em;
	margin-bottom: 0.25rem;
}
.status-sub {
	font-size: 0.8rem;
	color: var(--txt-dim);
	font-weight: 500;
	transition: opacity 0.3s ease;
}

.setup-error-box {
	background: rgba(220, 38, 38, 0.06);
	border: 1px solid rgba(220, 38, 38, 0.15);
	border-radius: 14px;
	padding: 1.25rem 1.5rem;
	width: 100%;
	display: none;
}
.setup-error-title {
	font-size: 0.85rem;
	font-weight: 800;
	color: var(--r);
	margin-bottom: 0.5rem;
}
.setup-error-msg {
	font-size: 0.8rem;
	color: var(--txt-main);
	line-height: 1.6;
	margin-bottom: 0.75rem;
}
.setup-error-hint {
	font-size: 0.75rem;
	color: var(--txt-dim);
	line-height: 1.5;
	padding-top: 0.5rem;
	border-top: 1px solid rgba(220,38,38,0.1);
}
.setup-error-actions {
	display: flex;
	gap: 0.5rem;
	margin-top: 1rem;
}
.btn-delete-account {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	padding: 0.5rem 1.25rem;
	background: var(--r);
	color: #fff;
	border: none;
	border-radius: 50px;
	font-weight: 700;
	font-size: 0.8rem;
	cursor: pointer;
	transition: transform 0.2s, box-shadow 0.2s;
}
.btn-delete-account:hover {
	transform: translateY(-1px);
	box-shadow: 0 4px 12px rgba(220,38,38,0.3);
}
.btn-retry {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	padding: 0.5rem 1.25rem;
	background: var(--txt-main);
	color: #fff;
	border: none;
	border-radius: 50px;
	font-weight: 700;
	font-size: 0.8rem;
	text-decoration: none;
	cursor: pointer;
	transition: transform 0.2s;
}
.btn-retry:hover { transform: translateY(-1px); color: #fff; }

.setup-success-box {
	background: rgba(22, 163, 74, 0.06);
	border: 1px solid rgba(22, 163, 74, 0.15);
	border-radius: 14px;
	padding: 1.25rem 1.5rem;
	width: 100%;
	text-align: center;
	display: none;
}
.setup-success-title {
	font-size: 0.85rem;
	font-weight: 800;
	color: var(--g);
	margin-bottom: 0.5rem;
}
.btn-continue {
	display: inline-block;
	margin-top: 0.75rem;
	padding: 0.6rem 2rem;
	background: var(--txt-main);
	color: #fff;
	border-radius: 50px;
	font-weight: 700;
	font-size: 0.85rem;
	text-decoration: none;
	transition: transform 0.2s, box-shadow 0.2s;
}
.btn-continue:hover {
	transform: translateY(-1px);
	box-shadow: 0 4px 16px rgba(0,0,0,0.15);
	color: #fff;
}

.node-network { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 320px; height: 320px; z-index: 1; }
.node-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 64px; height: 64px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 32px rgba(0,0,0,0.08); font-size: 1.5rem; color: var(--g); z-index: 3; }
.orbit-node { position: absolute; width: 42px; height: 42px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(0,0,0,0.06); font-size: 0.85rem; }
.orbit-node:nth-child(3) { top: 0; left: 50%; transform: translateX(-50%); }
.orbit-node:nth-child(4) { bottom: 0; left: 50%; transform: translateX(-50%); }
.orbit-node:nth-child(5) { top: 50%; left: 0; transform: translateY(-50%); }
.orbit-node:nth-child(6) { top: 50%; right: 0; transform: translateY(-50%); }
.beam-lines { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 2; }
.beam-line { stroke: url(#beamGrad); stroke-width: 1.5; opacity: 0.6; }
.beam-particle { fill: var(--g); filter: drop-shadow(0 0 4px rgba(22,163,74,0.6)); }
</style>

<div id="setupOverlay">
<canvas id="particleCanvas"></canvas>
<div class="node-network">
	<svg class="beam-lines" viewbox="0 0 320 320">
		<defs>
			<linearGradient id="beamGrad" x1="0%" y1="0%" x2="100%" y2="0%">
				<stop offset="0%" stop-color="#16a34a" stop-opacity="0"/>
				<stop offset="50%" stop-color="#16a34a" stop-opacity="0.7"/>
				<stop offset="100%" stop-color="#16a34a" stop-opacity="0"/>
			</linearGradient>
		</defs>
		<line class="beam-line" x1="160" y1="160" x2="160" y2="12"/>
		<line class="beam-line" x1="160" y1="160" x2="160" y2="308"/>
		<line class="beam-line" x1="160" y1="160" x2="12" y2="160"/>
		<line class="beam-line" x1="160" y1="160" x2="308" y2="160"/>
		<circle class="beam-particle" r="3">
			<animateMotion dur="2s" repeatcount="indefinite" path="M160,160 L160,12 L160,160" keytimes="0;0.5;1" calcmode="linear"/>
		</circle>
		<circle class="beam-particle" r="3">
			<animateMotion dur="2.4s" repeatcount="indefinite" path="M160,160 L160,308 L160,160" keytimes="0;0.5;1" calcmode="linear"/>
		</circle>
		<circle class="beam-particle" r="3">
			<animateMotion dur="2.2s" repeatcount="indefinite" path="M160,160 L12,160 L160,160" keytimes="0;0.5;1" calcmode="linear"/>
		</circle>
		<circle class="beam-particle" r="3">
			<animateMotion dur="2.6s" repeatcount="indefinite" path="M160,160 L308,160 L160,160" keytimes="0;0.5;1" calcmode="linear"/>
		</circle>
	</svg>
	<div class="node-center"><i class="fas fa-plug"></i></div>
	<div class="orbit-node"><i class="fas fa-server" style="color:#6366f1;"></i></div>
	<div class="orbit-node"><i class="fas fa-check-circle" style="color:#10b981;"></i></div>
	<div class="orbit-node"><i class="fas fa-key" style="color:#f59e0b;"></i></div>
	<div class="orbit-node"><i class="fas fa-chart-line" style="color:#ec4899;"></i></div>
</div>
<div class="setup-ui">
	<div class="json-display">
		<div>{</div>
		<div>&nbsp;&nbsp;<span class="json-key">"account"</span>: <span class="json-val-num">"{{ account.login }}"</span></div>
		<div>&nbsp;&nbsp;<span class="json-key">"broker"</span>: <span class="json-val-num">"{{ account.broker }}"</span></div>
		<div>&nbsp;&nbsp;<span class="json-key">"server"</span>: <span class="json-val-wait" id="jServer">"connecting..."</span></div>
		<div>&nbsp;&nbsp;<span class="json-key">"authentication"</span>: <span class="json-val-wait" id="jAuth">"verifying..."</span></div>
		<div>&nbsp;&nbsp;<span class="json-key">"balance"</span>: <span class="json-val-wait" id="jBalance">"loading..."</span></div>
		<div>&nbsp;&nbsp;<span class="json-key">"status"</span>: <span class="json-val-wait" id="jStatus">"installing..."</span></div>
		<div>}</div>
	</div>

	<div class="setup-progress">
		<div class="setup-progress-bar"><div class="setup-progress-fill" id="progressFill"></div></div>
		<div class="setup-progress-label">
			<span class="setup-progress-step" id="progressStep">Warte auf Server...</span>
			<span class="setup-progress-pct" id="progressPct">0%</span>
		</div>
	</div>

	<div class="setup-error-box" id="errorBox">
		<div class="setup-error-title"><i class="fas fa-exclamation-triangle me-1"></i> Installation fehlgeschlagen</div>
		<div class="setup-error-msg" id="errorMsg"></div>
		<div class="setup-error-hint" id="errorHint"></div>
		<div class="setup-error-actions">
			<a href="{{ path('app_account_index') }}" class="btn-retry"><i class="fas fa-redo me-1"></i> Neu anlegen</a>
			<form method="post" action="{{ path('app_account_delete', {'meta_id': account.metaId}) }}" id="deleteForm" style="margin:0;">
				<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ account.metaId) }}">
				<button type="submit" class="btn-delete-account" onclick="return confirm('Account wirklich löschen?')">
					<i class="fas fa-trash-alt"></i> Account löschen
				</button>
			</form>
		</div>
	</div>

	<div class="setup-success-box" id="successBox">
		<div class="setup-success-title"><i class="fas fa-check-circle me-1"></i> Account erfolgreich verbunden</div>
		<a href="{{ path('app_account_show', {'meta_id': account.host == 'denies' ? account.login : account.metaId}) }}" class="btn-continue">Zum Account</a>
	</div>

	<div class="setup-support-box" id="supportBox" style="display:none;background:rgba(99,102,241,0.06);border:1px solid rgba(99,102,241,0.15);border-radius:14px;padding:1.25rem 1.5rem;width:100%;text-align:center;">
		<div style="font-size:0.85rem;font-weight:800;color:#6366f1;margin-bottom:0.4rem;"><i class="fas fa-headset me-1"></i> Verbindung dauert länger als erwartet</div>
		<p style="font-size:0.8rem;color:var(--txt-main);line-height:1.5;margin-bottom:0.75rem;">Die Installation läuft noch, aber die Balance wurde noch nicht synchronisiert. Bitte erstelle ein Ticket, damit unser Support den Account prüfen kann.</p>
		<a href="{{ path('app_helpdesk_new') }}?subject={{ ('Account Installation prüfen: ' ~ account.login)|url_encode }}" class="btn-retry" style="background:#6366f1;"><i class="fas fa-ticket-alt me-1"></i> Support-Ticket erstellen</a>
	</div>

	<div class="status-text">
		<div class="status-title">Account Installation</div>
		<div class="status-sub" id="statusMessage">Verbinde mit dem Trading-Server...</div>
	</div>
</div>
</div>

<script>
(function() {
	// Particle canvas
	const c = document.getElementById('particleCanvas'), ctx = c.getContext('2d');
	let W, H, particles = [], t = 0;
	function resize() { W = c.width = c.offsetWidth; H = c.height = c.offsetHeight; }
	resize(); window.addEventListener('resize', resize);
	for (let i = 0; i < 400; i++) {
		const a = Math.random() * Math.PI * 2, r = Math.pow(Math.random(), 0.6) * Math.min(W, H) * 0.35;
		particles.push({ x: W/2 + Math.cos(a)*r, y: H/2 + Math.sin(a)*r*0.7,
			bx: W/2 + Math.cos(a)*r, by: H/2 + Math.sin(a)*r*0.7,
			vx: (Math.random()-0.5)*0.3, vy: (Math.random()-0.5)*0.3, s: Math.random()*2+0.5, o: Math.random()*0.3+0.1 });
	}
	function draw() {
		ctx.clearRect(0, 0, W, H); t += 0.003;
		particles.forEach(p => {
			p.x = p.bx + Math.sin(t + p.bx*0.01)*20 + p.vx; p.y = p.by + Math.cos(t + p.by*0.01)*15 + p.vy;
			ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI*2);
			ctx.fillStyle = `rgba(22,163,74,${p.o})`; ctx.fill();
		});
		requestAnimationFrame(draw);
	}
	draw();

	// ── Status mapping from Go backend ──
	// Maps server_status_message keywords to { pct, step, isError }
	const STATUS_MAP = {
		// MT4/MT5 installation progress steps
		'FOLDER_DELETE':        { pct: 5,   step: 'Bestehende Installation entfernen...' },
		'INSTALLER_NOT_EXIST':  { pct: 5,   step: 'Installer wird gesucht...', isError: true, hint: 'Der MT-Installer wurde auf dem Server nicht gefunden. Bitte kontaktiere den Support.' },
		'INSTALLING_FAILED':    { pct: 10,  step: 'Installation fehlgeschlagen', isError: true, hint: 'Die Installation der Trading-Plattform ist fehlgeschlagen. Versuche es erneut oder kontaktiere den Support.' },
		'PREPARATION':          { pct: 15,  step: 'Plattform wird vorbereitet...' },
		'PREPARATION_FAILED':   { pct: 15,  step: 'Vorbereitung fehlgeschlagen', isError: true, hint: 'Die Plattform-Vorbereitung ist fehlgeschlagen. Versuche es erneut.' },
		'PATCH_COMMON':         { pct: 25,  step: 'Konfiguration wird geschrieben...' },
		'PATCH_COMMON_INI_FAILED': { pct: 25, step: 'Konfiguration fehlgeschlagen', isError: true, hint: 'Die Serverkonfiguration konnte nicht geschrieben werden. Bitte versuche es erneut.' },
		'SET_LOGIN_DATA':       { pct: 30,  step: 'Login-Daten werden gesetzt...' },
		'SET_LOGIN_DATA_FAILED':{ pct: 30,  step: 'Login-Daten fehlgeschlagen', isError: true, hint: 'Die Login-Daten konnten nicht gesetzt werden. Prüfe, ob Account-Nummer und Passwort korrekt sind.' },
		'First boot':           { pct: 40,  step: 'Erster Start (Initialisierung)...' },
		'FIRST_BOOT_FAILED':    { pct: 40,  step: 'Erster Start fehlgeschlagen', isError: true, hint: 'Der erste Start der Plattform ist fehlgeschlagen. Mögliche Ursachen: Falsches Passwort, falscher Server oder Account-Nummer. Bitte prüfe deine Zugangsdaten.' },
		'PATCH_TERMINAL':       { pct: 55,  step: 'Terminal wird konfiguriert...' },
		'PATCH_TERMINAL_INI_FAILED': { pct: 55, step: 'Terminal-Konfiguration fehlgeschlagen', isError: true, hint: 'Die Terminal-Konfiguration konnte nicht geschrieben werden.' },
		'PATCH_DEFAULT_CHART':  { pct: 65,  step: 'Chart-Konfiguration wird geladen...' },
		'PATCH_DEFAULT_CHART_FAILED': { pct: 65, step: 'Chart-Konfiguration fehlgeschlagen', isError: true, hint: 'Die Chart-Datei konnte nicht geladen werden.' },
		'Second boot':          { pct: 75,  step: 'Zweiter Start (Verbindung)...' },
		'Final boot':           { pct: 75,  step: 'Finaler Start (Verbindung)...' },
		'FINAL_BOOT_FAILED':    { pct: 75,  step: 'Finaler Start fehlgeschlagen', isError: true, hint: 'Die Plattform konnte sich nicht mit dem Broker verbinden. Mögliche Ursachen: Falsches Passwort, falscher Server oder der Account ist deaktiviert.' },
		'PYTHON_START':         { pct: 85,  step: 'Trade-Copier wird gestartet...' },
		'PYTHON_START_FAILED':  { pct: 85,  step: 'Trade-Copier Start fehlgeschlagen', isError: true, hint: 'Der Trade-Copier konnte nicht gestartet werden. Bitte versuche es erneut.' },
		'SUCCESS_INSTALLED':    { pct: 95,  step: 'Installation abgeschlossen, synchronisiere...' },
	};

	function parseStatus(serverStatus) {
		if (!serverStatus) return null;
		// Try matching keywords from the map
		for (const [key, val] of Object.entries(STATUS_MAP)) {
			if (serverStatus.includes(key)) return val;
		}
		// Try parsing numeric prefix like "1.5 [MT4] First boot (INIT)"
		const numMatch = serverStatus.match(/^([\d.]+)/);
		if (numMatch) {
			const num = parseFloat(numMatch[1]);
			const pct = Math.min(90, Math.round((num / 9) * 90));
			return { pct, step: 'Einrichtung läuft... (Schritt ' + numMatch[1] + ')' };
		}
		return { pct: 10, step: 'Einrichtung läuft...' };
	}

	// DOM elements
	const jServer = document.getElementById('jServer');
	const jAuth = document.getElementById('jAuth');
	const jBalance = document.getElementById('jBalance');
	const jStatus = document.getElementById('jStatus');
	const statusMsg = document.getElementById('statusMessage');
	const errorBox = document.getElementById('errorBox');
	const errorMsg = document.getElementById('errorMsg');
	const errorHint = document.getElementById('errorHint');
	const successBox = document.getElementById('successBox');
	const supportBox = document.getElementById('supportBox');
	const progressFill = document.getElementById('progressFill');
	const progressPct = document.getElementById('progressPct');
	const progressStep = document.getElementById('progressStep');

	let pollCount = 0, done = false, lastPct = 0, stuckCount = 0, lastStatus = '', supportShown = false;

	function setOk(el, val) { el.className = 'json-val-ok'; el.textContent = val; }
	function setErr(el, val) { el.className = 'json-val-err'; el.textContent = val; }
	function setNum(el, val) { el.className = 'json-val-num'; el.textContent = val; }
	function setWait(el, val) { el.className = 'json-val-wait'; el.textContent = val; }

	function setProgress(pct, step, isError) {
		progressFill.style.width = pct + '%';
		progressPct.textContent = pct + '%';
		if (step) progressStep.textContent = step;
		if (isError) {
			progressFill.classList.add('error');
			progressPct.classList.add('error');
		}
		lastPct = pct;
	}

	function showError(msg, hint) {
		clearInterval(msgInterval);
		statusMsg.textContent = 'Installation fehlgeschlagen';
		statusMsg.style.color = '#dc2626';
		errorMsg.textContent = msg;
		errorHint.textContent = hint || '';
		errorHint.style.display = hint ? '' : 'none';
		errorBox.style.display = 'block';
		done = true;
	}

	const messages = [
		'Verbinde mit dem Trading-Server...',
		'Authentifiziere Account-Daten...',
		'Installiere Trading-Plattform...',
		'Synchronisiere Kontoinformationen...',
		'Prüfe Server-Verbindung...',
	];
	let msgIdx = 0;
	const msgInterval = setInterval(() => {
		if (done) return;
		msgIdx = (msgIdx + 1) % messages.length;
		statusMsg.style.opacity = '0';
		setTimeout(() => { statusMsg.textContent = messages[msgIdx]; statusMsg.style.opacity = '1'; }, 200);
	}, 2500);

	function poll() {
		if (done) return;
		pollCount++;

		fetch('{{ path("app_account_setup_status", {"id": account.id}) }}')
			.then(r => r.json())
			.then(data => {
				// ── Parse server_status_message ──
				const parsed = parseStatus(data.serverStatus);

				if (parsed) {
					setProgress(parsed.pct, parsed.step, parsed.isError);
					setWait(jStatus, '"' + parsed.step.replace(/\.+$/, '') + '"');

					if (parsed.isError) {
						setErr(jServer, '"error"');
						setErr(jAuth, '"failed"');
						setErr(jBalance, '"—"');
						setErr(jStatus, '"Fehler bei der Einrichtung"');
						showError(parsed.step, parsed.hint);
						return;
					}

					// Update partial JSON
					if (parsed.pct >= 40) {
						setOk(jServer, '"connected"');
					}
					if (parsed.pct >= 55) {
						setOk(jAuth, '"verified"');
					}
				}

				// ── Account-level error from refreshAccountStats ──
				if (data.error && data.error !== 'STÖRUNG') {
					setErr(jServer, '"error"');
					setErr(jAuth, '"failed"');
					setErr(jBalance, '"—"');
					setErr(jStatus, '"Verbindungsfehler"');
					setProgress(lastPct, 'Verbindung fehlgeschlagen', true);
					showError('Die Verbindung zum Trading-Server ist fehlgeschlagen.', 'Prüfe deine Zugangsdaten (Account-Nummer, Passwort, Server) und versuche es erneut.');
					return;
				}

				// ── Success: active + balance > 0 ──
				if (data.isActive) {
					setProgress(100, 'Fertig!', false);
					setOk(jServer, '"connected"');
					setOk(jAuth, '"verified"');
					setNum(jBalance, data.balance.toLocaleString('de-DE', {minimumFractionDigits:2, maximumFractionDigits:2}));
					setOk(jStatus, '"online"');
					clearInterval(msgInterval);
					statusMsg.textContent = 'Account erfolgreich verbunden!';
					statusMsg.style.color = '#16a34a';
					supportBox.style.display = 'none';
					successBox.style.display = 'block';
					done = true;
					return;
				}

				// ── Stuck detection: same status for 30+ seconds ──
				if (data.serverStatus === lastStatus) {
					stuckCount++;
				} else {
					stuckCount = 0;
					lastStatus = data.serverStatus || '';
				}

				if (stuckCount >= 75) { // 150 seconds (2.5 min) same status
					setErr(jStatus, '"keine Reaktion"');
					setProgress(lastPct, 'Einrichtung reagiert nicht', true);
					showError(
						'Die Einrichtung reagiert seit längerer Zeit nicht mehr.',
						'Mögliche Ursachen:\n• Falsches Passwort (WICHTIG: Master-Passwort, nicht Investor!)\n• Falscher Server-Name\n• Falsche Account-Nummer\n• Account ist beim Broker deaktiviert\n\nLösche den Account und lege ihn mit den korrekten Daten neu an.'
					);
					return;
				}

				// ── Timeout: 5 minutes total ──
				if (pollCount >= 150) {
					setErr(jServer, '"timeout"');
					setErr(jStatus, '"timeout"');
					setProgress(lastPct, 'Zeitüberschreitung', true);
					showError(
						'Der Trading-Server hat nicht rechtzeitig geantwortet.',
						'Mögliche Ursachen:\n• Server ist gerade nicht erreichbar\n• Zugangsdaten sind fehlerhaft\n• Account ist beim Broker deaktiviert\n\nLösche den Account und versuche es erneut.'
					);
					return;
				}

				// ── Not started yet (no serverStatus) ──
				if (!parsed && pollCount > 1) {
					setProgress(2, 'Warte auf Server...');
					setWait(jServer, '"queued..."');
				}

				// ── After 3 min without balance: show support button ──
				if (pollCount >= 90 && !supportShown) {
					supportShown = true;
					supportBox.style.display = 'block';
					supportBox.style.animation = 'wizardFadeIn .3s ease';
				}

				setTimeout(poll, 2000);
			})
			.catch(() => {
				if (!done) setTimeout(poll, 2000);
			});
	}

	setTimeout(poll, 2000);
})();
</script>
{% endblock %}
