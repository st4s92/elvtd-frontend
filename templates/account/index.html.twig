			<p class="text-muted mt-2 mb-0" style="font-size:0.8rem;">Der Name deines Brokers oder Prop-Firms. Hilft dir, deine Accounts zu unterscheiden.</p>
		</div>

		{# Step 3: Server #}
		<div class="wizard-step" data-step="2" style="display:none;">
			<label class="fw-bold mb-2" style="font-size:0.95rem;">Server</label>
			<div style="position:relative;">
				{{ form_widget(form.tradeServer, {'attr': {'class': 'form-control rounded-pill px-3 shadow-none border', 'placeholder': 'z.B. FTMO-Server3', 'autocomplete': 'off'}}) }}
				<div id="serverDropdown" class="list-group shadow" style="position:absolute;z-index:1055;width:100%;max-height:200px;overflow-y:auto;display:none;border-radius:12px;"></div>
			</div>
			<p class="text-muted mt-2 mb-0" style="font-size:0.8rem;">Den Server findest du in deinem MT4/MT5-Terminal unter Datei > Konto eröffnen. Tippe, um aus bekannten Servern zu wählen.</p>
		</div>

		{# Step 4: Login #}
		<div class="wizard-step" data-step="3" style="display:none;">
			<label class="fw-bold mb-2" style="font-size:0.95rem;">Login / Account-Nummer</label>
			{{ form_widget(form.login, {'attr': {'class': 'form-control rounded-pill px-3 shadow-none border', 'placeholder': 'z.B. 12345678'}}) }}
			<p class="text-muted mt-2 mb-0" style="font-size:0.8rem;">Deine Account-Nummer, die du vom Broker erhalten hast. Nicht die E-Mail-Adresse.</p>
		</div>

		{# Step 5: Password #}
		<div class="wizard-step" data-step="4" style="display:none;">
			<label class="fw-bold mb-2" style="font-size:0.95rem;">Passwort</label>
