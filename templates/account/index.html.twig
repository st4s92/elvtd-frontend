				<div class="wizard-dot"></div>
				<div class="wizard-dot"></div>
				<div class="wizard-dot"></div>
				<div class="wizard-dot"></div>
				<div class="wizard-dot"></div>
			</div>
		</div>
	</div>
	<div class="modal-body p-4">
		{{ form_start(form, { 'action': path('app_account_new'), 'attr': {'id': 'wizardForm'} }) }}

