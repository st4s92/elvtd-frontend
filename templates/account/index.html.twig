</div></div><script>
(function () {
const c = document.getElementById('particleCanvas'),
ctx = c.getContext('2d');
let W,
H,
particles = [],
beams = [],
t = 0,
stopped = false;
function resize() {
W = c.width = c.offsetWidth;
H = c.height = c.offsetHeight;
}
resize();
window.addEventListener('resize', resize);
const PC = 600;
for (let i = 0; i < PC; i++) {
const a = Math.random() * Math.PI * 2,
r = Math.pow(Math.random(), 0.6) * Math.min(W, H) * 0.35;
particles.push({
x: W / 2 + Math.cos(a) * r,
y: H / 2 + Math.sin(a) * r * 0.7,
bx: W / 2 + Math.cos(a) * r,
by: H / 2 + Math.sin(a) * r * 0.7,
vx: (Math.random() - 0.5) * 0.3,
vy: (Math.random() - 0.5) * 0.3,
sz: Math.random() * 3.5 + 1,
op: Math.random() * 0.5 + 0.15,
phase: Math.random() * Math.PI * 2,
speed: Math.random() * 0.008 + 0.003,
drift: Math.random() * 20 + 5,
hue: 140 + Math.random() * 40
});
}
for (let i = 0; i < 4; i++) {
beams.push({
a: Math.random() * Math.PI,
speed: 0.0003 + Math.random() * 0.0005,
w: 0.5 + Math.random() * 1
});
}
function drawGrid() {
ctx.strokeStyle = 'rgba(15,23,42,0.04)';
ctx.lineWidth = 1;
const s = 50,
ox = (t * 8) % s,
oy = (t * 8) % s;
for (let x = - s + ox; x < W + s; x += s) {
ctx.beginPath();
ctx.moveTo(x, 0);
ctx.lineTo(x, H);
ctx.stroke();
}
for (let y = - s + oy; y < H + s; y += s) {
ctx.beginPath();
ctx.moveTo(0, y);
ctx.lineTo(W, y);
ctx.stroke();
}
}
function drawBeams() {
beams.forEach(b => {
b.a += b.speed;
const cos = Math.cos(b.a),
sin = Math.sin(b.a);
const len = Math.max(W, H);
const grad = ctx.createLinearGradient(W / 2 - cos * len, H / 2 - sin * len, W / 2 + cos * len, H / 2 + sin * len);
grad.addColorStop(0, 'rgba(22,163,74,0)');
grad.addColorStop(0.45, 'rgba(22,163,74,0.06)');
grad.addColorStop(0.5, 'rgba(22,163,74,0.12)');
grad.addColorStop(0.55, 'rgba(22,163,74,0.06)');
grad.addColorStop(1, 'rgba(22,163,74,0)');
ctx.strokeStyle = grad;
ctx.lineWidth = b.w;
ctx.beginPath();
ctx.moveTo(W / 2 - cos * len, H / 2 - sin * len);
ctx.lineTo(W / 2 + cos * len, H / 2 + sin * len);
ctx.stroke();
});
}
function drawParticles() {
particles.forEach(p => {
p.phase += p.speed;
const dx = Math.sin(p.phase) * p.drift;
const dy = Math.cos(p.phase * 0.7) * p.drift * 0.6;
p.x = p.bx + dx + p.vx * t * 0.5;
p.y = p.by + dy + p.vy * t * 0.5;
const pulse = 0.5 + 0.5 * Math.sin(p.phase * 2);
const alpha = p.op * (0.6 + pulse * 0.4);
const sz = p.sz * (0.8 + pulse * 0.3);
ctx.beginPath();
ctx.arc(p.x, p.y, sz, 0, Math.PI * 2);
ctx.fillStyle = `hsla(${
p.hue
},45%,42%,${alpha})`;
ctx.fill();
if (sz > 2.5 && alpha > 0.3) {
ctx.beginPath();
ctx.arc(p.x, p.y, sz * 2, 0, Math.PI * 2);
ctx.fillStyle = `hsla(${
p.hue
},50%,50%,${
alpha * 0.15
})`;
ctx.fill();
}
});
}
function drawAxisLabels() {
ctx.font = '11px system-ui,sans-serif';
ctx.fillStyle = 'rgba(100,116,139,0.25)';
const labels = [
'8,000',
'10,000',
'12,000',
'14,000',
'18,000',
'20,000'
];
const step = W / (labels.length + 1);
labels.forEach((l, i) => {
ctx.fillText(l, step * (i + 1) - 15, H - 30);
});
}
function frame() {
if (stopped) 
return;



t += 0.016;
ctx.clearRect(0, 0, W, H);
drawGrid();
drawBeams();
drawParticles();
drawAxisLabels();
requestAnimationFrame(frame);
}
frame();
window._stopParticles = function () {
stopped = true;
};
})();</script></div><div class="pf-wrap"><div
class="container-custom">

{# ══════════════════════════════════════
