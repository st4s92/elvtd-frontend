@keyframes wizardFadeIn{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:translateX(0)}}
</style></div></div>{# ══ Charts JS ══ #}<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script><script>document.addEventListener('DOMContentLoaded', function () {
					
					const fmt = (n, d = 2) => Number(n).toLocaleString('de-DE', {
					minimumFractionDigits: d,
					maximumFractionDigits: d
					});
					const overlay = document.getElementById('loadingOverlay');
					const content = document.getElementById('portfolioContent');
					const statusMsg = document.getElementById('statusMessage');
					
					// Rotate status messages during load
					const messages = [
					'Fetching account data from brokers...',
					'Synchronising balances & equity...',
					'Calculating open positions...',
					'Aggregating performance metrics...',
					'Analysing risk exposure...',
					'Building portfolio overview...'
					];
					let msgIdx = 0;
					const msgInterval = setInterval(() => {
					msgIdx = (msgIdx + 1) % messages.length;
					statusMsg.style.opacity = '0';
					setTimeout(() => {
					statusMsg.textContent = messages[msgIdx];
					statusMsg.style.opacity = '1';
					}, 200);
					}, 2200);
					
					// Fetch data
					fetch('{{ path("app_account_api_data") }}').then(r => r.json()).then(data => {
					clearInterval(msgInterval);
					
					// Update JSON display with results
					const jAccounts = document.getElementById('jAccounts');
					const jBalance = document.getElementById('jBalance');
					const jPositions = document.getElementById('jPositions');
					const jRisk = document.getElementById('jRisk');
					const jPerf = document.getElementById('jPerf');
					
					const progressFill = document.getElementById('progressFill');
					const progressLabel = document.getElementById('progressLabel');
					const setProgress = (pct) => {
					progressFill.style.width = pct + '%';
					progressLabel.textContent = pct + '%';
					};
					
					const setDone = (el, val) => {
					el.className = 'json-val-done';
					el.textContent = val;
					};
					const setNum = (el, val) => {
					el.className = 'json-val-number';
					el.textContent = val;
					};
					
					setTimeout(() => {
					setDone(jAccounts, `"${
					data.accounts.length
					} accounts loaded"`);
					setProgress(20);
					}, 200);
					setTimeout(() => {
					setNum(jBalance, fmt(data.totalBalance) + ' €');
					setProgress(40);
					}, 500);
					setTimeout(() => {
					setDone(jPositions, '"synced"');
					setProgress(60);
					}, 800);
					setTimeout(() => {
					setDone(jRisk, '"calculated"');
					setProgress(80);
					}, 1100);
					setTimeout(() => {
					setDone(jPerf, '"ready"');
					setProgress(100);
					}, 1400);
					
					setTimeout(() => {
					statusMsg.textContent = 'Portfolio ready.';
					statusMsg.style.color = '#10b981';
					}, 1600);
					
					// Transition to real content
					setTimeout(() => {
					overlay.classList.add('fade-out');
					if (window._stopParticles) 
					window._stopParticles();
					
					
					
					setTimeout(() => {
					overlay.style.display = 'none';
					renderPortfolio(data);
					}, 800);
					}, 2200);
					}).catch(err => {
					clearInterval(msgInterval);
					statusMsg.textContent = 'Fehler beim Laden. Seite wird neu geladen...';
					statusMsg.style.color = '#ef4444';
					setTimeout(() => location.reload(), 2000);
					});
					
					function renderPortfolio(data) {
					const {
					accounts,
					totalEquity,
					totalBalance,
					totalProfit,
					totalDeposits,
					totalWithdrawals,
					totalYesterdayProfit
					} = data;
					
					// Header
					document.getElementById('headerSubtitle').textContent = `${
					accounts.length
					} aktive Accounts \u2022 ${
					fmt(totalBalance)
					} \u20ac Gesamtkapital`;
					
					// Stats
					document.getElementById('valCapital').textContent = fmt(totalBalance) + ' \u20ac';
					const ydClass = totalYesterdayProfit >= 0 ? 'delta-up' : 'delta-down';
					const ydIcon = totalYesterdayProfit >= 0 ? 'arrow-up' : 'arrow-down';
					document.getElementById('deltaCapital').className = `stat-delta ${ydClass}`;
					document.getElementById('deltaCapital').innerHTML = `<i class="fas fa-${ydIcon}"></i> ${
					fmt(totalYesterdayProfit)
					} \u20ac (Vortag)`;
					
					document.getElementById('valProfit').textContent = fmt(totalProfit) + ' \u20ac';
					if (totalDeposits > 0) {
					const totalGain = ((totalBalance - totalDeposits) / totalDeposits) * 100;
					const gClass = totalGain >= 0 ? 'delta-up' : 'delta-down';
					const gIcon = totalGain >= 0 ? 'chart-line' : 'chart-bar';
					document.getElementById('deltaGrowth').className = `stat-delta ${gClass}`;
					document.getElementById('deltaGrowth').innerHTML = `<i class="fas fa-${gIcon}"></i> ${
					fmt(totalGain)
					}% Wachstum`;
					}
					
					const openPnl = totalEquity - totalBalance;
					const openColor = openPnl >= 0 ? 'var(--g)' : 'var(--r)';
					document.getElementById('valOpen').style.color = openColor;
					document.getElementById('valOpen').textContent = fmt(openPnl) + ' \u20ac';
					const dd = totalBalance > 0 ? ((totalEquity - totalBalance) / totalBalance * 100) : 0;
					document.getElementById('valDrawdown').textContent = `Portfolio Drawdown: ${
					dd.toFixed(2)
					}%`;
					
					document.getElementById('valDeposits').textContent = fmt(totalDeposits, 0) + ' \u20ac';
					document.getElementById('valWithdrawals').textContent = fmt(totalWithdrawals, 0) + ' \u20ac';
					
					// Accounts grid
					const grid = document.getElementById('accountsGrid');
					accounts.forEach((acc, idx) => {
					const openPnL = acc.equity - acc.balance;
					const ddPct = acc.balance > 0 ? (openPnL / acc.balance * 100) : 0;
					const pnlColor = openPnL >= 0 ? 'var(--g)' : 'var(--r)';
					const profitColor = acc.profit >= 0 ? 'var(--g)' : 'var(--r)';
					const platformIcon = acc.platform === 'ctrader' ? 'dna' : 'bolt';

					let statusHtml = '';
					let cardClass = 'acc-card-online';
					const isDisc = acc.error === 'DISCONNECTED' || acc.error === 'ST\u00d6RUNG';
					const isError = acc.error && acc.error.length > 0;

					if (isDisc) {
					const label = acc.error === 'ST\u00d6RUNG' ? 'St\u00f6rung' : 'Disconnected';
					statusHtml = `<div class="pill pill-error"><span class="dot dot-r"></span> ${label}</div>`;
					cardClass = 'acc-card-error';
					} else if (isError && acc.error !== 'subscription expired') {
					const label = acc.isActive ? 'Online' : 'St\u00f6rung';
					statusHtml = `<div class="pill pill-offline"><span class="dot dot-off"></span> ${label}</div>`;
					cardClass = 'acc-card-offline';
					} else {
					const pillClass = acc.isActive ? 'pill-online' : 'pill-offline';
					const dotClass = acc.isActive ? 'dot-on' : 'dot-off';
					const label = acc.isActive ? 'Online' : 'Pausiert';
					statusHtml = `<div class="pill ${pillClass}"><span class="dot ${dotClass}"></span> ${label}</div>`;
					cardClass = acc.isActive ? 'acc-card-online' : 'acc-card-offline';
					}

					const agentHtml = acc.agents && acc.agents.length > 0
					? acc.agents.map(a => `<span class="acc-card-agent" style="color:var(--g);"><span class="dot dot-on" style="width:5px;height:5px;"></span> ${a.name}</span>`).join(' ')
					: `<span class="acc-card-agent" style="color:var(--txt-dim);"><i class="fas fa-link" style="font-size:0.6rem;"></i> Kein Agent</span>`;

					const card = document.createElement('div');
					card.className = `acc-card ${cardClass}`;
					card.style.opacity = '0';
					card.style.transform = 'translateY(12px)';
					card.style.transition = `opacity 0.4s ease ${idx * 0.06}s, transform 0.4s ease ${idx * 0.06}s`;
					card.onclick = (e) => {
					if (!e.target.closest('a') && !e.target.closest('form') && !e.target.closest('button')) {
					window.location.href = acc.showUrl;
					}
					};
					card.innerHTML = `
					<div class="acc-card-top">
						<div>
							<div class="acc-card-name">
								<i class="fas fa-${platformIcon}" style="font-size:0.75rem;opacity:0.3;margin-right:4px;"></i>
								${acc.name}
							</div>
							<div class="acc-card-meta">
								<span class="badge-acc">#${acc.login}</span>
								<span class="badge-acc">${acc.broker}</span>
								<span class="badge-acc">${acc.platform.toUpperCase()}</span>
							</div>
						</div>
						<div class="acc-card-status">${statusHtml}</div>
					</div>
					<div class="acc-card-numbers">
						<div class="acc-num-item">
							<div class="acc-num-label">Equity</div>
							<div class="acc-num-val">${fmt(acc.equity)}</div>
						</div>
						<div class="acc-num-item">
							<div class="acc-num-label">Balance</div>
							<div class="acc-num-val" style="color:var(--txt-dim);">${fmt(acc.balance)}</div>
						</div>
						<div class="acc-num-item">
							<div class="acc-num-label">Offener P&L</div>
							<div class="acc-num-val" style="color:${pnlColor};">${fmt(openPnL)} <span style="font-size:0.7rem;opacity:0.7;">${ddPct.toFixed(2)}%</span></div>
						</div>
						<div class="acc-num-item">
							<div class="acc-num-label">Gesamtprofit</div>
							<div class="acc-num-val" style="color:${profitColor};">${fmt(acc.profit)} <span style="font-size:0.7rem;opacity:0.7;">${Number(acc.gain).toFixed(2)}%</span></div>
						</div>
					</div>
					<div class="acc-card-footer">
						<div>${agentHtml}</div>
						<div class="acc-card-actions">
							<a href="${acc.showUrl}" class="btn-icon" title="Ansehen"><i class="fas fa-eye"></i></a>
							<a href="${acc.editUrl}" class="btn-icon" title="Bearbeiten"><i class="fas fa-pen"></i></a>
							<form method="post" action="${acc.deleteUrl}" onsubmit="return confirm('L\u00f6schen?');" style="margin:0;">
								<input type="hidden" name="_token" value="${acc.deleteToken}">
								<button class="btn-icon btn-icon-danger" type="submit" title="L\u00f6schen"><i class="fas fa-trash"></i></button>
							</form>
						</div>
					</div>`;
					grid.appendChild(card);
					});
					
					// Show content with staggered reveals
					content.classList.add('revealed');
					
					requestAnimationFrame(() => { // Reveal stat cards
					document.querySelectorAll('.stat-card').forEach((el, i) => {
					setTimeout(() => el.classList.add('revealed'), i * 100);
					});
					// Reveal charts
					setTimeout(() => {
					document.getElementById('chartPerf').classList.add('revealed');
					document.getElementById('chartAlloc').classList.add('revealed');
					}, 500);
					// Reveal grid
					setTimeout(() => {
					document.getElementById('tableWrap').classList.add('revealed');
					grid.querySelectorAll('.acc-card').forEach(card => {
					requestAnimationFrame(() => {
					card.style.opacity = '1';
					card.style.transform = 'translateY(0)';
					});
					});
					}, 700);
					});
					
					// Build charts
					buildCharts(accounts);
					}
					
					function buildCharts(accounts) { // 1. Performance Line Chart
					const ctxLine = document.getElementById('lineChart');
					if (ctxLine) {
					const datasets = [];
					accounts.forEach((acc, idx) => {
					if (acc.dailyGrowth && acc.dailyGrowth.length > 0) {
					const firstBal = Math.abs(acc.dailyGrowth[0].balance || 1);
					datasets.push({
					label: acc.name,
					data: acc.dailyGrowth.map(d => ({
					x: d.date,
					y: (d.balance || 0) / (firstBal > 0 ? firstBal : 1)
					})),
					borderColor: `hsl(${
					200 + (idx + 1) * 25
					}, 70%, 50%)`,
					backgroundColor: `hsla(${
					200 + (idx + 1) * 25
					}, 70%, 50%, 0.05)`,
					tension: 0.4,
					fill: true,
					pointRadius: 0,
					borderWidth: 2
					});
					}
					});
					new Chart(ctxLine, {
					type: 'line',
					data: {
					datasets
					},
					options: {
					responsive: true,
					maintainAspectRatio: false,
					interaction: {
					intersect: false,
					mode: 'index'
					},
					scales: {
					x: {
					type: 'time',
					time: {
					unit: 'day'
					},
					grid: {
					display: false
					}
					},
					y: {
					grid: {
					color: 'rgba(0,0,0,0.03)'
					},
					title: {
					display: true,
					text: 'Wachstumsfaktor'
					}
					}
