			<animateMotion dur="2.2s" repeatcount="indefinite" path="M160,160 L12,160 L160,160" keytimes="0;0.5;1" calcmode="linear"/>
		</circle>
		<circle class="beam-particle" r="3">
			<animateMotion dur="2.6s" repeatcount="indefinite" path="M160,160 L308,160 L160,160" keytimes="0;0.5;1" calcmode="linear"/>
