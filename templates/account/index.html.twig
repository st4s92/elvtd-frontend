					});</script><script>
(function() {
	const steps = document.querySelectorAll('.wizard-step');
	const dots = document.querySelectorAll('.wizard-dot');
	const btnNext = document.getElementById('wizardNext');
	const btnBack = document.getElementById('wizardBack');
	const btnSubmit = document.getElementById('wizardSubmit');
	const title = document.getElementById('wizardTitle');
	const platformSelect = document.getElementById('account_platform');
	const serverInput = document.getElementById('account_tradeServer');
	const dropdown = document.getElementById('serverDropdown');

	const titles = ['Plattform', 'Broker', 'Server', 'Login', 'Passwort', 'Benennen'];
	let current = 0;

	// Steps that should be skipped for cTrader (server, login, password)
	function getVisibleSteps() {
		const p = platformSelect.value;
		if (p === 'ctrader') return [0, 1, 5]; // platform, broker, name only
		return [0, 1, 2, 3, 4, 5]; // all steps for mt4/mt5
	}

	function currentVisible() { return getVisibleSteps(); }
	function currentIdx() { return currentVisible().indexOf(current); }

	function goTo(step) {
		current = step;

		steps.forEach(s => s.style.display = 'none');
		steps[step].style.display = 'block';
		steps[step].style.animation = 'none';
		steps[step].offsetHeight; // trigger reflow
		steps[step].style.animation = '';

		const visible = currentVisible();
		const idx = visible.indexOf(step);
		dots.forEach((d, i) => {
			d.className = 'wizard-dot';
			const stepForDot = visible[i];
			if (stepForDot === undefined) { d.style.display = 'none'; return; }
			d.style.display = '';
			if (stepForDot < step) d.classList.add('done');
			else if (stepForDot === step) d.classList.add('active');
		});
		dots.forEach((d, i) => { if (i >= visible.length) d.style.display = 'none'; });

		btnBack.style.display = idx > 0 ? '' : 'none';
		const isLast = idx === visible.length - 1;
		btnNext.style.display = isLast ? 'none' : '';
		btnSubmit.style.display = isLast ? '' : 'none';

		title.textContent = titles[step];

		const input = steps[step].querySelector('input, select');
		if (input) setTimeout(() => input.focus(), 100);
	}

	function validate() {
		const input = steps[current].querySelector('input, select');
		if (!input) return true;
		if (!input.value.trim()) {
			input.classList.add('is-invalid');
			input.addEventListener('input', () => input.classList.remove('is-invalid'), { once: true });
			input.focus();
			return false;
		}
		return true;
	}

	btnNext.addEventListener('click', () => {
		if (!validate()) return;
		const visible = currentVisible();
		const idx = currentIdx();
		if (idx < visible.length - 1) goTo(visible[idx + 1]);
	});

	btnBack.addEventListener('click', () => {
		const visible = currentVisible();
		const idx = currentIdx();
		if (idx > 0) goTo(visible[idx - 1]);
	});

	// Reset wizard when modal opens
	document.getElementById('addAccountModal').addEventListener('show.bs.modal', () => {
		goTo(0);
	});

	// Allow Enter to go next (not submit)
	document.getElementById('wizardForm').addEventListener('keydown', function(e) {
		if (e.key === 'Enter' && btnSubmit.style.display === 'none') {
			e.preventDefault();
			btnNext.click();
		}
	});

	// Server autocomplete
	let debounceTimer = null;
	function fetchServers() {
		const platform = platformSelect.value;
		if (platform !== 'mt4' && platform !== 'mt5') { dropdown.style.display = 'none'; return; }
		const q = serverInput.value.trim();
		clearTimeout(debounceTimer);
		debounceTimer = setTimeout(() => {
			fetch('{{ path("app_account_api_servers") }}?platform=' + encodeURIComponent(platform) + '&q=' + encodeURIComponent(q))
				.then(r => r.json())
				.then(servers => {
					dropdown.innerHTML = '';
					if (!servers.length) { dropdown.style.display = 'none'; return; }
					servers.forEach(s => {
						const item = document.createElement('a');
						item.href = '#';
						item.className = 'list-group-item list-group-item-action';
						item.style.cssText = 'font-size:0.85rem;padding:8px 16px;';
						item.textContent = s;
						item.addEventListener('mousedown', function(e) {
							e.preventDefault();
							serverInput.value = s;
							dropdown.style.display = 'none';
						});
						dropdown.appendChild(item);
					});
					dropdown.style.display = 'block';
				});
		}, 200);
	}
	serverInput.addEventListener('input', fetchServers);
	serverInput.addEventListener('focus', fetchServers);
	serverInput.addEventListener('blur', () => { setTimeout(() => dropdown.style.display = 'none', 150); });

	goTo(0);
})();
</script>{% endblock %}
