			<p class="text-muted mt-2 mb-0" style="font-size:0.8rem;">WICHTIG: Dein Master-Passwort, NICHT das Investor-Passwort. Wird verschlüsselt gespeichert und nur zur Verbindung genutzt.</p>
		</div>

		{# Step 6: Name #}
		<div class="wizard-step" data-step="5" style="display:none;">
			<label class="fw-bold mb-2" style="font-size:0.95rem;">Account-Name</label>
			{{ form_widget(form.name, {'attr': {'class': 'form-control rounded-pill px-3 shadow-none border', 'placeholder': 'z.B. FTMO Challenge 100k'}}) }}
			<p class="text-muted mt-2 mb-0" style="font-size:0.8rem;">Ein frei wählbarer Name, damit du den Account in deinem Dashboard wiederfindest.</p>
		</div>

		<div class="d-flex gap-2 mt-4">
			<button type="button" id="wizardBack" class="btn btn-outline-secondary rounded-pill py-2 fw-bold flex-fill" style="display:none;">Zurück</button>
			<button type="button" id="wizardNext" class="btn btn-dark rounded-pill py-2 fw-bold flex-fill">Weiter</button>
			<button type="submit" id="wizardSubmit" class="btn btn-dark rounded-pill py-2 fw-bold flex-fill" style="display:none;">Verknüpfen</button>
		</div>

		{{ form_end(form) }}
	</div>
</div>
<style>
.wizard-dot{height:4px;flex:1;border-radius:4px;background:var(--bs-gray-300);transition:background .3s}
.wizard-dot.active{background:var(--bs-dark)}
